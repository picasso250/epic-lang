fun mir_inject_all_runtime_helpers(program: MirProgram): void {
    mir_runtime_add_global(program, "str.runtime.bool.true", "true")
    mir_runtime_add_global(program, "str.runtime.bool.false", "false")
    mir_runtime_add_global(program, "str.runtime.empty", "")
    push(program.functions, mir_runtime_emit_ep_slice_u8_from_str())
    push(program.functions, mir_runtime_emit_ep_str_from_slice_u8())
    push(program.functions, mir_runtime_emit_ep_str_cat())
    push(program.functions, mir_runtime_emit_ep_slice_u8_alloc())
    push(program.functions, mir_runtime_emit_ep_slice_u8_get())
    push(program.functions, mir_runtime_emit_ep_slice_i64_new())
    push(program.functions, mir_runtime_emit_ep_slice_i64_get())
    push(program.functions, mir_runtime_emit_ep_slice_i64_set())
    push(program.functions, mir_runtime_emit_ep_slice_i64_push())
    push(program.functions, mir_runtime_emit_ep_slice_ptr_new())
    push(program.functions, mir_runtime_emit_ep_slice_ptr_get())
    push(program.functions, mir_runtime_emit_ep_slice_ptr_set())
    push(program.functions, mir_runtime_emit_ep_slice_ptr_push())
    push(program.functions, mir_runtime_emit_ep_slice_u8_set())
    push(program.functions, mir_runtime_emit_ep_slice_u8_push())
    push(program.functions, mir_runtime_emit_ep_slice_u8_slice())
    push(program.functions, mir_runtime_emit_ep_slice_u8_extend())
    push(program.functions, mir_runtime_emit_ep_map_str_i64_new())
    push(program.functions, mir_runtime_emit_ep_map_str_i64_get())
    push(program.functions, mir_runtime_emit_ep_map_str_i64_set())
