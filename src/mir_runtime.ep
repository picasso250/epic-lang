fun mir_runtime_param(name: str, typ: str): MirParam {
    let p = new MirParam
    p.name = name
    p.typ = typ
    return p
}

fun mir_runtime_has_global(program: MirProgram, name: str): bool {
    let i = 0
    while i < len(program.globals) {
        if program.globals[i].name == name { return true }
        i = i + 1
    }
    return false
}

fun mir_runtime_add_global(program: MirProgram, name: str, init: str): void {
    if !mir_runtime_has_global(program, name) { push(program.globals, mir_global_string(name, init)) }
}


