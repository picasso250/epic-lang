#
# Minimal self-hosted X64IR DTO and text output helpers.
# This intentionally covers the pretty-print oracle first; validation and
# machine encoding belong to later bootstrap stages.
#

struct X64Operand {
    kind: str
    name: str
    value: i64
    base: str
    disp: i64
    symbol: str
    size: i64
    has_base: bool
    has_symbol: bool
}

struct X64Item {
    kind: str
    name: str
    op: str
    operands: X64Operand[]
    values: i64[]
    count: i64
}

struct X64Program {
    items: X64Item[]
}

fun x64_operand_empty(): X64Operand {
    let op = new X64Operand
    op.kind = ""
    op.name = ""
    op.value = 0
    op.base = ""
    op.disp = 0
    op.symbol = ""
    op.size = 8
    op.has_base = false
    op.has_symbol = false
    ret op
}

fun x64_reg(name: str): X64Operand {
    let op = x64_operand_empty()
    op.kind = "reg"
    op.name = name
    ret op
}

fun x64_imm(value: i64): X64Operand {
    let op = x64_operand_empty()
    op.kind = "imm"
    op.value = value
    ret op
}

fun x64_symbol(name: str): X64Operand {
    let op = x64_operand_empty()
    op.kind = "symbol"
    op.name = name
    ret op
}

fun x64_label_ref(name: str): X64Operand {
    let op = x64_operand_empty()
    op.kind = "label_ref"
    op.name = name
    ret op
}

fun x64_mem_base(base: str, disp: i64, size: i64): X64Operand {
    let op = x64_operand_empty()
    op.kind = "mem"
    op.base = base
    op.disp = disp
    op.size = size
    op.has_base = true
    ret op
}

fun x64_mem_symbol(symbol: str, size: i64): X64Operand {
    let op = x64_operand_empty()
    op.kind = "mem"
    op.symbol = symbol
    op.size = size
    op.has_symbol = true
    ret op
}

fun x64_item_empty(kind: str): X64Item {
    let item = new X64Item
    item.kind = kind
    item.name = ""
    item.op = ""
    item.operands = new X64Operand[0]
    item.values = new i64[0]
    item.count = 0
    ret item
}

fun x64_program_empty(): X64Program {
    let program = new X64Program
    program.items = new X64Item[0]
    ret program
}

fun x64_add_global(program: X64Program, name: str): void {
    let item = x64_item_empty("global")
    item.name = name
    program.items.push(item)
}

fun x64_add_extern(program: X64Program, name: str): void {
    let item = x64_item_empty("extern")
    item.name = name
    program.items.push(item)
}

fun x64_add_section(program: X64Program, name: str): void {
    let item = x64_item_empty("section")
    item.name = name
    program.items.push(item)
}

fun x64_add_label(program: X64Program, name: str): void {
    let item = x64_item_empty("label")
    item.name = name
    program.items.push(item)
}

fun x64_add_inst(program: X64Program, op: str, operands: X64Operand[]): void {
    let item = x64_item_empty("inst")
    item.op = op
    item.operands = operands
    program.items.push(item)
}

fun x64_add_inst0(program: X64Program, op: str): void {
    x64_add_inst(program, op, new X64Operand[0])
}

fun x64_add_inst1(program: X64Program, op: str, a: X64Operand): void {
    let operands = new X64Operand[0]
    operands.push(a)
    x64_add_inst(program, op, operands)
}

fun x64_add_inst2(program: X64Program, op: str, a: X64Operand, b: X64Operand): void {
    let operands = new X64Operand[0]
    operands.push(a)
    operands.push(b)
    x64_add_inst(program, op, operands)
}

fun x64_add_data_bytes(program: X64Program, label: str, values: i64[]): void {
    let item = x64_item_empty("data_bytes")
    item.name = label
    item.values = values
    program.items.push(item)
}

fun x64_add_data_zero(program: X64Program, label: str, count: i64): void {
    let item = x64_item_empty("data_zero")
    item.name = label
    item.count = count
    program.items.push(item)
}

fun x64_size_prefix(size: i64): str {
    if size == 1 {
        ret "byte "
    }
    ret "qword "
}

fun x64_mem_addr_text(op: X64Operand): str {
    if op.has_symbol {
        ret op.symbol
    }
    if op.disp == 0 {
        ret op.base
    }
    if op.disp > 0 {
        ret str_cat2(str_cat2(op.base, "+"), str(op.disp))
    }
    ret str_cat2(op.base, str(op.disp))
}

fun x64_operand_text(op: X64Operand): str {
    if op.kind == "reg" {
        ret op.name
    }
    if op.kind == "imm" {
        ret str(op.value)
    }
    if op.kind == "symbol" {
        ret op.name
    }
    if op.kind == "label_ref" {
        ret op.name
    }
    if op.kind == "mem" {
        ret str_cat2(str_cat2(x64_size_prefix(op.size), "["), str_cat2(x64_mem_addr_text(op), "]"))
    }
    ret "<bad operand>"
}

fun x64_operands_text(operands: X64Operand[]): str {
    let buf = make_str_buf()
    let i = 0
    for i < len(operands) {
        if i > 0 {
            str_buf_extend(buf, ", ")
        }
        str_buf_extend(buf, x64_operand_text(operands[i]))
        i = i + 1
    }
    ret str_buf_finish(buf)
}

fun x64_values_text(values: i64[]): str {
    let buf = make_str_buf()
    let i = 0
    for i < len(values) {
        if i > 0 {
            str_buf_extend(buf, ", ")
        }
        str_buf_extend(buf, str(values[i]))
        i = i + 1
    }
    ret str_buf_finish(buf)
}

fun x64_item_text(item: X64Item): str {
    if item.kind == "global" {
        ret str_cat2(str_cat2("global ", item.name), "\n")
    }
    if item.kind == "extern" {
        ret str_cat2(str_cat2("extern ", item.name), "\n")
    }
    if item.kind == "section" {
        ret str_cat2(str_cat2("section ", item.name), "\n")
    }
    if item.kind == "label" {
        ret str_cat2(str_cat2(item.name, ":"), "\n")
    }
    if item.kind == "inst" {
        if len(item.operands) == 0 {
            ret str_cat2(str_cat2("    ", item.op), "\n")
        }
        ret str_cat2(str_cat2(str_cat2(str_cat2("    ", item.op), " "), x64_operands_text(item.operands)), "\n")
    }
    if item.kind == "data_bytes" {
        ret str_cat2(str_cat2(str_cat2(item.name, ": db "), x64_values_text(item.values)), "\n")
    }
    if item.kind == "data_zero" {
        ret str_cat2(str_cat2(str_cat2(str_cat2(item.name, ": times "), str(item.count)), " db 0"), "\n")
    }
    ret "<bad x64 item>\n"
}

fun x64_program_text(program: X64Program): str {
    let buf = make_str_buf()
    let i = 0
    for i < len(program.items) {
        str_buf_extend(buf, x64_item_text(program.items[i]))
        i = i + 1
    }
    ret str_buf_finish(buf)
}
