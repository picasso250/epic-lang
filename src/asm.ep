#
# Epic's structured private NASM-subset assembler. Codegen builds AsmProgram
# directly; runtime/*.asm enters through the parser below.
#
type AsmOperandKind = Register | Immediate | Memory | Symbol
type AsmInstructionKind = Mov | Lea | Movzx | Add | Sub | And | Or | Xor | Cmp | Test | Imul | Call | Jmp | Je | Jz | Jne | Jnz | Jl | Jge | Jle | Jg | Jns | Sete | Setne | Setl | Setge | Setle | Setg | Shl | Shr | Sar | Inc | Dec | Div | Idiv | Neg | Push | Pop | Ret | Cqo | RepStosd
type AsmSectionKind = Text | Data
type AsmItemKind = Section | Extern | Label | Instruction | Bytes | DataInteger | DataSymbol | RepeatData

type AsmSymbol {
    name: str
    section: i64
    offset: i64
    external: i64
}
type AsmReloc {
    section: i64
    offset: i64
    kind: i64
    symbol: str
    symbol_index: i64
    addend: i64
}
type ExeImage {
    text: u8[]
    data: u8[]
    symbols: AsmSymbol[]
    relocs: AsmReloc[]
    entry_offset: i64
    section: i64
}
type AsmOperand {
    kind: AsmOperandKind
    width: i64
    reg: i64
    imm: i64
    symbol: str
    base: i64
    index: i64
    scale: i64
    disp: i64
}

type AsmItem {
    kind: AsmItemKind
    section: AsmSectionKind
    name: str
    instruction: AsmInstructionKind
    a: AsmOperand
    b: AsmOperand
    bytes: u8[]
    width: i64
    value: i64
    repeat_count: i64
}
type AsmProgram {
    items: AsmItem[]
    entry_symbol: str
}
type AsmProgramParser {
    program: AsmProgram
    scope: str
    section: AsmSectionKind
    has_section: i64
}

fun asm_die(msg: str): i64 {
    print("assembler: ")
    print(msg)
    print("\n")
    os.ExitProcess(1)
    return 0
}
fun asm_slice(s: str, start: i64, end: i64): str {
    return str_new(s.data + start, end - start)
}
fun asm_trim(s: str): str {
    let a = 0
    let b = len(s)
    while a < b && (s.data[a] == 32 || s.data[a] == 9 || s.data[a] == 13) {
        a += 1
    }
    while b > a && (s.data[b - 1] == 32 || s.data[b - 1] == 9 || s.data[b - 1] == 13) {
        b -= 1
    }
    return asm_slice(s, a, b)
}
fun asm_starts(s: str, prefix: str): i64 {
    if len(s) < len(prefix) {
        return 0
    }
    for i: 0:len(prefix) {
        if s.data[i] != prefix.data[i] {
            return 0
        }
    }
    return 1
}
fun asm_find(s: str, ch: i64): i64 {
    for i: 0:len(s) {
        if s.data[i] == ch {
            return i
        }
    }
    return -1
}
fun asm_remove_spaces(s: str): str {
    let out = new u8[]
    for i: 0:len(s) {
        if s.data[i] != 32 && s.data[i] != 9 {
            push(out, s.data[i])
        }
    }
    return str_new(out.data, len(out))
}
fun asm_digit(c: i64): i64 {
    if c >= 48 && c <= 57 {
        return c - 48
    }
    if c >= 65 && c <= 70 {
        return c - 55
    }
    if c >= 97 && c <= 102 {
        return c - 87
    }
    return -1
}
fun asm_is_number(s: str): i64 {
    if len(s) == 0 {
        return 0
    }
    let i = 0
    if s.data[0] == 45 {
        i = 1
    }
    let hex = 0
    if i + 2 <= len(s) && s.data[i] == 48 && (s.data[i + 1] == 120 || s.data[i + 1] == 88) {
        hex = 1
        i += 2
    }
    if i >= len(s) {
        return 0
    }
    while i < len(s) {
        if hex == 0 && (s.data[i] < 48 || s.data[i] > 57) {
            return 0
        }
        if hex == 1 && asm_digit(s.data[i]) < 0 {
            return 0
        }
        i += 1
    }
    return 1
}
fun asm_number(s: str): i64 {
    let sign = 1
    let i = 0
    if s[0] == 45 {
        sign = -1
        i = 1
    }
    let base = 10
    if i + 2 <= len(s) && s.data[i] == 48 && (s.data[i + 1] == 120 || s.data[i + 1] == 88) {
        base = 16
        i += 2
    }
    let value = 0
    while i < len(s) {
        value = value * base + asm_digit(s.data[i])
        i += 1
    }
    return value * sign
}
fun asm_reg(name: str): i64 {
    if name == "rax" || name == "eax" || name == "al" {
        return 0
    }
    if name == "rcx" || name == "ecx" || name == "cl" {
        return 1
    }
    if name == "rdx" || name == "edx" || name == "dl" {
        return 2
    }
    if name == "rbx" || name == "ebx" || name == "bl" {
        return 3
    }
    if name == "rsp" || name == "esp" {
        return 4
    }
    if name == "rbp" || name == "ebp" {
        return 5
    }
    if name == "rsi" || name == "esi" {
        return 6
    }
    if name == "rdi" || name == "edi" {
        return 7
    }
    if name == "r8" || name == "r8d" || name == "r8b" {
        return 8
    }
    if name == "r9" || name == "r9d" || name == "r9b" {
        return 9
    }
    if name == "r10" || name == "r10d" || name == "r10b" {
        return 10
    }
    if name == "r11" || name == "r11d" || name == "r11b" {
        return 11
    }
    return -1
}
fun asm_reg_width(name: str): i64 {
    if name == "al" || name == "bl" || name == "cl" || name == "dl" || name == "r8b" || name == "r9b" || name == "r10b" || name == "r11b" {
        return 8
    }
    if name == "eax" || name == "ebx" || name == "ecx" || name == "edx" || name == "esp" || name == "ebp" || name == "esi" || name == "edi" || name == "r8d" || name == "r9d" || name == "r10d" || name == "r11d" {
        return 32
    }
    if asm_reg(name) >= 0 {
        return 64
    }
    return 0
}
fun asm_operand_new(kind: AsmOperandKind): AsmOperand {
    let op = new AsmOperand
    op.kind = kind
    op.width = 0
    op.reg = -1
    op.base = -1
    op.index = -1
    op.scale = 1
    op.symbol = ""
    return op
}
fun asm_register(reg: i64, width: i64): AsmOperand {
    let op = asm_operand_new(AsmOperandKind.Register)
    op.reg = reg
    op.width = width
    return op
}
fun asm_rax(): AsmOperand {
    return asm_register(0, 64)
}
fun asm_eax(): AsmOperand {
    return asm_register(0, 32)
}
fun asm_al(): AsmOperand {
