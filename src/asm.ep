#
# Epic's structured private NASM-subset assembler. Codegen builds AsmProgram
# directly; runtime/*.asm enters through the parser below.
#
type AsmOperandKind = Register | Immediate | Memory | Symbol
type AsmInstructionKind = Mov | Lea | Movzx | Movsx | Movsxd | Add | Sub | And | Or | Xor | Cmp | Test | Imul | Call | Jmp | Je | Jz | Jne | Jnz | Jb | Jae | Jbe | Ja | Jl | Jge | Jle | Jg | Jns | Sete | Setne | Setb | Setae | Setbe | Seta | Setl | Setge | Setle | Setg | Shl | Shr | Sar | Inc | Dec | Div | Idiv | Neg | Push | Pop | Ret | Cqo | RepStosd
type AsmSectionKind = Text | Data
type AsmItemKind = Section | Extern | Label | Instruction | Bytes | DataInteger | DataSymbol | RepeatData

type AsmSymbol {
    name: str
    section: i64
    offset: i64
    external: bool
    defined: bool
}
type AsmReloc {
    section: i64
    offset: i64
    kind: i64
    symbol_index: i64
    addend: i64
}
type ExeImage {
    text: u8[]
    data: u8[]
    symbols: AsmSymbol[]
    relocs: AsmReloc[]
    entry_offset: i64
    section: i64
}
type AsmOperand {
    kind: AsmOperandKind
    width: i64
    reg: i64
    imm: i64
    symbol_index: i64
    base: i64
    index: i64
    scale: i64
    disp: i64
}

type AsmItem {
    kind: AsmItemKind
    section: AsmSectionKind
    symbol_index: i64
    instruction: AsmInstructionKind
    a: AsmOperand
    b: AsmOperand
    bytes: u8[]
    width: i64
    value: i64
    repeat_count: i64
}
type AsmProgram {
    items: AsmItem[]
    symbols: AsmSymbol[]
    named_symbols: i64[]
    entry_symbol_index: i64
}
type AsmProgramParser {
    program: AsmProgram
    scope: str
    section: AsmSectionKind
    has_section: bool
}
type AsmRenderer {
    out: u8[]
    program: AsmProgram
}

fun asm_die(msg: str): void {
    print("assembler: ")
    print(msg)
    print("\n")
    exit(1)
    ret
}
fun asm_slice(s: str, start: i64, end: i64): str {
    ret s[start:end]
}
fun asm_trim(s: str): str {
    let a = 0
    let b = len(s)
    while a < b && (s[a] == 32 || s[a] == 9 || s[a] == 13) {
        a += 1
    }
    while b > a && (s[b - 1] == 32 || s[b - 1] == 9 || s[b - 1] == 13) {
        b -= 1
    }
    ret asm_slice(s, a, b)
}
fun asm_starts(s: str, prefix: str): bool {
    if len(s) < len(prefix) {
        ret false
    }
    for i: 0:len(prefix) {
        if s[i] != prefix[i] {
            ret false
        }
    }
    ret true
}
fun asm_find(s: str, ch: i64): i64 {
    for i: 0:len(s) {
        if s[i] == ch {
            ret i
        }
    }
    ret -1
}
fun asm_remove_spaces(s: str): str {
    let out = new u8[]
    for i: 0:len(s) {
        if s[i] != 32 && s[i] != 9 {
            push(out, s[i])
        }
    }
    ret str(out)
}
fun asm_is_number(s: str): bool {
    if len(s) == 0 {
        ret false
    }
    let i = 0
    if s[0] == 45 {
        i = 1
    }
    let hex = false
    if i + 2 <= len(s) && s[i] == 48 && (s[i + 1] == 120 || s[i + 1] == 88) {
        hex = true
        i += 2
    }
    if i >= len(s) {
        ret false
    }
    while i < len(s) {
        if !hex && (s[i] < 48 || s[i] > 57) {
            ret false
        }
        if hex && digit_value(s[i]) < 0 {
            ret false
        }
        i += 1
    }
    ret true
}
fun asm_reg(name: str): i64 {
    if name == "rax" || name == "eax" || name == "ax" || name == "al" {
        ret 0
    }
    if name == "rcx" || name == "ecx" || name == "cx" || name == "cl" {
        ret 1
    }
    if name == "rdx" || name == "edx" || name == "dx" || name == "dl" {
        ret 2
    }
    if name == "rbx" || name == "ebx" || name == "bx" || name == "bl" {
        ret 3
    }
    if name == "rsp" || name == "esp" || name == "sp" {
        ret 4
    }
    if name == "rbp" || name == "ebp" || name == "bp" {
        ret 5
    }
    if name == "rsi" || name == "esi" || name == "si" {
        ret 6
    }
    if name == "rdi" || name == "edi" || name == "di" {
        ret 7
    }
    if name == "r8" || name == "r8d" || name == "r8w" || name == "r8b" {
        ret 8
    }
    if name == "r9" || name == "r9d" || name == "r9w" || name == "r9b" {
        ret 9
    }
    if name == "r10" || name == "r10d" || name == "r10w" || name == "r10b" {
        ret 10
    }
    if name == "r11" || name == "r11d" || name == "r11w" || name == "r11b" {
        ret 11
    }
    ret -1
}
fun asm_reg_width(name: str): i64 {
    if name == "al" || name == "bl" || name == "cl" || name == "dl" || name == "r8b" || name == "r9b" || name == "r10b" || name == "r11b" {
        ret 8
    }
    if name == "eax" || name == "ebx" || name == "ecx" || name == "edx" || name == "esp" || name == "ebp" || name == "esi" || name == "edi" || name == "r8d" || name == "r9d" || name == "r10d" || name == "r11d" {
        ret 32
    }
    if name == "ax" || name == "bx" || name == "cx" || name == "dx" || name == "sp" || name == "bp" || name == "si" || name == "di" || name == "r8w" || name == "r9w" || name == "r10w" || name == "r11w" {
        ret 16
    }
    if asm_reg(name) >= 0 {
        ret 64
    }
    ret 0
}
fun asm_operand_new(kind: AsmOperandKind): AsmOperand {
    let op = new AsmOperand
    op.kind = kind
    op.width = 0
    op.reg = -1
    op.symbol_index = -1
    op.base = -1
    op.index = -1
    op.scale = 1
    ret op
}
fun asm_register(reg: i64, width: i64): AsmOperand {
    let op = asm_operand_new(AsmOperandKind.Register)
    op.reg = reg
    op.width = width
    ret op
}
fun asm_rax(): AsmOperand {
    ret asm_register(0, 64)
}
fun asm_eax(): AsmOperand {
    ret asm_register(0, 32)
}
