        AsmInstructionKind.Sar {
            asm_render_inst2(renderer, "sar", item.a, item.b)
            ret
        }
        AsmInstructionKind.Call {
            asm_render_inst1(renderer, "call", item.a)
            ret
        }
        AsmInstructionKind.Jmp {
            asm_render_inst1(renderer, "jmp", item.a)
            ret
        }
        AsmInstructionKind.Je {
            asm_render_inst1(renderer, "je", item.a)
            ret
        }
        AsmInstructionKind.Jz {
            asm_render_inst1(renderer, "jz", item.a)
            ret
        }
        AsmInstructionKind.Jne {
            asm_render_inst1(renderer, "jne", item.a)
            ret
        }
        AsmInstructionKind.Jnz {
            asm_render_inst1(renderer, "jnz", item.a)
            ret
        }
        AsmInstructionKind.Jb {
            asm_render_inst1(renderer, "jb", item.a)
            ret
        }
        AsmInstructionKind.Jae {
            asm_render_inst1(renderer, "jae", item.a)
            ret
        }
        AsmInstructionKind.Jbe {
            asm_render_inst1(renderer, "jbe", item.a)
            ret
        }
        AsmInstructionKind.Ja {
            asm_render_inst1(renderer, "ja", item.a)
            ret
        }
        AsmInstructionKind.Jl {
            asm_render_inst1(renderer, "jl", item.a)
            ret
        }
        AsmInstructionKind.Jge {
            asm_render_inst1(renderer, "jge", item.a)
            ret
        }
        AsmInstructionKind.Jle {
            asm_render_inst1(renderer, "jle", item.a)
            ret
        }
        AsmInstructionKind.Jg {
            asm_render_inst1(renderer, "jg", item.a)
            ret
        }
        AsmInstructionKind.Jns {
            asm_render_inst1(renderer, "jns", item.a)
            ret
        }
        AsmInstructionKind.Sete {
            asm_render_inst1(renderer, "sete", item.a)
            ret
        }
        AsmInstructionKind.Setne {
            asm_render_inst1(renderer, "setne", item.a)
            ret
        }
        AsmInstructionKind.Setb {
            asm_render_inst1(renderer, "setb", item.a)
            ret
        }
        AsmInstructionKind.Setae {
            asm_render_inst1(renderer, "setae", item.a)
            ret
        }
        AsmInstructionKind.Setbe {
            asm_render_inst1(renderer, "setbe", item.a)
            ret
        }
        AsmInstructionKind.Seta {
            asm_render_inst1(renderer, "seta", item.a)
            ret
        }
        AsmInstructionKind.Setl {
            asm_render_inst1(renderer, "setl", item.a)
            ret
        }
        AsmInstructionKind.Setge {
            asm_render_inst1(renderer, "setge", item.a)
            ret
        }
        AsmInstructionKind.Setle {
            asm_render_inst1(renderer, "setle", item.a)
            ret
        }
        AsmInstructionKind.Setg {
            asm_render_inst1(renderer, "setg", item.a)
            ret
        }
        AsmInstructionKind.Inc {
            asm_render_inst1(renderer, "inc", item.a)
            ret
        }
        AsmInstructionKind.Dec {
            asm_render_inst1(renderer, "dec", item.a)
            ret
        }
        AsmInstructionKind.Div {
            asm_render_inst1(renderer, "div", item.a)
            ret
        }
        AsmInstructionKind.Idiv {
            asm_render_inst1(renderer, "idiv", item.a)
