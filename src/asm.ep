fun asm_imm(value: i64): AsmOperand {
    let op = asm_operand_new(AsmOperandKind.Immediate)
    op.imm = value
    ret op
}
fun asm_symbol(symbol_index: i64): AsmOperand {
    let op = asm_operand_new(AsmOperandKind.Symbol)
    op.symbol_index = symbol_index
    ret op
}
fun asm_mem_base(width: i64, base: AsmOperand, disp: i64): AsmOperand {
    if base.kind != AsmOperandKind.Register {
        asm_die("memory base must be a register")
    }
    let op = asm_operand_new(AsmOperandKind.Memory)
    op.width = width
    op.base = base.reg
    op.disp = disp
    ret op
}
fun asm_mem_indexed(base: AsmOperand, index: AsmOperand, scale: i64, disp: i64): AsmOperand {
    if base.kind != AsmOperandKind.Register || index.kind != AsmOperandKind.Register {
        asm_die("memory address requires registers")
    }
    let op = asm_mem_base(0, base, disp)
    op.index = index.reg
    op.scale = scale
    ret op
}
fun asm_operand_width(op: AsmOperand, width: i64): AsmOperand {
    op.width = width
    ret op
}
fun asm_mem_symbol(width: i64, symbol_index: i64, disp: i64): AsmOperand {
    let op = asm_operand_new(AsmOperandKind.Memory)
    op.width = width
    op.symbol_index = symbol_index
    op.disp = disp
    ret op
}
fun asm_program_new(): AsmProgram {
    let program = new AsmProgram
    program.items = new AsmItem[]
    program.symbols = new AsmSymbol[]
    program.named_symbols = new i64[]
    program.entry_symbol_index = -1
    ret program
}
fun asm_symbol_new(program: AsmProgram, name: str): i64 {
    let symbol = new AsmSymbol
    symbol.name = name
    let symbol_index = len(program.symbols)
    push(program.symbols, symbol)
    if len(name) != 0 {
        push(program.named_symbols, symbol_index)
    }
    ret symbol_index
}
fun asm_named_symbol_find(program: AsmProgram, name: str): i64 {
    for named_i: 0:len(program.named_symbols) {
        let symbol_index = program.named_symbols[named_i]
        if program.symbols[symbol_index].name == name {
            ret symbol_index
        }
    }
    ret -1
}
fun asm_symbol_intern(program: AsmProgram, name: str): i64 {
    let symbol_index = asm_named_symbol_find(program, name)
    if symbol_index >= 0 {
        ret symbol_index
    }
    ret asm_symbol_new(program, name)
}
fun asm_symbol_name(program: AsmProgram, symbol_index: i64): str {
    if symbol_index < 0 || symbol_index >= len(program.symbols) {
        asm_die("invalid symbol index")
    }
    let name = program.symbols[symbol_index].name
    if len(name) != 0 {
        ret name
    }
    let generated = "__ep_anon_" + itoa(symbol_index)
    while asm_named_symbol_find(program, generated) >= 0 {
        generated = generated + "_"
    }
    ret generated
}
fun asm_item_new(kind: AsmItemKind): AsmItem {
    let item = new AsmItem
    item.kind = kind
    item.symbol_index = -1
    ret item
}
fun asm_section(program: AsmProgram, section: AsmSectionKind): i64 {
    let item = asm_item_new(AsmItemKind.Section)
    item.section = section
    push(program.items, item)
    ret 0
}
fun asm_section_text(program: AsmProgram): i64 {
    ret asm_section(program, AsmSectionKind.Text)
}
fun asm_section_data(program: AsmProgram): i64 {
    ret asm_section(program, AsmSectionKind.Data)
}
fun asm_extern_item(program: AsmProgram, symbol_index: i64): i64 {
    if symbol_index < 0 || symbol_index >= len(program.symbols) {
        asm_die("invalid extern symbol index")
    }
    let symbol = program.symbols[symbol_index]
    if !symbol.defined {
        symbol.external = true
    }
    let item = asm_item_new(AsmItemKind.Extern)
    item.symbol_index = symbol_index
    push(program.items, item)
    ret 0
}
fun asm_label(program: AsmProgram, symbol_index: i64): i64 {
    if symbol_index < 0 || symbol_index >= len(program.symbols) {
        asm_die("invalid label symbol index")
    }
    let symbol = program.symbols[symbol_index]
    if symbol.defined {
        asm_die("duplicate symbol: " + asm_symbol_name(program, symbol_index))
    }
    symbol.defined = true
    symbol.external = false
    let item = asm_item_new(AsmItemKind.Label)
    item.symbol_index = symbol_index
    push(program.items, item)
    ret 0
}
fun asm_bytes(program: AsmProgram, values: u8[]): i64 {
    let item = asm_item_new(AsmItemKind.Bytes)
    item.bytes = values
    push(program.items, item)
    ret 0
}
fun asm_dd(program: AsmProgram, value: i64): i64 {
    let item = asm_item_new(AsmItemKind.DataInteger)
    item.width = 4
    item.value = value
    push(program.items, item)
    ret 0
}
fun asm_dq(program: AsmProgram, value: i64): i64 {
    let item = asm_item_new(AsmItemKind.DataInteger)
    item.width = 8
    item.value = value
    push(program.items, item)
    ret 0
}
fun asm_dq_symbol(program: AsmProgram, symbol_index: i64): i64 {
    let item = asm_item_new(AsmItemKind.DataSymbol)
    item.symbol_index = symbol_index
    push(program.items, item)
    ret 0
}
fun asm_times(program: AsmProgram, count: i64, width: i64, value: i64): i64 {
    let item = asm_item_new(AsmItemKind.RepeatData)
    item.repeat_count = count
    item.width = width
    item.value = value
    push(program.items, item)
    ret 0
}
fun asm_instruction0(program: AsmProgram, kind: AsmInstructionKind): void {
    let item = asm_item_new(AsmItemKind.Instruction)
    item.instruction = kind
    push(program.items, item)
    ret
}
fun asm_instruction1(program: AsmProgram, kind: AsmInstructionKind, a: AsmOperand): void {
    let item = asm_item_new(AsmItemKind.Instruction)
    item.instruction = kind
    item.a = a
    push(program.items, item)
    ret
}
fun asm_instruction2(program: AsmProgram, kind: AsmInstructionKind, a: AsmOperand, b: AsmOperand): void {
    let item = asm_item_new(AsmItemKind.Instruction)
    item.instruction = kind
    item.a = a
    item.b = b
    push(program.items, item)
    ret
}
fun asm_mov(program: AsmProgram, a: AsmOperand, b: AsmOperand): void {
    asm_instruction2(program, AsmInstructionKind.Mov, a, b)
    ret
}
fun asm_lea(program: AsmProgram, a: AsmOperand, b: AsmOperand): void {
