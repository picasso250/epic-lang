    return asm_register(11, 8)
}
fun asm_imm(value: i64): AsmOperand {
    let op = asm_operand_new(AsmOperandKind.Immediate)
    op.imm = value
    return op
}
fun asm_symbol(name: str): AsmOperand {
    let op = asm_operand_new(AsmOperandKind.Symbol)
    op.symbol = name
    return op
}
fun asm_mem_base(width: i64, base: AsmOperand, disp: i64): AsmOperand {
    if base.kind != AsmOperandKind.Register {
        asm_die("memory base must be a register")
    }
    let op = asm_operand_new(AsmOperandKind.Memory)
    op.width = width
    op.base = base.reg
    op.disp = disp
    return op
}
fun asm_mem_indexed(base: AsmOperand, index: AsmOperand, scale: i64, disp: i64): AsmOperand {
    if base.kind != AsmOperandKind.Register || index.kind != AsmOperandKind.Register {
        asm_die("memory address requires registers")
    }
    let op = asm_mem_base(0, base, disp)
    op.index = index.reg
    op.scale = scale
    return op
}
fun asm_operand_width(op: AsmOperand, width: i64): AsmOperand {
    op.width = width
    return op
}
fun asm_mem_symbol(width: i64, symbol: str, disp: i64): AsmOperand {
    let op = asm_operand_new(AsmOperandKind.Memory)
    op.width = width
    op.symbol = symbol
    op.disp = disp
    return op
}
fun asm_program_new(): AsmProgram {
    let program = new AsmProgram
    program.items = new AsmItem[]
    program.entry_symbol = ""
    return program
}
fun asm_item_new(kind: AsmItemKind): AsmItem {
    let item = new AsmItem
    item.kind = kind
    return item
}
fun asm_section(program: AsmProgram, section: AsmSectionKind): i64 {
    let item = asm_item_new(AsmItemKind.Section)
    item.section = section
    push(program.items, item)
    return 0
}
fun asm_section_text(program: AsmProgram): i64 {
    return asm_section(program, AsmSectionKind.Text)
}
fun asm_section_data(program: AsmProgram): i64 {
    return asm_section(program, AsmSectionKind.Data)
}
fun asm_extern_item(program: AsmProgram, name: str): i64 {
    let item = asm_item_new(AsmItemKind.Extern)
    item.name = name
    push(program.items, item)
    return 0
}
fun asm_label(program: AsmProgram, name: str): i64 {
    let item = asm_item_new(AsmItemKind.Label)
    item.name = name
    push(program.items, item)
    return 0
}
fun asm_bytes(program: AsmProgram, values: u8[]): i64 {
    let item = asm_item_new(AsmItemKind.Bytes)
    item.bytes = values
    push(program.items, item)
    return 0
}
fun asm_dd(program: AsmProgram, value: i64): i64 {
    let item = asm_item_new(AsmItemKind.DataInteger)
    item.width = 4
    item.value = value
    push(program.items, item)
    return 0
}
fun asm_dq(program: AsmProgram, value: i64): i64 {
    let item = asm_item_new(AsmItemKind.DataInteger)
    item.width = 8
    item.value = value
    push(program.items, item)
    return 0
}
fun asm_dq_symbol(program: AsmProgram, name: str): i64 {
    let item = asm_item_new(AsmItemKind.DataSymbol)
    item.name = name
    push(program.items, item)
    return 0
}
fun asm_times(program: AsmProgram, count: i64, width: i64, value: i64): i64 {
    let item = asm_item_new(AsmItemKind.RepeatData)
    item.repeat_count = count
    item.width = width
    item.value = value
    push(program.items, item)
    return 0
}
fun asm_instruction0(program: AsmProgram, kind: AsmInstructionKind): i64 {
    let item = asm_item_new(AsmItemKind.Instruction)
    item.instruction = kind
    push(program.items, item)
    return 0
}
fun asm_instruction1(program: AsmProgram, kind: AsmInstructionKind, a: AsmOperand): i64 {
    let item = asm_item_new(AsmItemKind.Instruction)
    item.instruction = kind
    item.a = a
    push(program.items, item)
    return 0
}
fun asm_instruction2(program: AsmProgram, kind: AsmInstructionKind, a: AsmOperand, b: AsmOperand): i64 {
    let item = asm_item_new(AsmItemKind.Instruction)
    item.instruction = kind
    item.a = a
    item.b = b
    push(program.items, item)
    return 0
}
fun asm_mov(program: AsmProgram, a: AsmOperand, b: AsmOperand): i64 {
    return asm_instruction2(program, AsmInstructionKind.Mov, a, b)
}
