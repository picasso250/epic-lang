        AsmInstructionKind.Push {
            asm_render_inst1(renderer, "push", item.a)
            ret
        }
        AsmInstructionKind.Pop {
            asm_render_inst1(renderer, "pop", item.a)
            ret
        }
        AsmInstructionKind.Ret {
            asm_render_inst0(renderer, "ret")
            ret
        }
        AsmInstructionKind.Cqo {
            asm_render_inst0(renderer, "cqo")
            ret
        }
        AsmInstructionKind.RepStosd {
            asm_render_inst0(renderer, "rep stosd")
            ret
        }
    }
    ret
}
fun asm_render(program: AsmProgram): u8[] {
    let out = new u8[]
    let renderer = new AsmRenderer
    renderer.out = out
    renderer.program = program
    if program.entry_symbol_index >= 0 {
        asm_render_s(out, "global ")
        asm_render_s(out, asm_symbol_name(program, program.entry_symbol_index))
        asm_render_s(out, "\n")
        asm_render_s(out, "default rel\n")
    }
    for item_i: 0:len(program.items) {
        let item = program.items[item_i]
        match item.kind {
            AsmItemKind.Section {
                if item.section == AsmSectionKind.Text {
                    asm_render_s(out, "section .text\n")
                } else {
                    asm_render_s(out, "section .data\n")
                }
            }
            AsmItemKind.Extern {
                asm_render_s(out, "extern ")
                asm_render_s(out, asm_symbol_name(program, item.symbol_index))
                asm_render_s(out, "\n")
            }
            AsmItemKind.Label {
                asm_render_s(out, asm_symbol_name(program, item.symbol_index))
                asm_render_s(out, ":\n")
            }
            AsmItemKind.Instruction {
                asm_render_instruction(renderer, item)
            }
            AsmItemKind.Bytes {
                asm_render_s(out, "    db ")
                for byte_i: 0:len(item.bytes) {
                    if byte_i != 0 {
                        asm_render_s(out, ", ")
                    }
                    asm_render_i(out, item.bytes[byte_i])
                }
                asm_render_s(out, "\n")
            }
            AsmItemKind.DataInteger {
                if item.width == 4 {
                    asm_render_s(out, "    dd ")
                } else {
                    asm_render_s(out, "    dq ")
                }
                asm_render_i(out, item.value)
                asm_render_s(out, "\n")
            }
            AsmItemKind.DataSymbol {
                asm_render_s(out, "    dq ")
                asm_render_s(out, asm_symbol_name(program, item.symbol_index))
                asm_render_s(out, "\n")
            }
            AsmItemKind.RepeatData {
                asm_render_s(out, "    times ")
                asm_render_i(out, item.repeat_count)
                if item.width == 1 {
                    asm_render_s(out, " db ")
                } else if item.width == 4 {
                    asm_render_s(out, " dd ")
                } else {
                    asm_render_s(out, " dq ")
                }
                asm_render_i(out, item.value)
                asm_render_s(out, "\n")
            }
        }
    }
    ret out
}

fun assemble_text(src: str): ExeImage {
    ret asm_encode(asm_parse(src))
}
