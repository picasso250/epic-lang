}
fun asm_rdi(): AsmOperand {
    return asm_register(7, 64)
}
fun asm_edi(): AsmOperand {
    return asm_register(7, 32)
}
fun asm_r8(): AsmOperand {
    return asm_register(8, 64)
}
fun asm_r8d(): AsmOperand {
    return asm_register(8, 32)
}
fun asm_r8b(): AsmOperand {
    return asm_register(8, 8)
}
fun asm_r9(): AsmOperand {
    return asm_register(9, 64)
}
fun asm_r9d(): AsmOperand {
    return asm_register(9, 32)
}
fun asm_r9b(): AsmOperand {
