fun ast_name(node: AstNode): str {
    if node.name? {
        ret node.name
    }
    ret ""
}

fun ast_set_name(node: AstNode, value: str): void {
    if node.name? {
        node.name = value
        ret
    }
    ast_bad_field("name")
}

