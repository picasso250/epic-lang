#
# Epic v2 parser.
# TODO dogfood: migrate output to print/println/f-strings and bare `new Type` to `new Type {}`.
#

fun epic_type_is_int(t: str): bool {
    ret t == "i64" || t == "u64" || t == "i32" || t == "u32" || t == "u8"
}

fun epic_type_starts_with(s: str, prefix: str): bool {
    if len(s) < len(prefix) {
        ret false
    }
    ret s[0:len(prefix)] == prefix
}

fun epic_type_ends_with(s: str, suffix: str): bool {
    if len(s) < len(suffix) {
        ret false
    }
    ret s[len(s) - len(suffix):len(s)] == suffix
}

fun epic_type_array_of(elem: str): str {
    ret str_cat2(elem, "[]")
}

fun epic_type_map_of(value: str): str {
    ret str_cat2("map[str]", value)
}

fun epic_type_is_array(t: str): bool {
    ret epic_type_ends_with(t, "[]")
}

fun epic_type_is_map(t: str): bool {
    ret epic_type_starts_with(t, "map[str]")
}

fun epic_type_array_elem(t: str): str {
    if epic_type_is_array(t) == false {
        panic str_cat2("internal type error: expected array type, got ", t)
    }
    ret t[0:len(t) - 2]
}

fun epic_type_map_value(t: str): str {
    if epic_type_is_map(t) == false {
        panic str_cat2("internal type error: expected map type, got ", t)
    }
    ret t[8:len(t)]
}

struct TypeMissing {
    dummy: i64
}

struct TypeName {
    name: str
}

struct TypeArray {
    elem: TypeExpr
}

struct TypeMap {
    value: TypeExpr
}

type TypeExpr = TypeMissing | TypeName | TypeArray | TypeMap

fun type_missing(): TypeExpr {
    ret new TypeExpr(new TypeMissing { dummy: 0 })
}

fun type_name_expr(name: str): TypeExpr {
    ret new TypeExpr(new TypeName { name: name })
}

fun type_array_of(elem: TypeExpr): TypeExpr {
    ret new TypeExpr(new TypeArray { elem: elem })
}

fun type_map_of(value: TypeExpr): TypeExpr {
    ret new TypeExpr(new TypeMap { value: value })
}

fun type_expr_is_missing(t: TypeExpr): bool {
    match t {
        TypeMissing n: { ret true }
        else: {}
    }
    ret false
}

fun type_expr_text(t: TypeExpr): str {
    match t {
        TypeMissing n: { ret "" }
        TypeName n: { ret n.name }
        TypeArray n: { ret epic_type_array_of(type_expr_text(n.elem)) }
        TypeMap n: { ret epic_type_map_of(type_expr_text(n.value)) }
    }
    ret ""
}

struct AstMeta {
    line: i64
    resolved_type: str
}

fun ast_meta(): AstMeta {
    ret new AstMeta { resolved_type: "" }
}

struct AstEmpty {
    AstMeta
}

struct AstProgram {
    AstMeta
    funcs: AstNode[]
    structs: AstNode[]
    globals: AstNode[]
    unions: AstNode[]
}

struct AstStructDef {
    AstMeta
    name: str
    fields: AstNode[]
}

struct AstUnionDef {
    AstMeta
    name: str
    members: str[]
}

struct AstFunDef {
    AstMeta
    name: str
    params: AstNode[]
    source_type: TypeExpr
    body: AstNode
    receiver_name: str
    receiver_type: str
    method_name: str
}

struct AstParam {
    AstMeta
    name: str
    source_type: TypeExpr
}

struct AstStructField {
    AstMeta
    name: str
    source_type: TypeExpr
    embedded: bool
}

struct AstBlock {
    AstMeta
    stmts: AstNode[]
}

struct AstLet {
    AstMeta
    name: str
    source_type: TypeExpr
    value_expr: AstNode
}

struct AstReturn {
    AstMeta
    expr: AstNode
}

struct AstAssign {
    AstMeta
    name: str
    value_expr: AstNode
}

struct AstAssignOp {
    AstMeta
    expr: AstNode
    op: str
    value_expr: AstNode
}

struct AstFieldSet {
    AstMeta
    object: AstNode
    name: str
    value_expr: AstNode
}

struct AstSubscriptAssign {
    AstMeta
    base: AstNode
    index: AstNode
    value_expr: AstNode
}

struct AstIf {
    AstMeta
    expr: AstNode
    then_block: AstNode
    else_block: AstNode
}

struct AstWhile {
    AstMeta
    expr: AstNode
    body: AstNode
}

struct AstForRange {
    AstMeta
    name: str
    start: AstNode
    end: AstNode
    body: AstNode
}

struct AstForIn {
    AstMeta
    name: str
    source: AstNode
    body: AstNode
}

struct AstBreak {
    AstMeta
}

struct AstContinue {
    AstMeta
}

struct AstPanic {
    AstMeta
    expr: AstNode
}

struct AstAssert {
    AstMeta
    expr: AstNode
    value_expr: AstNode
}

struct AstMatch {
    AstMeta
    expr: AstNode
    fields: AstNode[]
    else_block: AstNode
}

struct AstMatchCase {
    AstMeta
    variant_name: str
    binding_name: str
    expr: AstNode
    body: AstNode
}

struct AstExprStmt {
    AstMeta
    expr: AstNode
}

struct AstLiteral {
    AstMeta
    value: str
}

struct AstChar {
    AstMeta
    value: str
}

struct AstBool {
    AstMeta
    value: str
}

struct AstString {
    AstMeta
    value: str
}

struct AstFString {
    AstMeta
    fields: AstNode[]
}

struct AstFStringText {
    AstMeta
    value: str
}

struct AstVar {
    AstMeta
    name: str
}

struct AstBinary {
    AstMeta
    op: str
    left: AstNode
    right: AstNode
}

struct AstUnary {
    AstMeta
    op: str
    expr: AstNode
}

struct AstCall {
    AstMeta
    name: str
    args: AstNode[]
    type_name: str
    dll: str
}

struct AstDotCall {
    AstMeta
    object: AstNode
    name: str
    args: AstNode[]
}

struct AstFieldAccess {
    AstMeta
    object: AstNode
    name: str
}

struct AstFieldHas {
    AstMeta
    object: AstNode
    name: str
}

struct AstSubscript {
    AstMeta
    base: AstNode
    index: AstNode
}

struct AstSlice {
    AstMeta
    base: AstNode
    start: AstNode
    end: AstNode
}

struct AstNewArray {
    AstMeta
    elem_type: TypeExpr
    count: AstNode
}

struct AstArrayLiteral {
    AstMeta
    elem_type: TypeExpr
    args: AstNode[]
}

struct AstStructInit {
    AstMeta
    name: str
    fields: AstNode[]
}

struct AstInitField {
    AstMeta
    name: str
    value_expr: AstNode
}

struct AstUnionInit {
    AstMeta
    type_name: str
    expr: AstNode
}

struct AstMapInit {
    AstMeta
    source_type: TypeExpr
    map_keys: AstNode[]
    map_values: AstNode[]
}

type AstNode = AstEmpty | AstProgram | AstStructDef | AstUnionDef | AstFunDef | AstParam | AstStructField | AstBlock | AstLet | AstReturn | AstAssign | AstAssignOp | AstFieldSet | AstSubscriptAssign | AstIf | AstWhile | AstForRange | AstForIn | AstBreak | AstContinue | AstPanic | AstAssert | AstMatch | AstMatchCase | AstExprStmt | AstLiteral | AstChar | AstBool | AstString | AstFString | AstFStringText | AstVar | AstBinary | AstUnary | AstCall | AstDotCall | AstFieldAccess | AstFieldHas | AstSubscript | AstSlice | AstNewArray | AstArrayLiteral | AstStructInit | AstInitField | AstUnionInit | AstMapInit

fun ast_new_empty(): AstNode {
    ret new AstNode(new AstEmpty { AstMeta: ast_meta() })
}

fun ast_new_program(): AstNode {
    ret new AstNode(new AstProgram { AstMeta: ast_meta(), funcs: new AstNode[0], structs: new AstNode[0], globals: new AstNode[0], unions: new AstNode[0] })
}

fun ast_new_struct_def(): AstNode {
    ret new AstNode(new AstStructDef { AstMeta: ast_meta(), name: "", fields: new AstNode[0] })
}

fun ast_new_union_def(): AstNode {
    ret new AstNode(new AstUnionDef { AstMeta: ast_meta(), name: "", members: new str[0] })
}

fun ast_new_fun_def(): AstNode {
    ret new AstNode(new AstFunDef { AstMeta: ast_meta(), name: "", params: new AstNode[0], source_type: type_missing(), body: ast_empty(), receiver_name: "", receiver_type: "", method_name: "" })
}

fun ast_new_param(): AstNode {
    ret new AstNode(new AstParam { AstMeta: ast_meta(), name: "", source_type: type_missing() })
}

fun ast_new_struct_field(): AstNode {
    ret new AstNode(new AstStructField { AstMeta: ast_meta(), name: "", source_type: type_missing(), embedded: false })
}

fun ast_new_block(): AstNode {
    ret new AstNode(new AstBlock { AstMeta: ast_meta(), stmts: new AstNode[0] })
}

fun ast_new_let(): AstNode {
    ret new AstNode(new AstLet { AstMeta: ast_meta(), name: "", source_type: type_missing(), value_expr: ast_empty() })
}

fun ast_new_return(): AstNode {
    ret new AstNode(new AstReturn { AstMeta: ast_meta(), expr: ast_empty() })
}

fun ast_new_assign(): AstNode {
    ret new AstNode(new AstAssign { AstMeta: ast_meta(), name: "", value_expr: ast_empty() })
}

fun ast_new_assign_op(): AstNode {
    ret new AstNode(new AstAssignOp { AstMeta: ast_meta(), expr: ast_empty(), op: "", value_expr: ast_empty() })
}

fun ast_new_field_set(): AstNode {
    ret new AstNode(new AstFieldSet { AstMeta: ast_meta(), object: ast_empty(), name: "", value_expr: ast_empty() })
}

fun ast_new_subscript_assign(): AstNode {
    ret new AstNode(new AstSubscriptAssign { AstMeta: ast_meta(), base: ast_empty(), index: ast_empty(), value_expr: ast_empty() })
}

fun ast_new_if(): AstNode {
    ret new AstNode(new AstIf { AstMeta: ast_meta(), expr: ast_empty(), then_block: ast_empty(), else_block: ast_empty() })
}

fun ast_new_while(): AstNode {
    ret new AstNode(new AstWhile { AstMeta: ast_meta(), expr: ast_empty(), body: ast_empty() })
}

fun ast_new_for_range(): AstNode {
    ret new AstNode(new AstForRange { AstMeta: ast_meta(), name: "", start: ast_empty(), end: ast_empty(), body: ast_empty() })
}

fun ast_new_for_in(): AstNode {
    ret new AstNode(new AstForIn { AstMeta: ast_meta(), name: "", source: ast_empty(), body: ast_empty() })
}

fun ast_new_break(): AstNode {
    ret new AstNode(new AstBreak { AstMeta: ast_meta() })
}

fun ast_new_continue(): AstNode {
    ret new AstNode(new AstContinue { AstMeta: ast_meta() })
}

fun ast_new_panic(): AstNode {
    ret new AstNode(new AstPanic { AstMeta: ast_meta(), expr: ast_empty() })
}

fun ast_new_assert(): AstNode {
    ret new AstNode(new AstAssert { AstMeta: ast_meta(), expr: ast_empty(), value_expr: ast_empty() })
}

fun ast_new_match(): AstNode {
    ret new AstNode(new AstMatch { AstMeta: ast_meta(), expr: ast_empty(), fields: new AstNode[0], else_block: ast_empty() })
}

fun ast_new_match_case(): AstNode {
    ret new AstNode(new AstMatchCase { AstMeta: ast_meta(), variant_name: "", binding_name: "", expr: ast_empty(), body: ast_empty() })
}

fun ast_new_expr_stmt(): AstNode {
    ret new AstNode(new AstExprStmt { AstMeta: ast_meta(), expr: ast_empty() })
}

fun ast_new_literal(): AstNode {
    ret new AstNode(new AstLiteral { AstMeta: ast_meta(), value: "" })
}

fun ast_new_char(): AstNode {
    ret new AstNode(new AstChar { AstMeta: ast_meta(), value: "" })
}

fun ast_new_bool(): AstNode {
    ret new AstNode(new AstBool { AstMeta: ast_meta(), value: "" })
}

fun ast_new_string(): AstNode {
    ret new AstNode(new AstString { AstMeta: ast_meta(), value: "" })
}

fun ast_new_f_string(): AstNode {
    ret new AstNode(new AstFString { AstMeta: ast_meta(), fields: new AstNode[0] })
}

fun ast_new_f_string_text(): AstNode {
    ret new AstNode(new AstFStringText { AstMeta: ast_meta(), value: "" })
}

fun ast_new_var(): AstNode {
    ret new AstNode(new AstVar { AstMeta: ast_meta(), name: "" })
}

fun ast_new_binary(): AstNode {
    ret new AstNode(new AstBinary { AstMeta: ast_meta(), op: "", left: ast_empty(), right: ast_empty() })
}

fun ast_new_unary(): AstNode {
    ret new AstNode(new AstUnary { AstMeta: ast_meta(), op: "", expr: ast_empty() })
}

fun ast_new_call(): AstNode {
    ret new AstNode(new AstCall { AstMeta: ast_meta(), name: "", args: new AstNode[0], type_name: "", dll: "" })
}

fun ast_new_dot_call(): AstNode {
    ret new AstNode(new AstDotCall { AstMeta: ast_meta(), object: ast_empty(), name: "", args: new AstNode[0] })
}

fun ast_new_field_access(): AstNode {
    ret new AstNode(new AstFieldAccess { AstMeta: ast_meta(), object: ast_empty(), name: "" })
}

fun ast_new_field_has(): AstNode {
    ret new AstNode(new AstFieldHas { AstMeta: ast_meta(), object: ast_empty(), name: "" })
}

fun ast_new_subscript(): AstNode {
    ret new AstNode(new AstSubscript { AstMeta: ast_meta(), base: ast_empty(), index: ast_empty() })
}

fun ast_new_slice(): AstNode {
    ret new AstNode(new AstSlice { AstMeta: ast_meta(), base: ast_empty(), start: ast_empty(), end: ast_empty() })
}

fun ast_new_new_array(): AstNode {
    ret new AstNode(new AstNewArray { AstMeta: ast_meta(), elem_type: type_missing(), count: ast_empty() })
}

fun ast_new_array_literal(): AstNode {
    ret new AstNode(new AstArrayLiteral { AstMeta: ast_meta(), elem_type: type_missing(), args: new AstNode[0] })
}

fun ast_new_struct_init(): AstNode {
    ret new AstNode(new AstStructInit { AstMeta: ast_meta(), name: "", fields: new AstNode[0] })
}

fun ast_new_init_field(): AstNode {
    ret new AstNode(new AstInitField { AstMeta: ast_meta(), name: "", value_expr: ast_empty() })
}

fun ast_new_union_init(): AstNode {
    ret new AstNode(new AstUnionInit { AstMeta: ast_meta(), type_name: "", expr: ast_empty() })
}

fun ast_new_map_init(): AstNode {
    ret new AstNode(new AstMapInit { AstMeta: ast_meta(), source_type: type_missing(), map_keys: new AstNode[0], map_values: new AstNode[0] })
}

fun ast_empty(): AstNode {
    ret ast_new_empty()
}

fun ast_node(kind: str): AstNode {
    match kind {
        "Program": { ret ast_new_program() }
        "StructDef": { ret ast_new_struct_def() }
        "UnionDef": { ret ast_new_union_def() }
        "FunDef": { ret ast_new_fun_def() }
        "Param": { ret ast_new_param() }
        "StructField": { ret ast_new_struct_field() }
        "Block": { ret ast_new_block() }
        "Let": { ret ast_new_let() }
        "Return": { ret ast_new_return() }
        "Assign": { ret ast_new_assign() }
        "AssignOp": { ret ast_new_assign_op() }
        "FieldSet": { ret ast_new_field_set() }
        "SubscriptAssign": { ret ast_new_subscript_assign() }
        "If": { ret ast_new_if() }
        "While": { ret ast_new_while() }
        "ForRange": { ret ast_new_for_range() }
        "ForIn": { ret ast_new_for_in() }
        "Break": { ret ast_new_break() }
        "Continue": { ret ast_new_continue() }
        "Panic": { ret ast_new_panic() }
        "Assert": { ret ast_new_assert() }
        "Match": { ret ast_new_match() }
        "MatchCase": { ret ast_new_match_case() }
        "ExprStmt": { ret ast_new_expr_stmt() }
        "Literal": { ret ast_new_literal() }
        "Char": { ret ast_new_char() }
        "Bool": { ret ast_new_bool() }
        "String": { ret ast_new_string() }
        "FString": { ret ast_new_f_string() }
        "FStringText": { ret ast_new_f_string_text() }
        "Var": { ret ast_new_var() }
        "Binary": { ret ast_new_binary() }
        "Unary": { ret ast_new_unary() }
        "Call": { ret ast_new_call() }
        "DotCall": { ret ast_new_dot_call() }
        "FieldAccess": { ret ast_new_field_access() }
        "FieldHas": { ret ast_new_field_has() }
        "Subscript": { ret ast_new_subscript() }
        "Slice": { ret ast_new_slice() }
        "NewArray": { ret ast_new_new_array() }
        "ArrayLiteral": { ret ast_new_array_literal() }
        "StructInit": { ret ast_new_struct_init() }
        "InitField": { ret ast_new_init_field() }
        "UnionInit": { ret ast_new_union_init() }
        "MapInit": { ret ast_new_map_init() }
        else: {}
    }
    ret ast_empty()
}

fun ast_bad_field(field: str): void {
    panic str_cat2("invalid AST field ", field)
}

fun ast_line(node: AstNode): i64 { ret node.AstMeta.line }
fun ast_set_line(node: AstNode, value: i64): void { node.AstMeta.line = value }
fun ast_resolved_type(node: AstNode): str { ret node.AstMeta.resolved_type }
fun ast_set_resolved_type(node: AstNode, value: str): void { node.AstMeta.resolved_type = value }

fun ast_funcs(node: AstNode): AstNode[] {
    match node {
        AstProgram n: { ret n.funcs }
        else: {}
    }
    ret new AstNode[0]
}

fun ast_set_funcs(node: AstNode, value: AstNode[]): void {
    match node {
        AstProgram n: { n.funcs = value
            ret
        }
        else: {}
    }
    ast_bad_field("funcs")
}

fun ast_structs(node: AstNode): AstNode[] {
    match node {
