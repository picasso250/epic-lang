fun ast_body(node: AstNode): AstNode {
    match node {
        AstFunDef n: { ret n.body }
        AstWhile n: { ret n.body }
        AstFor n: { ret n.body }
        AstMatchCase n: { ret n.body }
        else: {}
    }
    ret ast_empty()
}

fun ast_set_body(node: AstNode, value: AstNode): void {
    match node {
        AstFunDef n: { n.body = value
            ret
        }
        AstWhile n: { n.body = value
            ret
        }
        AstFor n: { n.body = value
            ret
        }
        AstMatchCase n: { n.body = value
            ret
        }
        else: {}
    }
    ast_bad_field("body")
}

fun ast_receiver_name(node: AstNode): str {
    match node {
        AstFunDef n: { ret n.receiver_name }
        else: {}
    }
    ret ""
}

fun ast_set_receiver_name(node: AstNode, value: str): void {
    match node {
