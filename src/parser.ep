#
# Epic v2 parser.
# TODO dogfood: migrate output to print/println/f-strings and bare `new Type` to `new Type {}`.
#

struct AstMeta {
    kind: str
    line: i64
    resolved_type: str
}

struct AstEmpty {
    AstMeta
}

struct AstProgram {
    AstMeta
    funcs: AstNode[]
    structs: AstNode[]
    globals: AstNode[]
    unions: AstNode[]
}

struct AstStructDef {
    AstMeta
    name: str
    fields: AstNode[]
}

struct AstUnionDef {
    AstMeta
    name: str
    members: str[]
}

struct AstFunDef {
    AstMeta
    name: str
    params: AstNode[]
    type_name: str
    body: AstNode
    receiver_name: str
    receiver_type: str
    method_name: str
}

struct AstParam {
    AstMeta
    name: str
    type_name: str
}

struct AstStructField {
    AstMeta
    name: str
    type_name: str
    embedded: bool
}

struct AstBlock {
    AstMeta
    stmts: AstNode[]
}

struct AstLet {
    AstMeta
    name: str
    type_name: str
    value_expr: AstNode
}

struct AstReturn {
    AstMeta
    expr: AstNode
}

struct AstAssign {
    AstMeta
    name: str
    value_expr: AstNode
}

struct AstAssignOp {
    AstMeta
    expr: AstNode
    op: str
    value_expr: AstNode
}

struct AstFieldSet {
    AstMeta
    object: AstNode
    name: str
    value_expr: AstNode
}

struct AstSubscriptAssign {
    AstMeta
    base: AstNode
    index: AstNode
    value_expr: AstNode
}

struct AstIf {
    AstMeta
    expr: AstNode
    then_block: AstNode
    else_block: AstNode
}

struct AstWhile {
    AstMeta
    expr: AstNode
    body: AstNode
}

struct AstFor {
    AstMeta
    name: str
    start: AstNode
    end: AstNode
    body: AstNode
}

struct AstBreak {
    AstMeta
}

struct AstContinue {
    AstMeta
}

struct AstPanic {
    AstMeta
    expr: AstNode
}

struct AstAssert {
    AstMeta
    expr: AstNode
    value_expr: AstNode
}

struct AstMatch {
    AstMeta
    expr: AstNode
    fields: AstNode[]
    else_block: AstNode
}

struct AstMatchCase {
    AstMeta
    variant_name: str
    binding_name: str
    expr: AstNode
    body: AstNode
}

struct AstExprStmt {
    AstMeta
    expr: AstNode
}

struct AstLiteral {
    AstMeta
    value: str
}

struct AstChar {
    AstMeta
    value: str
}

struct AstBool {
    AstMeta
    value: str
}

struct AstString {
    AstMeta
    value: str
}

struct AstFString {
    AstMeta
    fields: AstNode[]
}

struct AstFStringText {
    AstMeta
    value: str
}

struct AstVar {
    AstMeta
    name: str
}

struct AstBinary {
    AstMeta
    op: str
    left: AstNode
    right: AstNode
}

struct AstUnary {
    AstMeta
    op: str
    expr: AstNode
}

struct AstCall {
    AstMeta
    name: str
    args: AstNode[]
}

struct AstDotCall {
    AstMeta
    object: AstNode
    name: str
    args: AstNode[]
}

struct AstFieldAccess {
    AstMeta
    object: AstNode
    name: str
}

struct AstSubscript {
    AstMeta
    base: AstNode
    index: AstNode
}

struct AstSlice {
    AstMeta
    base: AstNode
    start: AstNode
    end: AstNode
}

struct AstNewArray {
    AstMeta
    type_name: str
    count: AstNode
}

struct AstArrayLiteral {
    AstMeta
    type_name: str
    args: AstNode[]
}

struct AstStructInit {
    AstMeta
    name: str
    fields: AstNode[]
}

struct AstInitField {
    AstMeta
    name: str
    value_expr: AstNode
}

struct AstUnionInit {
    AstMeta
    type_name: str
    expr: AstNode
}

struct AstMapInit {
    AstMeta
    type_name: str
    map_keys: AstNode[]
    map_values: AstNode[]
}

type AstNode = AstEmpty | AstProgram | AstStructDef | AstUnionDef | AstFunDef | AstParam | AstStructField | AstBlock | AstLet | AstReturn | AstAssign | AstAssignOp | AstFieldSet | AstSubscriptAssign | AstIf | AstWhile | AstFor | AstBreak | AstContinue | AstPanic | AstAssert | AstMatch | AstMatchCase | AstExprStmt | AstLiteral | AstChar | AstBool | AstString | AstFString | AstFStringText | AstVar | AstBinary | AstUnary | AstCall | AstDotCall | AstFieldAccess | AstSubscript | AstSlice | AstNewArray | AstArrayLiteral | AstStructInit | AstInitField | AstUnionInit | AstMapInit

fun ast_meta(kind: str): AstMeta {
    let m = new AstMeta
    m.kind = kind
    m.line = 0
    m.resolved_type = ""
    ret m
}

fun ast_new_empty(): AstNode {
    let n = new AstEmpty
    n.AstMeta = ast_meta("")
    ret new AstNode(n)
}

fun ast_new_program(): AstNode {
    let n = new AstProgram
    n.AstMeta = ast_meta("Program")
    n.funcs = new AstNode[0]
    n.structs = new AstNode[0]
    n.globals = new AstNode[0]
    n.unions = new AstNode[0]
    ret new AstNode(n)
}

fun ast_new_struct_def(): AstNode {
    let n = new AstStructDef
    n.AstMeta = ast_meta("StructDef")
    n.name = ""
    n.fields = new AstNode[0]
    ret new AstNode(n)
}

fun ast_new_union_def(): AstNode {
    let n = new AstUnionDef
    n.AstMeta = ast_meta("UnionDef")
    n.name = ""
    n.members = new str[0]
    ret new AstNode(n)
}

fun ast_new_fun_def(): AstNode {
    let n = new AstFunDef
    n.AstMeta = ast_meta("FunDef")
    n.name = ""
    n.params = new AstNode[0]
    n.type_name = ""
    n.body = ast_empty()
    n.receiver_name = ""
    n.receiver_type = ""
    n.method_name = ""
    ret new AstNode(n)
}

fun ast_new_param(): AstNode {
    let n = new AstParam
    n.AstMeta = ast_meta("Param")
    n.name = ""
    n.type_name = ""
    ret new AstNode(n)
}

fun ast_new_struct_field(): AstNode {
    let n = new AstStructField
    n.AstMeta = ast_meta("StructField")
    n.name = ""
    n.type_name = ""
    n.embedded = false
    ret new AstNode(n)
}

fun ast_new_block(): AstNode {
    let n = new AstBlock
    n.AstMeta = ast_meta("Block")
    n.stmts = new AstNode[0]
    ret new AstNode(n)
}

fun ast_new_let(): AstNode {
    let n = new AstLet
    n.AstMeta = ast_meta("Let")
    n.name = ""
    n.type_name = ""
    n.value_expr = ast_empty()
    ret new AstNode(n)
}

fun ast_new_return(): AstNode {
    let n = new AstReturn
    n.AstMeta = ast_meta("Return")
    n.expr = ast_empty()
    ret new AstNode(n)
}

fun ast_new_assign(): AstNode {
    let n = new AstAssign
    n.AstMeta = ast_meta("Assign")
    n.name = ""
    n.value_expr = ast_empty()
    ret new AstNode(n)
}

fun ast_new_assign_op(): AstNode {
    let n = new AstAssignOp
    n.AstMeta = ast_meta("AssignOp")
    n.expr = ast_empty()
    n.op = ""
    n.value_expr = ast_empty()
    ret new AstNode(n)
}

fun ast_new_field_set(): AstNode {
    let n = new AstFieldSet
    n.AstMeta = ast_meta("FieldSet")
    n.object = ast_empty()
    n.name = ""
    n.value_expr = ast_empty()
    ret new AstNode(n)
}

fun ast_new_subscript_assign(): AstNode {
    let n = new AstSubscriptAssign
    n.AstMeta = ast_meta("SubscriptAssign")
    n.base = ast_empty()
    n.index = ast_empty()
    n.value_expr = ast_empty()
    ret new AstNode(n)
}

fun ast_new_if(): AstNode {
    let n = new AstIf
    n.AstMeta = ast_meta("If")
    n.expr = ast_empty()
    n.then_block = ast_empty()
    n.else_block = ast_empty()
    ret new AstNode(n)
}

fun ast_new_while(): AstNode {
    let n = new AstWhile
    n.AstMeta = ast_meta("While")
    n.expr = ast_empty()
    n.body = ast_empty()
    ret new AstNode(n)
}

fun ast_new_for(): AstNode {
    let n = new AstFor
    n.AstMeta = ast_meta("For")
    n.name = ""
    n.start = ast_empty()
    n.end = ast_empty()
    n.body = ast_empty()
    ret new AstNode(n)
}

fun ast_new_break(): AstNode {
    let n = new AstBreak
    n.AstMeta = ast_meta("Break")
    ret new AstNode(n)
}

fun ast_new_continue(): AstNode {
    let n = new AstContinue
    n.AstMeta = ast_meta("Continue")
    ret new AstNode(n)
}

fun ast_new_panic(): AstNode {
    let n = new AstPanic
    n.AstMeta = ast_meta("Panic")
    n.expr = ast_empty()
    ret new AstNode(n)
}

fun ast_new_assert(): AstNode {
    let n = new AstAssert
    n.AstMeta = ast_meta("Assert")
    n.expr = ast_empty()
    n.value_expr = ast_empty()
    ret new AstNode(n)
}

fun ast_new_match(): AstNode {
    let n = new AstMatch
    n.AstMeta = ast_meta("Match")
    n.expr = ast_empty()
    n.fields = new AstNode[0]
    n.else_block = ast_empty()
    ret new AstNode(n)
}

fun ast_new_match_case(): AstNode {
    let n = new AstMatchCase
    n.AstMeta = ast_meta("MatchCase")
    n.variant_name = ""
    n.binding_name = ""
    n.expr = ast_empty()
    n.body = ast_empty()
    ret new AstNode(n)
}

fun ast_new_expr_stmt(): AstNode {
    let n = new AstExprStmt
    n.AstMeta = ast_meta("ExprStmt")
    n.expr = ast_empty()
    ret new AstNode(n)
}

fun ast_new_literal(): AstNode {
    let n = new AstLiteral
    n.AstMeta = ast_meta("Literal")
    n.value = ""
    ret new AstNode(n)
}

fun ast_new_char(): AstNode {
    let n = new AstChar
    n.AstMeta = ast_meta("Char")
    n.value = ""
    ret new AstNode(n)
}

fun ast_new_bool(): AstNode {
    let n = new AstBool
    n.AstMeta = ast_meta("Bool")
    n.value = ""
    ret new AstNode(n)
}

fun ast_new_string(): AstNode {
    let n = new AstString
    n.AstMeta = ast_meta("String")
    n.value = ""
    ret new AstNode(n)
}

fun ast_new_f_string(): AstNode {
    let n = new AstFString
    n.AstMeta = ast_meta("FString")
    n.fields = new AstNode[0]
    ret new AstNode(n)
}

fun ast_new_f_string_text(): AstNode {
    let n = new AstFStringText
    n.AstMeta = ast_meta("FStringText")
    n.value = ""
    ret new AstNode(n)
}

fun ast_new_var(): AstNode {
    let n = new AstVar
    n.AstMeta = ast_meta("Var")
    n.name = ""
    ret new AstNode(n)
}

fun ast_new_binary(): AstNode {
    let n = new AstBinary
    n.AstMeta = ast_meta("Binary")
    n.op = ""
    n.left = ast_empty()
    n.right = ast_empty()
    ret new AstNode(n)
}

fun ast_new_unary(): AstNode {
    let n = new AstUnary
    n.AstMeta = ast_meta("Unary")
    n.op = ""
    n.expr = ast_empty()
    ret new AstNode(n)
}

fun ast_new_call(): AstNode {
    let n = new AstCall
    n.AstMeta = ast_meta("Call")
    n.name = ""
    n.args = new AstNode[0]
    ret new AstNode(n)
}

fun ast_new_dot_call(): AstNode {
    let n = new AstDotCall
    n.AstMeta = ast_meta("DotCall")
    n.object = ast_empty()
    n.name = ""
    n.args = new AstNode[0]
    ret new AstNode(n)
}

fun ast_new_field_access(): AstNode {
    let n = new AstFieldAccess
    n.AstMeta = ast_meta("FieldAccess")
    n.object = ast_empty()
    n.name = ""
    ret new AstNode(n)
}

fun ast_new_subscript(): AstNode {
    let n = new AstSubscript
    n.AstMeta = ast_meta("Subscript")
    n.base = ast_empty()
    n.index = ast_empty()
    ret new AstNode(n)
}

fun ast_new_slice(): AstNode {
    let n = new AstSlice
    n.AstMeta = ast_meta("Slice")
    n.base = ast_empty()
    n.start = ast_empty()
    n.end = ast_empty()
    ret new AstNode(n)
}

fun ast_new_new_array(): AstNode {
    let n = new AstNewArray
    n.AstMeta = ast_meta("NewArray")
    n.type_name = ""
    n.count = ast_empty()
    ret new AstNode(n)
}

fun ast_new_array_literal(): AstNode {
    let n = new AstArrayLiteral
    n.AstMeta = ast_meta("ArrayLiteral")
    n.type_name = ""
    n.args = new AstNode[0]
    ret new AstNode(n)
}

fun ast_new_struct_init(): AstNode {
    let n = new AstStructInit
    n.AstMeta = ast_meta("StructInit")
    n.name = ""
    n.fields = new AstNode[0]
    ret new AstNode(n)
}

fun ast_new_init_field(): AstNode {
    let n = new AstInitField
    n.AstMeta = ast_meta("InitField")
    n.name = ""
    n.value_expr = ast_empty()
    ret new AstNode(n)
}

fun ast_new_union_init(): AstNode {
    let n = new AstUnionInit
    n.AstMeta = ast_meta("UnionInit")
    n.type_name = ""
    n.expr = ast_empty()
    ret new AstNode(n)
}

fun ast_new_map_init(): AstNode {
    let n = new AstMapInit
    n.AstMeta = ast_meta("MapInit")
    n.type_name = ""
    n.map_keys = new AstNode[0]
    n.map_values = new AstNode[0]
    ret new AstNode(n)
}

fun ast_empty(): AstNode {
    ret ast_new_empty()
}

fun ast_node(kind: str): AstNode {
    match kind {
        "Program": { ret ast_new_program() }
        "StructDef": { ret ast_new_struct_def() }
        "UnionDef": { ret ast_new_union_def() }
        "FunDef": { ret ast_new_fun_def() }
        "Param": { ret ast_new_param() }
        "StructField": { ret ast_new_struct_field() }
        "Block": { ret ast_new_block() }
        "Let": { ret ast_new_let() }
        "Return": { ret ast_new_return() }
        "Assign": { ret ast_new_assign() }
        "AssignOp": { ret ast_new_assign_op() }
        "FieldSet": { ret ast_new_field_set() }
        "SubscriptAssign": { ret ast_new_subscript_assign() }
        "If": { ret ast_new_if() }
        "While": { ret ast_new_while() }
        "For": { ret ast_new_for() }
        "Break": { ret ast_new_break() }
        "Continue": { ret ast_new_continue() }
        "Panic": { ret ast_new_panic() }
        "Assert": { ret ast_new_assert() }
        "Match": { ret ast_new_match() }
        "MatchCase": { ret ast_new_match_case() }
        "ExprStmt": { ret ast_new_expr_stmt() }
        "Literal": { ret ast_new_literal() }
        "Char": { ret ast_new_char() }
        "Bool": { ret ast_new_bool() }
        "String": { ret ast_new_string() }
        "FString": { ret ast_new_f_string() }
        "FStringText": { ret ast_new_f_string_text() }
        "Var": { ret ast_new_var() }
        "Binary": { ret ast_new_binary() }
        "Unary": { ret ast_new_unary() }
        "Call": { ret ast_new_call() }
        "DotCall": { ret ast_new_dot_call() }
        "FieldAccess": { ret ast_new_field_access() }
        "Subscript": { ret ast_new_subscript() }
        "Slice": { ret ast_new_slice() }
        "NewArray": { ret ast_new_new_array() }
        "ArrayLiteral": { ret ast_new_array_literal() }
        "StructInit": { ret ast_new_struct_init() }
        "InitField": { ret ast_new_init_field() }
        "UnionInit": { ret ast_new_union_init() }
        "MapInit": { ret ast_new_map_init() }
        else: {}
    }
    ret ast_empty()
}

fun ast_bad_field(field: str): void {
    panic str_cat2("invalid AST field ", field)
}

fun ast_kind(node: AstNode): str { ret node.AstMeta.kind }
fun ast_set_kind(node: AstNode, value: str): void { node.AstMeta.kind = value }
fun ast_line(node: AstNode): i64 { ret node.AstMeta.line }
fun ast_set_line(node: AstNode, value: i64): void { node.AstMeta.line = value }
fun ast_resolved_type(node: AstNode): str { ret node.AstMeta.resolved_type }
fun ast_set_resolved_type(node: AstNode, value: str): void { node.AstMeta.resolved_type = value }

fun ast_funcs(node: AstNode): AstNode[] {
    match node {
        AstProgram n: { ret n.funcs }
        else: {}
    }
    ret new AstNode[0]
}

fun ast_set_funcs(node: AstNode, value: AstNode[]): void {
    match node {
        AstProgram n: { n.funcs = value
            ret
        }
        else: {}
    }
    ast_bad_field("funcs")
}

fun ast_structs(node: AstNode): AstNode[] {
    match node {
        AstProgram n: { ret n.structs }
        else: {}
    }
    ret new AstNode[0]
}

fun ast_set_structs(node: AstNode, value: AstNode[]): void {
    match node {
        AstProgram n: { n.structs = value
            ret
        }
        else: {}
    }
    ast_bad_field("structs")
}

fun ast_globals(node: AstNode): AstNode[] {
    match node {
        AstProgram n: { ret n.globals }
        else: {}
    }
    ret new AstNode[0]
}

fun ast_set_globals(node: AstNode, value: AstNode[]): void {
    match node {
        AstProgram n: { n.globals = value
            ret
        }
        else: {}
    }
    ast_bad_field("globals")
}

fun ast_unions(node: AstNode): AstNode[] {
    match node {
        AstProgram n: { ret n.unions }
        else: {}
    }
    ret new AstNode[0]
}

fun ast_set_unions(node: AstNode, value: AstNode[]): void {
    match node {
        AstProgram n: { n.unions = value
            ret
        }
        else: {}
    }
    ast_bad_field("unions")
}

fun ast_name(node: AstNode): str {
    match node {
        AstStructDef n: { ret n.name }
        AstUnionDef n: { ret n.name }
        AstFunDef n: { ret n.name }
        AstParam n: { ret n.name }
        AstStructField n: { ret n.name }
        AstLet n: { ret n.name }
        AstAssign n: { ret n.name }
        AstFieldSet n: { ret n.name }
        AstFor n: { ret n.name }
        AstVar n: { ret n.name }
        AstCall n: { ret n.name }
        AstDotCall n: { ret n.name }
        AstFieldAccess n: { ret n.name }
        AstStructInit n: { ret n.name }
        AstInitField n: { ret n.name }
        else: {}
    }
    ret ""
}

fun ast_set_name(node: AstNode, value: str): void {
    match node {
        AstStructDef n: { n.name = value
            ret
        }
        AstUnionDef n: { n.name = value
            ret
        }
        AstFunDef n: { n.name = value
            ret
        }
        AstParam n: { n.name = value
            ret
        }
        AstStructField n: { n.name = value
            ret
        }
        AstLet n: { n.name = value
            ret
        }
        AstAssign n: { n.name = value
            ret
        }
        AstFieldSet n: { n.name = value
            ret
        }
        AstFor n: { n.name = value
            ret
        }
        AstVar n: { n.name = value
            ret
        }
        AstCall n: { n.name = value
            ret
        }
        AstDotCall n: { n.name = value
            ret
        }
        AstFieldAccess n: { n.name = value
            ret
        }
        AstStructInit n: { n.name = value
            ret
        }
        AstInitField n: { n.name = value
            ret
        }
        else: {}
    }
    ast_bad_field("name")
}

fun ast_fields(node: AstNode): AstNode[] {
    match node {
        AstStructDef n: { ret n.fields }
        AstMatch n: { ret n.fields }
        AstFString n: { ret n.fields }
        AstStructInit n: { ret n.fields }
        else: {}
    }
    ret new AstNode[0]
}

fun ast_set_fields(node: AstNode, value: AstNode[]): void {
    match node {
        AstStructDef n: { n.fields = value
            ret
        }
        AstMatch n: { n.fields = value
            ret
        }
        AstFString n: { n.fields = value
            ret
        }
        AstStructInit n: { n.fields = value
            ret
        }
        else: {}
    }
    ast_bad_field("fields")
}

