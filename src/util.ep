#
# Shared Epic source utilities.
#

fun make_str_buf(): u8[] {
    ret new u8[]
}

fun str_buf_extend(buf: u8[], s: str): void {
    buf.extend(bytes(s))
}

fun str_buf_finish(buf: u8[]): str {
    ret str(buf)
}

fun str_cat2(a: str, b: str): str {
    let out = make_str_buf()
    str_buf_extend(out, a)
    str_buf_extend(out, b)
    ret str_buf_finish(out)
}
