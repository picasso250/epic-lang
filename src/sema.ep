#
# Epic self-hosted semantic typed dump.
#
# TODO self-host sema: replace string type names with a TypeInfo struct before
# feeding typed sema output into MIR/codegen. String names are kept in this
# catch-up pass to make the Python reference behavior easier to mirror.
#

struct SemaState {
    struct_names: map[str]bool
    struct_fields: map[str]str
    funcs_ret: map[str]str
    funcs_param_count: map[str]i64
    funcs_param_types: map[str]str
    globals: map[str]str
    locals: map[str]str
    current_fn: str
    current_ret: str
    loop_depth: i64
}

fun sema_die(msg: str): void {
    panic str_cat2("Sema error: ", msg)
}

fun sema_starts_with(s: str, prefix: str): bool {
    if len(s) < len(prefix) {
        ret false
    }
    ret s[0:len(prefix)] == prefix
}

fun sema_ends_with(s: str, suffix: str): bool {
    if len(s) < len(suffix) {
        ret false
    }
    ret s[len(s) - len(suffix):len(s)] == suffix
}

fun sema_key2(a: str, b: str): str {
    let out = new u8[]
    extend(out, bytes(a))
    push(out, '.')
    extend(out, bytes(b))
    ret str(out)
}

fun sema_key_index(a: str, i: i64): str {
    ret sema_key2(a, str(i))
}

fun sema_set_type(node: AstNode, typ: str): str {
    node.resolved_type = typ
    ret typ
}

fun sema_need_type(node: AstNode): str {
    if node.resolved_type == "" {
        sema_die(f"internal typed AST missing resolved_type for {node.kind}")
    }
    ret node.resolved_type
}

fun sema_is_int(t: str): bool {
    ret t == "i64" || t == "u64" || t == "i32" || t == "u32" || t == "u8"
}

fun sema_is_array(t: str): bool {
    ret sema_ends_with(t, "[]")
}

fun sema_is_map(t: str): bool {
    ret sema_starts_with(t, "map[str]")
}

fun sema_array_elem(t: str): str {
    if sema_is_array(t) == false {
        sema_die("expected array type")
    }
    ret t[0:len(t) - 2]
}

fun sema_map_value(t: str): str {
    if sema_is_map(t) == false {
        sema_die("expected map type")
    }
    ret t[8:len(t)]
}

fun sema_is_reserved_func(name: str): bool {
    if name == "argv" || name == "print" || name == "println" || name == "exit" || name == "str" || name == "cstr" || name == "bytes" {
        ret true
    }
    if name == "read_file" || name == "write_file" || name == "system" || name == "len" || name == "cap" || name == "push" || name == "extend" {
        ret true
    }
    if name == "map_has" || name == "map_del" {
        ret true
    }
    ret false
}

fun sema_type_name(st: SemaState, name: str): str {
    if name == "" {
        ret "void"
    }
    if sema_is_array(name) {
        let elem = sema_type_name(st, name[0:len(name) - 2])
        if elem == "void" {
            sema_die("array element type cannot be void")
        }
        ret str_cat2(elem, "[]")
    }
    if sema_is_map(name) {
        let value = sema_type_name(st, sema_map_value(name))
        if value != "i64" && value != "bool" && value != "str" {
            sema_die(f"only map[str]i64, map[str]bool, and map[str]str are supported, got {name}")
        }
        ret str_cat2("map[str]", value)
    }
    if name == "i64" || name == "u64" || name == "i32" || name == "u32" || name == "u8" {
        ret name
    }
    if name == "bool" || name == "void" || name == "str" {
        ret name
    }
    if map_has(st.struct_names, name) {
        ret name
    }
    sema_die(f"unknown type {name}")
    ret ""
}

fun sema_lookup(st: SemaState, name: str): str {
    if map_has(st.locals, name) {
        ret st.locals[name]
    }
    if map_has(st.globals, name) {
        ret st.globals[name]
    }
    sema_die(f"undefined variable {name}")
    ret ""
}

fun sema_field_type(st: SemaState, base_type: str, field: str): str {
    if base_type == "str" {
        sema_die(f"unknown field str.{field}")
    }
    if sema_is_array(base_type) {
        sema_die(f"unknown field {sema_key2(base_type, field)}")
    }
    let key = sema_key2(base_type, field)
    if map_has(st.struct_fields, key) == false {
        if map_has(st.struct_names, base_type) == false {
            sema_die(f"field access expected aggregate, got {base_type}")
        }
        sema_die(f"unknown field {key}")
    }
    ret st.struct_fields[key]
}

fun sema_digit_value(c: u8): i64 {
    if c < u8(48) || c > u8(57) {
        ret 0
    }
    ret i64(c) - 48
}

fun sema_parse_i64(s: str): i64 {
    let bs = bytes(s)
    let n = 0
    for i in 0:len(bs) {
        n = n * 10 + sema_digit_value(bs[i])
    }
    ret n
}

fun sema_decimal_gt(a: str, b: str): bool {
    if len(a) > len(b) {
        ret true
    }
    if len(a) < len(b) {
        ret false
    }
    let ab = bytes(a)
    let bb = bytes(b)
    for i in 0:len(ab) {
        if ab[i] > bb[i] {
            ret true
        }
        if ab[i] < bb[i] {
            ret false
        }
    }
    ret false
}

fun sema_check_decimal_i64_literal(s: str, context: str): void {
    if sema_decimal_gt(s, "9223372036854775807") {
        sema_die(f"{context} literal {s} out of range for i64")
    }
}

fun sema_has_literal_int(node: AstNode): bool {
    if node.kind == "Literal" || node.kind == "Char" {
        ret true
    }
    if node.kind == "Unary" {
        ret sema_has_literal_int(node.expr)
    }
    if node.kind == "Binary" {
        ret sema_has_literal_int(node.left) && sema_has_literal_int(node.right)
    }
    ret false
}

fun sema_literal_int(node: AstNode): i64 {
    if node.kind == "Literal" || node.kind == "Char" {
        ret sema_parse_i64(node.value)
    }
    if node.kind == "Unary" {
        let inner = sema_literal_int(node.expr)
        if node.op == "-" {
            ret 0 - inner
        }
        if node.op == "~" {
            ret 0 - inner - 1
        }
        ret inner
    }
    if node.kind == "Binary" {
        let left = sema_literal_int(node.left)
        let right = sema_literal_int(node.right)
        if node.op == "+" {
            ret left + right
        }
        if node.op == "-" {
            ret left - right
        }
        if node.op == "*" {
            ret left * right
        }
        if node.op == "/" {
            if right == 0 {
                ret 0
            }
            ret left / right
        }
        if node.op == "%" {
            if right == 0 {
                ret 0
            }
            ret left % right
        }
        if node.op == "&" {
            ret left & right
        }
        if node.op == "|" {
            ret left | right
        }
        if node.op == "^" {
            ret left ^ right
        }
        if node.op == "<<" {
            ret left << right
        }
        if node.op == ">>" || node.op == ">>>" {
            ret left >> right
        }
    }
    ret 0
}

fun sema_check_int_literal_range(target: str, value: i64, context: str): void {
    if target == "u8" {
        if value < 0 || value > 255 {
            sema_die(f"{context} literal {value} out of range for {target}")
        }
    }
    if target == "i32" {
        if value < (0 - 2147483647 - 1) || value > 2147483647 {
            sema_die(f"{context} literal {value} out of range for {target}")
        }
    }
    if target == "u32" {
        if value < 0 || value > 4294967295 {
            sema_die(f"{context} literal {value} out of range for {target}")
        }
    }
    if target == "i64" {
        if false {
            sema_die(f"{context} literal {value} out of range for {target}")
        }
    }
    if target == "u64" {
        if value < 0 {
            sema_die(f"{context} literal {value} out of range for {target}")
        }
    }
}

fun sema_check_assign_info(target: str, value_type: str, value_node: AstNode, context: str): void {
    if target == "void" {
        sema_die(f"{context} expected non-void target, got void")
    }
    if value_type == "void" {
        sema_die(f"{context} expected {target}, got void")
    }
    if target == value_type {
        if sema_is_int(target) && sema_has_literal_int(value_node) {
            sema_check_int_literal_range(target, sema_literal_int(value_node), context)
        }
        ret
    }
    if sema_is_int(target) && sema_is_int(value_type) {
        sema_die(f"{context} expected {target}, got {value_type}; use {target}(... ) for an explicit conversion")
    }
    sema_die(f"{context} expected {target}, got {value_type}")
}

fun sema_check_assign(st: SemaState, target: str, value_node: AstNode, context: str): void {
    sema_check_assign_info(target, sema_expr_type(st, value_node), value_node, context)
}

fun sema_expect_bool(st: SemaState, node: AstNode, context: str): void {
    let t = sema_expr_type(st, node)
    if t != "bool" {
        sema_die(f"{context} expected bool, got {t}")
    }
}

fun sema_expect_int(st: SemaState, node: AstNode, context: str): str {
    let t = sema_expr_type(st, node)
    if sema_is_int(t) == false {
        sema_die(f"{context} expected integer, got {t}")
    }
    ret t
}

fun sema_check_str_convertible(info_type: str, context: str): void {
    if info_type == "str" || sema_is_int(info_type) || info_type == "bool" || info_type == "u8[]" {
        ret
    }
    if info_type == "void" {
        sema_die(f"{context} argument cannot be void")
    }
    sema_die(f"{context} expected str, integer, bool, or u8[], got {info_type}")
}

fun sema_check_arity(name: str, expected: i64, args: AstNode[]): void {
    if len(args) != expected {
        sema_die(f"{name} expected {expected} arguments, got {len(args)}")
    }
}

fun sema_build_types(st: SemaState, ast: AstNode): void {
    for i in 0:len(ast.structs) {
        let s = ast.structs[i]
        st.struct_names[s.name] = true
    }
    for i in 0:len(ast.structs) {
        let s = ast.structs[i]
        let seen = new map[str]bool
        for j in 0:len(s.fields) {
            let f = s.fields[j]
            if map_has(seen, f.name) {
                sema_die(f"duplicate field {sema_key2(s.name, f.name)}")
            }
            seen[f.name] = true
            f.resolved_type = sema_type_name(st, f.type_name)
            st.struct_fields[sema_key2(s.name, f.name)] = f.resolved_type
        }
    }
}

fun sema_build_funcs(st: SemaState, ast: AstNode): void {
    for i in 0:len(ast.funcs) {
        let f = ast.funcs[i]
        if sema_is_reserved_func(f.name) {
            sema_die(f"reserved builtin function name: {f.name}")
        }
        f.resolved_type = sema_type_name(st, f.type_name)
        st.funcs_ret[f.name] = f.resolved_type
        st.funcs_param_count[f.name] = len(f.params)
        for j in 0:len(f.params) {
            let p = f.params[j]
            p.resolved_type = sema_type_name(st, p.type_name)
            if p.resolved_type == "void" {
                sema_die(f"function {f.name} parameter {p.name} cannot have type void")
            }
            st.funcs_param_types[sema_key_index(f.name, j)] = p.resolved_type
        }
    }
}

fun sema_is_global_literal_init(node: AstNode): bool {
    if node.kind == "Literal" || node.kind == "Char" || node.kind == "Bool" || node.kind == "String" {
        ret true
    }
    if node.kind == "Call" {
        if len(node.args) != 1 {
            ret false
        }
        if node.name != "u8" && node.name != "i64" && node.name != "u64" && node.name != "i32" && node.name != "u32" && node.name != "bool" {
            ret false
        }
        ret sema_is_global_literal_init(node.args[0])
    }
    if node.kind == "ArrayLiteral" {
        for i in 0:len(node.args) {
            if sema_is_global_literal_init(node.args[i]) == false {
                ret false
            }
        }
        ret true
    }
    if node.kind == "MapInit" {
        for i in 0:len(node.map_keys) {
            if sema_is_global_literal_init(node.map_keys[i]) == false {
                ret false
            }
            if sema_is_global_literal_init(node.map_values[i]) == false {
                ret false
            }
        }
        ret true
    }
    if node.kind == "StructInit" {
        for i in 0:len(node.fields) {
            if sema_is_global_literal_init(node.fields[i].value_expr) == false {
                ret false
            }
        }
        ret true
    }
    ret false
}

fun sema_build_globals(st: SemaState, ast: AstNode): void {
    for i in 0:len(ast.globals) {
        let g = ast.globals[i]
        if g.kind != "Let" {
            sema_die("internal: expected top-level let")
        }
        if g.value_expr.kind == "" {
            sema_die(f"global let {g.name} requires an initializer")
        }
        let target = ""
        if g.type_name != "" {
            target = sema_type_name(st, g.type_name)
        }
        let val = sema_expr_type(st, g.value_expr)
        if target == "" {
            target = val
        } else {
            sema_check_assign_info(target, val, g.value_expr, f"global let {g.name}")
        }
        if sema_is_global_literal_init(g.value_expr) == false {
            sema_die(f"global let {g.name} requires a literal initializer")
        }
        g.resolved_type = target
        st.globals[g.name] = target
    }
}

fun sema_reset_locals(st: SemaState): void {
    st.locals = new map[str]str { "argv": "str[]" }
}

fun sema_subscript_type(st: SemaState, base_expr: AstNode, index_expr: AstNode): str {
    let base = sema_expr_type(st, base_expr)
    if sema_is_map(base) {
        sema_check_assign(st, "str", index_expr, "map key")
        ret sema_map_value(base)
    }
    sema_expect_int(st, index_expr, "subscript index")
    if base == "str" {
        sema_die("str subscript is removed; use bytes(s)[i]")
    }
    if sema_is_array(base) {
        ret sema_array_elem(base)
    }
    sema_die(f"subscript expected array, map, or pointer, got {base}")
    ret ""
}

fun sema_expr_type(st: SemaState, node: AstNode): str {
    if node.kind == "Literal" {
        sema_check_decimal_i64_literal(node.value, "integer")
        ret sema_set_type(node, "i64")
    }
    if node.kind == "Char" {
        ret sema_set_type(node, "u8")
    }
    if node.kind == "Bool" {
        ret sema_set_type(node, "bool")
    }
    if node.kind == "String" {
        ret sema_set_type(node, "str")
    }
    if node.kind == "FString" {
        for i in 0:len(node.fields) {
            let part = node.fields[i]
            if part.kind != "FStringText" {
                sema_check_str_convertible(sema_expr_type(st, part), "f-string expression")
            }
        }
        ret sema_set_type(node, "str")
    }
    if node.kind == "Var" {
        ret sema_set_type(node, sema_lookup(st, node.name))
    }
    if node.kind == "Unary" {
        let inner = sema_expr_type(st, node.expr)
        if node.op == "!" {
            if inner != "bool" {
                sema_die(f"unary ! expected bool, got {inner}")
            }
            ret sema_set_type(node, "bool")
        }
        if node.op == "-" || node.op == "~" {
            if sema_is_int(inner) == false {
                sema_die(f"unary {node.op} expected integer, got {inner}")
            }
            ret sema_set_type(node, "i64")
        }
        sema_die(f"unsupported unary operator {node.op}")
    }
    if node.kind == "Binary" {
        let left = sema_expr_type(st, node.left)
        let right = sema_expr_type(st, node.right)
        if node.op == "&&" || node.op == "||" {
            if left != "bool" {
                sema_die(f"{node.op} expected bool, got {left}")
            }
            if right != "bool" {
                sema_die(f"{node.op} expected bool, got {right}")
            }
            ret sema_set_type(node, "bool")
        }
        if node.op == "+" && left == "str" && right == "str" {
            sema_die("string concatenation is removed; use u8[] + extend + str(bytes)")
        }
        if node.op == "==" || node.op == "!=" || node.op == "<" || node.op == ">" || node.op == "<=" || node.op == ">=" {
            if sema_is_int(left) && sema_is_int(right) {
                if left != right {
                    sema_die(f"comparison expected {left}, got {right}; use an explicit conversion")
                }
                ret sema_set_type(node, "bool")
            }
            sema_check_assign_info(left, right, node.right, "comparison")
            ret sema_set_type(node, "bool")
        }
        if sema_is_int(left) == false {
            sema_die(f"operator {node.op} left expected integer, got {left}")
        }
        if sema_is_int(right) == false {
            sema_die(f"operator {node.op} right expected integer, got {right}")
        }
        if node.op == "<<" || node.op == ">>" || node.op == ">>>" {
            ret sema_set_type(node, left)
        }
        if left != right {
            sema_die(f"operator {node.op} expected matching integer types, got {left} and {right}; use an explicit conversion")
        }
        ret sema_set_type(node, left)
    }
    if node.kind == "Call" {
        ret sema_set_type(node, sema_call_type(st, node))
    }
    if node.kind == "FieldAccess" {
        ret sema_set_type(node, sema_field_type(st, sema_expr_type(st, node.object), node.name))
    }
    if node.kind == "Subscript" {
        ret sema_set_type(node, sema_subscript_type(st, node.base, node.index))
    }
    if node.kind == "Slice" {
        let base = sema_expr_type(st, node.base)
        if base != "str" && (sema_is_array(base) == false || sema_array_elem(base) != "u8") {
            sema_die("slice only supports str and u8[]")
        }
        sema_expect_int(st, node.start, "slice start")
        sema_expect_int(st, node.end, "slice end")
        ret sema_set_type(node, base)
    }
    if node.kind == "NewArray" {
        let elem = sema_type_name(st, node.type_name)
        if node.count.kind != "" {
            sema_expect_int(st, node.count, "array length")
        }
        ret sema_set_type(node, str_cat2(elem, "[]"))
    }
    if node.kind == "ArrayLiteral" {
        let elem = sema_type_name(st, node.type_name)
        for i in 0:len(node.args) {
            sema_check_assign(st, elem, node.args[i], "array literal element")
        }
        ret sema_set_type(node, str_cat2(elem, "[]"))
    }
    if node.kind == "StructInit" {
        if map_has(st.struct_names, node.name) == false {
            sema_die(f"unknown struct {node.name}")
        }
        let seen = new map[str]bool
        for i in 0:len(node.fields) {
            let f = node.fields[i]
            if map_has(seen, f.name) {
                sema_die(f"duplicate field initializer {sema_key2(node.name, f.name)}")
            }
            seen[f.name] = true
            let ft = sema_field_type(st, node.name, f.name)
            sema_check_assign(st, ft, f.value_expr, f"field {sema_key2(node.name, f.name)}")
        }
        ret sema_set_type(node, node.name)
    }
    if node.kind == "MapInit" {
        let typ = sema_type_name(st, node.type_name)
        if sema_is_map(typ) {
            let value_type = sema_map_value(typ)
            if len(node.map_keys) != len(node.map_values) {
                sema_die("internal map initializer entry mismatch")
            }
            for i in 0:len(node.map_keys) {
                sema_check_assign(st, "str", node.map_keys[i], "map init key")
                sema_check_assign(st, value_type, node.map_values[i], "map init value")
            }
            ret sema_set_type(node, typ)
        }
        sema_die(f"new expected map, got {typ}")
    }
    sema_die(f"unsupported expression: {node.kind}")
    ret ""
}

fun sema_check_os_call(st: SemaState, node: AstNode, count: i64, ret_type: str): str {
    sema_check_arity(f"os.{node.dll}.{node.name}", count, node.args)
    for i in 0:count {
        sema_check_assign(st, "i64", node.args[i], f"os.{node.dll}.{node.name} argument {i + 1}")
    }
    ret ret_type
}

fun sema_os_call_type(st: SemaState, node: AstNode): str {
    if node.dll != "kernel32" && node.dll != "user32" {
        sema_die(f"unsupported os dll os.{node.dll}")
    }
    if node.dll == "kernel32" {
        if node.name == "ExitProcess" {
            ret sema_check_os_call(st, node, 1, "void")
        }
        if node.name == "Sleep" {
            ret sema_check_os_call(st, node, 1, "void")
        }
        if node.name == "GetTickCount64" {
            ret sema_check_os_call(st, node, 0, "i64")
        }
        if node.name == "lstrlenA" {
            ret sema_check_os_call(st, node, 1, "i64")
        }
        if node.name == "lstrcmpA" {
            ret sema_check_os_call(st, node, 2, "i64")
        }
        if node.name == "GetStdHandle" {
            ret sema_check_os_call(st, node, 1, "i64")
        }
        if node.name == "GetProcessHeap" {
            ret sema_check_os_call(st, node, 0, "i64")
        }
        if node.name == "HeapAlloc" {
            ret sema_check_os_call(st, node, 3, "i64")
        }
        if node.name == "CreateFileA" {
            ret sema_check_os_call(st, node, 7, "i64")
        }
        if node.name == "GetFileSize" {
            ret sema_check_os_call(st, node, 2, "i64")
        }
        if node.name == "ReadFile" {
            ret sema_check_os_call(st, node, 5, "i64")
        }
        if node.name == "WriteFile" {
            ret sema_check_os_call(st, node, 5, "i64")
        }
        if node.name == "CloseHandle" {
            ret sema_check_os_call(st, node, 1, "i64")
        }
        if node.name == "CreateProcessA" {
            ret sema_check_os_call(st, node, 0, "i64")
        }
        if node.name == "WaitForSingleObject" {
            ret sema_check_os_call(st, node, 2, "i64")
        }
        if node.name == "GetExitCodeProcess" {
            ret sema_check_os_call(st, node, 2, "i64")
        }
        if node.name == "GetCommandLineA" {
            ret sema_check_os_call(st, node, 0, "i64")
        }
    }
    if node.dll == "user32" && node.name == "MessageBoxA" {
        ret sema_check_os_call(st, node, 4, "i64")
    }
    sema_die(f"unsupported os call os.{node.dll}.{node.name}")
    ret ""
}

fun sema_call_type(st: SemaState, node: AstNode): str {
    if node.type_name == "os" {
        ret sema_os_call_type(st, node)
    }
    if node.type_name != "" {
        sema_die(f"unsupported namespaced call {node.type_name}.{node.name}")
    }
    if node.name == "print" {
        if len(node.args) != 1 {
            sema_die("print expects 1 argument")
        }
        let arg = sema_expr_type(st, node.args[0])
        if arg != "str" {
            sema_die(f"print expected str, got {arg}")
        }
        ret "void"
    }
    if node.name == "println" {
        if len(node.args) > 1 {
            sema_die("println expects at most one argument")
        }
        if len(node.args) == 1 {
            let arg = sema_expr_type(st, node.args[0])
            if arg != "str" {
                sema_die(f"println expected str, got {arg}")
            }
        }
        ret "void"
    }
    if node.name == "exit" {
        sema_check_arity("exit", 1, node.args)
        sema_check_assign(st, "i64", node.args[0], "exit argument 1")
        ret "void"
    }
    if node.name == "str" {
        sema_check_arity("str", 1, node.args)
        sema_check_str_convertible(sema_expr_type(st, node.args[0]), "str")
        ret "str"
    }
    if node.name == "cstr" {
        sema_check_arity("cstr", 1, node.args)
        sema_check_assign(st, "str", node.args[0], "cstr argument 1")
        ret "i64"
    }
    if node.name == "i64" || node.name == "u64" || node.name == "i32" || node.name == "u32" || node.name == "u8" {
        sema_check_arity(node.name, 1, node.args)
        sema_expect_int(st, node.args[0], f"{node.name} argument")
        ret sema_type_name(st, node.name)
    }
    if node.name == "bool" {
        sema_check_arity("bool", 1, node.args)
        let t = sema_expr_type(st, node.args[0])
        if t != "bool" && sema_is_int(t) == false {
            sema_die(f"bool expected integer or bool, got {t}")
        }
        ret "bool"
    }
    if node.name == "bytes" {
        sema_check_arity("bytes", 1, node.args)
        sema_check_assign(st, "str", node.args[0], "bytes argument 1")
        ret "u8[]"
    }
    if node.name == "read_file" {
        sema_check_arity("read_file", 1, node.args)
        sema_check_assign(st, "str", node.args[0], "read_file argument 1")
        ret "u8[]"
    }
    if node.name == "write_file" {
        sema_check_arity("write_file", 2, node.args)
        sema_check_assign(st, "str", node.args[0], "write_file argument 1")
        sema_check_assign(st, "u8[]", node.args[1], "write_file argument 2")
        ret "i64"
    }
    if node.name == "system" {
        sema_check_arity("system", 1, node.args)
        sema_check_assign(st, "str", node.args[0], "system argument 1")
        ret "i64"
    }
    if node.name == "len" {
        sema_check_arity("len", 1, node.args)
        let arg = sema_expr_type(st, node.args[0])
        if arg != "str" && sema_is_array(arg) == false {
            sema_die(f"len expected str or array, got {arg}")
        }
        ret "i64"
    }
    if node.name == "cap" {
        sema_check_arity("cap", 1, node.args)
        let arg = sema_expr_type(st, node.args[0])
        if sema_is_array(arg) == false {
            sema_die(f"cap expected array, got {arg}")
        }
        ret "i64"
    }
    if node.name == "push" {
        sema_check_arity("push", 2, node.args)
        let arr = sema_expr_type(st, node.args[0])
        if sema_is_array(arr) == false {
            sema_die(f"push expected array, got {arr}")
        }
        sema_check_assign(st, sema_array_elem(arr), node.args[1], "push value")
        ret "void"
    }
    if node.name == "extend" {
        sema_check_arity("extend", 2, node.args)
        let dst = sema_expr_type(st, node.args[0])
        let src = sema_expr_type(st, node.args[1])
        if dst != "u8[]" || src != "u8[]" {
            sema_die("extend only supports u8[]")
        }
        ret "void"
    }
    if node.name == "map_has" || node.name == "map_del" {
        sema_check_arity(node.name, 2, node.args)
        let mt = sema_expr_type(st, node.args[0])
        if sema_is_map(mt) == false {
            sema_die(f"{node.name} expects map")
        }
        sema_check_assign(st, "str", node.args[1], f"{node.name} key")
        ret "bool"
    }
    if map_has(st.funcs_ret, node.name) == false {
        sema_die(f"unknown function {node.name}")
    }
    let expected_count = st.funcs_param_count[node.name]
    sema_check_arity(node.name, expected_count, node.args)
    for i in 0:expected_count {
        sema_check_assign(st, st.funcs_param_types[sema_key_index(node.name, i)], node.args[i], f"{node.name} argument {i + 1}")
    }
    ret st.funcs_ret[node.name]
}

fun sema_lvalue_type(st: SemaState, node: AstNode): str {
    if node.kind == "Var" {
        ret sema_set_type(node, sema_lookup(st, node.name))
    }
    if node.kind == "FieldAccess" || node.kind == "Subscript" {
        ret sema_expr_type(st, node)
    }
    sema_die(f"unsupported assignment target {node.kind}")
    ret ""
}

fun sema_stmt(st: SemaState, node: AstNode): void {
    if node.kind == "Let" {
        if node.value_expr.kind == "" {
            sema_die(f"let {node.name} requires an initializer")
        }
        let target = ""
        if node.type_name != "" {
            target = sema_type_name(st, node.type_name)
        }
        let val = sema_expr_type(st, node.value_expr)
        if target == "" {
            target = val
            if target == "void" {
                sema_die(f"let {node.name} cannot infer void")
            }
        } else {
            sema_check_assign_info(target, val, node.value_expr, f"let {node.name}")
        }
        if target == "void" {
            sema_die(f"let {node.name} cannot have type void")
        }
        node.resolved_type = target
        st.locals[node.name] = target
        ret
    }
    if node.kind == "Assign" {
        sema_check_assign(st, sema_lookup(st, node.name), node.value_expr, f"assignment to {node.name}")
        ret
    }
    if node.kind == "FieldSet" {
        let target = sema_field_type(st, sema_expr_type(st, node.object), node.name)
        sema_check_assign(st, target, node.value_expr, f"assignment to field {node.name}")
        ret
    }
    if node.kind == "SubscriptAssign" {
        sema_check_assign(st, sema_subscript_type(st, node.base, node.index), node.value_expr, "subscript assignment")
        ret
    }
    if node.kind == "AssignOp" {
        let target = sema_lvalue_type(st, node.expr)
        let rhs = sema_expr_type(st, node.value_expr)
        if node.op == "+" && target == "str" {
            sema_die("string += is removed; use u8[] + extend instead")
        }
        if sema_is_int(target) == false {
            sema_die(f"compound assignment expected integer target, got {target}")
        }
        if sema_is_int(rhs) == false {
            sema_die(f"compound assignment value expected integer, got {rhs}")
        }
        if target != rhs {
            sema_die(f"compound assignment expected matching integer types, got {target} and {rhs}; use an explicit conversion")
        }
        ret
    }
    if node.kind == "ExprStmt" {
        sema_expr_type(st, node.expr)
        ret
    }
    if node.kind == "Return" {
        if st.current_ret == "void" {
            if node.expr.kind != "" {
                sema_die(f"return expected void, got {sema_expr_type(st, node.expr)}")
            }
            ret
        }
        if node.expr.kind == "" {
            sema_die(f"return expected {st.current_ret}, got void")
        }
        sema_check_assign(st, st.current_ret, node.expr, "return")
        ret
    }
    if node.kind == "If" {
        sema_expect_bool(st, node.expr, "if condition")
        sema_block(st, node.then_block)
        if node.else_block.kind != "" {
            sema_block(st, node.else_block)
        }
        ret
    }
    if node.kind == "While" {
        sema_expect_bool(st, node.expr, "for condition")
        st.loop_depth += 1
        sema_block(st, node.body)
        st.loop_depth -= 1
        ret
    }
    if node.kind == "For" {
        sema_expect_int(st, node.start, "for range start")
        sema_expect_int(st, node.end, "for range end")
        node.resolved_type = "i64"
        st.locals[node.name] = "i64"
        st.loop_depth += 1
        sema_block(st, node.body)
        st.loop_depth -= 1
        ret
    }
    if node.kind == "Break" {
        if st.loop_depth == 0 {
            sema_die("break outside loop")
        }
        ret
    }
    if node.kind == "Continue" {
        if st.loop_depth == 0 {
            sema_die("continue outside loop")
        }
        ret
    }
    if node.kind == "Assert" {
        sema_expect_bool(st, node.expr, "assert condition")
        if node.value_expr.kind != "" {
            sema_expr_type(st, node.value_expr)
        }
        ret
    }
    if node.kind == "Panic" {
        sema_expr_type(st, node.expr)
        ret
    }
    if node.kind == "Match" {
        let scrutinee = sema_expr_type(st, node.expr)
        for i in 0:len(node.fields) {
            let c = node.fields[i]
            sema_check_assign(st, scrutinee, c.expr, "match pattern")
            sema_block(st, c.body)
        }
        if node.else_block.kind != "" {
            sema_block(st, node.else_block)
        }
        ret
    }
    sema_die(f"unsupported statement: {node.kind}")
}

fun sema_block(st: SemaState, block: AstNode): void {
    for i in 0:len(block.stmts) {
        sema_stmt(st, block.stmts[i])
    }
}

fun sema_expr_is_exit(node: AstNode): bool {
    if node.kind != "Call" {
        ret false
    }
    if node.type_name == "" && node.name == "exit" {
        ret true
    }
    ret node.type_name == "os" && node.dll == "kernel32" && node.name == "ExitProcess"
}

fun sema_stmt_returns(node: AstNode): bool {
    if node.kind == "Return" || node.kind == "Panic" {
        ret true
    }
    if node.kind == "ExprStmt" && sema_expr_is_exit(node.expr) {
        ret true
    }
    if node.kind == "If" {
        if node.else_block.kind == "" {
            ret false
        }
        ret sema_block_returns(node.then_block) && sema_block_returns(node.else_block)
    }
    if node.kind == "Match" {
        if node.else_block.kind == "" {
            ret false
        }
        for i in 0:len(node.fields) {
            if sema_block_returns(node.fields[i].body) == false {
                ret false
            }
        }
        ret sema_block_returns(node.else_block)
    }
    ret false
}

fun sema_block_returns(block: AstNode): bool {
    for i in 0:len(block.stmts) {
        if sema_stmt_returns(block.stmts[i]) {
            ret true
        }
    }
    ret false
}

fun sema_program(st: SemaState, ast: AstNode): void {
    sema_build_types(st, ast)
    sema_build_funcs(st, ast)
    sema_build_globals(st, ast)
    for i in 0:len(ast.funcs) {
        let f = ast.funcs[i]
        sema_reset_locals(st)
        st.current_fn = f.name
        st.current_ret = f.resolved_type
        st.loop_depth = 0
        for j in 0:len(f.params) {
            let p = f.params[j]
            st.locals[p.name] = p.resolved_type
        }
        sema_block(st, f.body)
        if st.current_ret != "void" && sema_block_returns(f.body) == false {
            sema_die(f"function must return {st.current_ret} on all paths")
        }
    }
}

fun sema_indent(n: i64): void {
    for i in 0:n {
        print("  ")
    }
}

fun sema_print_type(t: str): void {
    if t != "" {
        print(" : ")
        print(t)
    }
}

fun sema_dump_list(nodes: AstNode[], depth: i64): void {
    for i in 0:len(nodes) {
        sema_dump_node(nodes[i], depth)
    }
}

fun sema_print_expr_head(kind: str, extra: str, t: str): void {
    print(kind)
    if extra != "" {
        print(" ")
        print(extra)
    }
    sema_print_type(t)
    println("")
}

fun sema_dump_node(node: AstNode, depth: i64): void {
    if node.kind == "" {
        ret
    }
    if node.kind == "Program" {
        sema_indent(depth)
        println("Program")
        sema_dump_list(node.structs, depth + 1)
        sema_dump_list(node.globals, depth + 1)
        sema_dump_list(node.funcs, depth + 1)
        ret
    }
    if node.kind == "StructDef" {
        sema_indent(depth)
        print("StructDef ")
        println(node.name)
        sema_dump_list(node.fields, depth + 1)
        ret
    }
    if node.kind == "StructField" {
        sema_indent(depth)
        print("StructField ")
        print(node.name)
        sema_print_type(sema_need_type(node))
        println("")
        ret
    }
    if node.kind == "FunDef" {
        sema_indent(depth)
        print("FunDef ")
        print(node.name)
        sema_print_type(sema_need_type(node))
        println("")
        sema_dump_list(node.params, depth + 1)
        sema_dump_node(node.body, depth + 1)
        ret
    }
    if node.kind == "Param" {
        sema_indent(depth)
        print("Param ")
        print(node.name)
        sema_print_type(sema_need_type(node))
        println("")
        ret
    }
    if node.kind == "Block" {
        sema_indent(depth)
        println("Block")
        sema_dump_list(node.stmts, depth + 1)
        ret
    }
    if node.kind == "Let" {
        sema_indent(depth)
        print("Let ")
        print(node.name)
        sema_print_type(sema_need_type(node))
        println("")
        sema_dump_node(node.value_expr, depth + 1)
        ret
    }
    if node.kind == "Return" {
        sema_indent(depth)
        println("Return")
        sema_dump_node(node.expr, depth + 1)
        ret
    }
    if node.kind == "Assign" {
        sema_indent(depth)
        print("Assign ")
        println(node.name)
        sema_dump_node(node.value_expr, depth + 1)
        ret
    }
    if node.kind == "AssignOp" {
        sema_indent(depth)
        print("AssignOp ")
        println(node.op)
        sema_dump_node(node.expr, depth + 1)
        sema_dump_node(node.value_expr, depth + 1)
        ret
    }
    if node.kind == "FieldSet" {
        sema_indent(depth)
        print("FieldSet ")
        println(node.name)
        sema_dump_node(node.value_expr, depth + 1)
        sema_dump_node(node.object, depth + 1)
        ret
    }
    if node.kind == "SubscriptAssign" {
        sema_indent(depth)
        println("SubscriptAssign")
        sema_dump_node(node.value_expr, depth + 1)
        sema_dump_node(node.base, depth + 1)
        sema_dump_node(node.index, depth + 1)
        ret
    }
    if node.kind == "If" {
        sema_indent(depth)
        println("If")
        sema_dump_node(node.then_block, depth + 1)
        sema_dump_node(node.else_block, depth + 1)
        sema_dump_node(node.expr, depth + 1)
        ret
    }
    if node.kind == "While" {
        sema_indent(depth)
        println("While")
        sema_dump_node(node.body, depth + 1)
        sema_dump_node(node.expr, depth + 1)
        ret
    }
    if node.kind == "For" {
        sema_indent(depth)
        print("For ")
        print(node.name)
        sema_print_type(sema_need_type(node))
        println("")
        sema_dump_node(node.body, depth + 1)
        sema_dump_node(node.start, depth + 1)
        sema_dump_node(node.end, depth + 1)
        ret
    }
    if node.kind == "Break" || node.kind == "Continue" {
        sema_indent(depth)
        println(node.kind)
        ret
    }
    if node.kind == "Assert" {
        sema_indent(depth)
        println("Assert")
        sema_dump_node(node.expr, depth + 1)
        sema_dump_node(node.value_expr, depth + 1)
        ret
    }
    if node.kind == "Panic" {
        sema_indent(depth)
        println("Panic")
        sema_dump_node(node.expr, depth + 1)
        ret
    }
    if node.kind == "Match" {
        sema_indent(depth)
        println("Match")
        sema_dump_node(node.expr, depth + 1)
        sema_dump_list(node.fields, depth + 1)
        if node.else_block.kind != "" {
            sema_indent(depth + 1)
            println("MatchCase")
            sema_dump_node(node.else_block, depth + 2)
        }
        ret
    }
    if node.kind == "MatchCase" {
        sema_indent(depth)
        println("MatchCase")
        sema_dump_node(node.expr, depth + 1)
        sema_dump_node(node.body, depth + 1)
        ret
    }
    if node.kind == "ExprStmt" {
        sema_indent(depth)
        println("ExprStmt")
        sema_dump_node(node.expr, depth + 1)
        ret
    }
    if node.kind == "FStringText" {
        sema_indent(depth)
        print("FStringText ")
        println(node.value)
        ret
    }

    let t = sema_need_type(node)
    sema_indent(depth)
    if node.kind == "Literal" || node.kind == "Char" || node.kind == "Bool" || node.kind == "String" {
        print(node.kind)
        print(" ")
        print(node.value)
        sema_print_type(t)
        println("")
        ret
    }
    if node.kind == "FString" {
        sema_print_expr_head(node.kind, "", t)
        sema_dump_list(node.fields, depth + 1)
        ret
    }
    if node.kind == "Var" {
        sema_print_expr_head("Var", node.name, t)
        ret
    }
    if node.kind == "Call" {
        print("Call ")
        print(node.name)
        if node.type_name != "" {
            print(" : ")
            print(node.type_name)
        }
        sema_print_type(t)
        println("")
        sema_dump_list(node.args, depth + 1)
        ret
    }
    if node.kind == "Binary" {
        sema_print_expr_head("Binary", node.op, t)
        sema_dump_node(node.left, depth + 1)
        sema_dump_node(node.right, depth + 1)
        ret
    }
    if node.kind == "Unary" {
        sema_print_expr_head("Unary", node.op, t)
        sema_dump_node(node.expr, depth + 1)
        ret
    }
    if node.kind == "FieldAccess" {
        sema_print_expr_head("FieldAccess", node.name, t)
        sema_dump_node(node.object, depth + 1)
        ret
    }
    if node.kind == "Subscript" {
        sema_print_expr_head("Subscript", "", t)
        sema_dump_node(node.base, depth + 1)
        sema_dump_node(node.index, depth + 1)
        ret
    }
    if node.kind == "Slice" {
        sema_print_expr_head("Slice", "", t)
        sema_dump_node(node.base, depth + 1)
        sema_dump_node(node.start, depth + 1)
        sema_dump_node(node.end, depth + 1)
        ret
    }
    if node.kind == "MapInit" {
        print("MapInit : ")
        print(node.type_name)
        sema_print_type(t)
        println("")
        for i in 0:len(node.map_keys) {
            sema_indent(depth + 1)
            println("Key")
            sema_dump_node(node.map_keys[i], depth + 2)
            sema_indent(depth + 1)
            println("Value")
            sema_dump_node(node.map_values[i], depth + 2)
        }
        ret
    }
    if node.kind == "NewArray" {
        print("NewArray : ")
        print(node.type_name)
        sema_print_type(t)
        println("")
        sema_dump_node(node.count, depth + 1)
        ret
    }
    if node.kind == "ArrayLiteral" {
        print("ArrayLiteral : ")
        print(node.type_name)
        sema_print_type(t)
        println("")
        sema_dump_list(node.args, depth + 1)
        ret
    }
    if node.kind == "StructInit" {
        print("StructInit ")
        print(node.name)
        sema_print_type(t)
        println("")
        for i in 0:len(node.fields) {
            let f = node.fields[i]
            sema_indent(depth + 1)
            print("InitField ")
            println(f.name)
            sema_dump_node(f.value_expr, depth + 2)
        }
        ret
    }
    sema_die(f"unsupported dump node {node.kind}")
}

fun make_sema_state(): SemaState {
    let st = new SemaState
    st.struct_names = new map[str]bool
    st.struct_fields = new map[str]str
    st.funcs_ret = new map[str]str
    st.funcs_param_count = new map[str]i64
    st.funcs_param_types = new map[str]str
    st.globals = new map[str]str
    st.locals = new map[str]str { "argv": "str[]" }
    st.current_fn = ""
    st.current_ret = "void"
    st.loop_depth = 0
    ret st
}

fun main(): void {
    if len(argv) < 2 {
        panic "usage: sema <file>"
    }
    let src = str(read_file(argv[1]))
    let tokens = lex(src)
    let p = make_parser(tokens)
    let ast = parse_program(p)
    let st = make_sema_state()
    sema_program(st, ast)
    sema_dump_node(ast, 0)
}
