#
# Minimal self-hosted typed AST -> AST-to-MIR.
# First milestone path: user-function MIR text oracle comparison against Python.
#

struct MirCodegenState {
    program: MirProgram
    current_fn: MirFunction
    current_block: MirBlock
    value_counter: i64
    block_counter: i64
    local_names: str[]
    local_addr_names: str[]
    local_types: str[]
    func_names: str[]
    func_return_types: str[]
    global_names: str[]
    global_types: str[]
    continue_targets: str[]
    break_targets: str[]
    struct_names: str[]
    union_names: str[]
    union_member_keys: str[]
    union_member_tags: i64[]
    union_member_names: str[]
    struct_field_keys: str[]
    struct_field_types: str[]
    struct_field_indexes: i64[]
    struct_field_embedded: i64[]
    string_values: str[]
    string_labels: str[]
    string_counter: i64
}

struct MirValueFlow {
    value: MirOperand
    block: MirBlock
}

struct MirBlockFlow {
    reachable: bool
    block: MirBlock
}

fun mir_value_flow(value: MirOperand, block: MirBlock): MirValueFlow {
    let flow = new MirValueFlow
    flow.value = value
    flow.block = block
    ret flow
}

fun mir_reachable_flow(block: MirBlock): MirBlockFlow {
    let flow = new MirBlockFlow
    flow.reachable = true
    flow.block = block
    ret flow
}

fun mir_unreachable_flow(): MirBlockFlow {
    let flow = new MirBlockFlow
    flow.reachable = false
    flow.block = mir_block_empty("")
    ret flow
}

fun ast_to_mir_die(msg: str): void {
    panic str_cat2("AST-to-MIR error: ", msg)
}

fun mir_epic_type(type_name: str): str {
    if type_name == "void" {
        ret "void"
    }
    if type_name == "bool" {
        ret "bool"
    }
    if type_name == "i64" || type_name == "i32" || type_name == "u64" || type_name == "u32" || type_name == "u8" {
        ret "i64"
    }
    ret "ptr"
}

fun mir_new_value(st: MirCodegenState, hint: str): str {
    st.value_counter = st.value_counter + 1
    ret str_cat2(hint, str(st.value_counter))
}

fun mir_new_block(st: MirCodegenState, prefix: str): MirBlock {
    st.block_counter = st.block_counter + 1
    let block = mir_block_empty(str_cat2(prefix, str(st.block_counter)))
    st.current_fn.blocks.push(block)
    ret block
}

fun mir_emit_inst(st: MirCodegenState, inst: MirInst): void {
    st.current_block.instructions.push(inst)
}

fun mir_alloc_local(st: MirCodegenState, name: str, typ: str): MirOperand {
    let addr_name = mir_new_value(st, str_cat2(name, ".addr"))
    mir_emit_inst(st, mir_alloca(addr_name, typ))
    st.local_names.push(name)
    st.local_addr_names.push(addr_name)
    st.local_types.push(typ)
    ret mir_value_operand("ptr", addr_name)
}

fun mir_local_index(st: MirCodegenState, name: str): i64 {
    let i = len(st.local_names) - 1
    for i >= 0 {
        if st.local_names[i] == name {
            ret i
        }
        i = i - 1
    }
    ast_to_mir_die(f"undefined variable: {name}")
    ret 0
}

fun mir_global_label(name: str): str {
    ret str_cat2("__epg_", name)
}

fun mir_global_index(st: MirCodegenState, name: str): i64 {
    let i = 0
    for i < len(st.global_names) {
        if st.global_names[i] == name {
            ret i
        }
        i = i + 1
    }
    ret 0 - 1
}


fun mir_add_global_lets(st: MirCodegenState, ast: AstProgram): void {
    let i = 0
    for i < len(ast.globals) {
        match ast.globals[i] {
            AstLet g: {
                let typ = mir_epic_type(g.AstMeta.resolved_type)
                let label = mir_global_label(g.name)
                st.global_names.push(g.name)
                st.global_types.push(typ)
                st.program.globals.push(mir_global_decl(label, typ))
            }
            _: { ast_to_mir_die("internal: expected top-level let") }
        }
        i = i + 1
    }
}



fun mir_emit_global_init_function(st: MirCodegenState, ast: AstProgram): void {
    if len(ast.globals) == 0 {
        ret
    }
    st.value_counter = 0
    st.block_counter = 0
    st.local_names = new str[0]
    st.local_addr_names = new str[0]
    st.local_types = new str[0]
    st.continue_targets = new str[0]
    st.break_targets = new str[0]
    st.current_fn = mir_function_empty("__ep_global_init", "void")
    st.current_block = mir_new_block(st, "entry")

    let i = 0
    for i < len(ast.globals) {
        match ast.globals[i] {
            AstLet g: {
                let value_flow = mir_emit_expr(st, st.current_block, g.value_expr)
                st.current_block = value_flow.block
                let addr = mir_symbol_operand("ptr", mir_global_label(g.name))
                mir_emit_inst(st, mir_store(value_flow.value, addr))
            }
            _: { ast_to_mir_die("internal: expected top-level let") }
        }
        i = i + 1
    }
    if st.current_block.has_terminator == false {
        st.current_block.terminator = mir_ret_void()
        st.current_block.has_terminator = true
    }
    st.program.functions.push(st.current_fn)
}


fun mir_struct_key(struct_name: str, field_name: str): str {
    ret str_cat2(str_cat2(struct_name, "."), field_name)
}

fun mir_is_union_name(st: MirCodegenState, name: str): bool {
    for i in 0:len(st.union_names) {
        if st.union_names[i] == name {
            ret true
        }
    }
    ret false
}

fun mir_union_tag(st: MirCodegenState, union_name: str, member_name: str): i64 {
    let key = mir_struct_key(union_name, member_name)
    for i in 0:len(st.union_member_keys) {
        if st.union_member_keys[i] == key {
            ret st.union_member_tags[i]
        }
    }
    ast_to_mir_die(f"unknown union member {key}")
    ret 0
}

fun mir_layout_struct_name(st: MirCodegenState, type_name: str): str {
    let slice_name = mir_slice_struct_name(st, type_name)
    if slice_name != "" {
        ret slice_name
    }
    let map_suffix = mir_map_suffix(type_name)
    if map_suffix != "" {
        ret str_cat2("_map_str_", map_suffix)
    }
    let i = 0
    for i < len(st.struct_names) {
        if st.struct_names[i] == type_name {
            ret type_name
        }
        i = i + 1
    }
    ret ""
}

fun mir_direct_field_index(st: MirCodegenState, struct_name: str, field_name: str): i64 {
    let key = mir_struct_key(struct_name, field_name)
    for i in 0:len(st.struct_field_keys) {
        if st.struct_field_keys[i] == key {
            ret st.struct_field_indexes[i]
        }
    }
    ret 0 - 1
}

fun mir_field_index(st: MirCodegenState, struct_name: str, field_name: str): i64 {
    let idx = mir_direct_field_index(st, struct_name, field_name)
    if idx >= 0 {
        ret idx
    }
    ast_to_mir_die(f"unknown struct field {mir_struct_key(struct_name, field_name)}")
    ret 0
}

fun mir_direct_field_type(st: MirCodegenState, struct_name: str, field_name: str): str {
    let key = mir_struct_key(struct_name, field_name)
    for i in 0:len(st.struct_field_keys) {
        if st.struct_field_keys[i] == key {
            ret st.struct_field_types[i]
        }
    }
    ret ""
}

fun mir_field_type(st: MirCodegenState, struct_name: str, field_name: str): str {
    let typ = mir_direct_field_type(st, struct_name, field_name)
    if typ != "" {
        ret typ
    }
    ast_to_mir_die(f"unknown struct field {mir_struct_key(struct_name, field_name)}")
    ret "i64"
}

fun mir_is_embedded_field(st: MirCodegenState, struct_name: str, field_name: str): bool {
    let key = mir_struct_key(struct_name, field_name)
    for i in 0:len(st.struct_field_keys) {
        if st.struct_field_keys[i] == key {
            ret st.struct_field_embedded[i] != 0
        }
    }
    ret false
}

fun mir_promoted_field_type_inner(st: MirCodegenState, struct_name: str, field_name: str, depth: i64): str {
    if depth <= 0 {
        ast_to_mir_die(f"embedded field cycle while resolving {mir_struct_key(struct_name, field_name)}")
    }
    let direct = mir_direct_field_type(st, struct_name, field_name)
    if direct != "" {
        ret direct
    }
    let found = ""
    for i in 0:len(st.struct_field_keys) {
        let prefix = str_cat2(struct_name, ".")
        let key = st.struct_field_keys[i]
        if len(key) > len(prefix) && key[0:len(prefix)] == prefix && st.struct_field_embedded[i] != 0 {
            let embedded_type = st.struct_field_types[i]
            if embedded_type == "ptr" {
                let embedded_name = key[len(prefix):len(key)]
                embedded_type = embedded_name
            }
            let candidate = mir_promoted_field_type_inner(st, embedded_type, field_name, depth - 1)
            if candidate != "" {
                if found != "" {
                    ast_to_mir_die(f"ambiguous field {mir_struct_key(struct_name, field_name)}")
                }
                found = candidate
            }
        }
    }
    ret found
}

fun mir_promoted_field_type(st: MirCodegenState, struct_name: str, field_name: str): str {
    let typ = mir_promoted_field_type_inner(st, struct_name, field_name, 64)
    if typ == "" {
        ast_to_mir_die(f"unknown struct field {mir_struct_key(struct_name, field_name)}")
    }
    ret typ
}

fun mir_func_return_type(st: MirCodegenState, name: str): str {
    let i = 0
    for i < len(st.func_names) {
        if st.func_names[i] == name {
            ret st.func_return_types[i]
        }
        i = i + 1
    }
    ast_to_mir_die(f"undefined function: {name}")
    ret "i64"
}

fun str_replace_char_local(s: str, from_ch: i64, to_ch: i64): str {
    let out = make_str_buf()
    let bs = bytes(s)
    let i = 0
    for i < len(bs) {
        if i64(bs[i]) == from_ch {
            out.push(u8(to_ch))
        } else {
            out.push(bs[i])
        }
        i = i + 1
    }
    ret str(out)
}

fun mir_is_unsigned_int_type(type_name: str): bool {
    ret type_name == "u64" || type_name == "u32" || type_name == "u8"
}

fun mir_binary_op(expr_op: str, source_type: str): str {
    let unsigned = mir_is_unsigned_int_type(source_type)
    if expr_op == "+" { ret "add" }
    if expr_op == "-" { ret "sub" }
    if expr_op == "*" { ret "mul" }
    if expr_op == "/" {
        if unsigned { ret "udiv" }
        ret "sdiv"
    }
    if expr_op == "%" {
        if unsigned { ret "urem" }
        ret "srem"
    }
    if expr_op == "&" { ret "and" }
    if expr_op == "|" { ret "or" }
    if expr_op == "^" { ret "xor" }
    if expr_op == "<<" { ret "shl" }
    if expr_op == ">>" { ret "sar" }
    if expr_op == ">>>" { ret "shr" }
    if expr_op == "==" { ret "icmp.eq" }
    if expr_op == "!=" { ret "icmp.ne" }
    if expr_op == "<" {
        if unsigned { ret "icmp.ult" }
        ret "icmp.slt"
    }
    if expr_op == ">" {
        if unsigned { ret "icmp.ugt" }
        ret "icmp.sgt"
    }
    if expr_op == "<=" {
        if unsigned { ret "icmp.ule" }
        ret "icmp.sle"
    }
    if expr_op == ">=" {
        if unsigned { ret "icmp.uge" }
        ret "icmp.sge"
    }
    ast_to_mir_die(f"unsupported binary op {expr_op}")
    ret ""
}

fun mir_op_result_type(op: str): str {
    if op == "icmp.eq" || op == "icmp.ne" || op == "icmp.slt" || op == "icmp.sgt" || op == "icmp.sle" || op == "icmp.sge" || op == "icmp.ult" || op == "icmp.ugt" || op == "icmp.ule" || op == "icmp.uge" {
        ret "bool"
    }
    ret "i64"
}

fun mir_shift_width(source_type: str): i64 {
    if source_type == "u8" { ret 8 }
    if source_type == "i32" || source_type == "u32" { ret 32 }
    ret 64
}

fun mir_emit_shift_count_check(st: MirCodegenState, count: MirOperand, source_type: str, line: i64): void {
    let width = mir_shift_width(source_type)
    let high_block = mir_new_block(st, "shift.high")
    let ok_block = mir_new_block(st, "shift.ok")
    let fail_block = mir_new_block(st, "shift.fail")
    let nonneg = mir_make_result_inst(st, "icmp.sge", "bool")
    nonneg.operands.push(count)
    nonneg.operands.push(mir_const_int("i64", 0))
    mir_emit_inst(st, nonneg)
    st.current_block.terminator = mir_condbr(mir_value_operand("bool", nonneg.result_name), high_block.name, fail_block.name)
    st.current_block.has_terminator = true
    st.current_block = high_block
    let in_range = mir_make_result_inst(st, "icmp.slt", "bool")
    in_range.operands.push(count)
    in_range.operands.push(mir_const_int("i64", width))
    mir_emit_inst(st, in_range)
    st.current_block.terminator = mir_condbr(mir_value_operand("bool", in_range.result_name), ok_block.name, fail_block.name)
    st.current_block.has_terminator = true
    st.current_block = fail_block
    let print_args = new MirOperand[0]
    print_args.push(mir_symbol_operand("ptr", mir_string_label(st, str_cat2(str_cat2("pa", "nic line "), str_cat2(str(line), ": invalid shift count")))))
    mir_emit_call_inst(st, "__ep_print_str", "void", print_args)
    let nl_args = new MirOperand[0]
    mir_emit_call_inst(st, "__ep_print_newline", "void", nl_args)
    let exit_args = new MirOperand[0]
    exit_args.push(mir_const_int("i64", 1))
    mir_emit_inst(st, mir_call(str_cat2("Exit", "Process"), "void", exit_args))
    if st.current_fn.return_type == "void" { st.current_block.terminator = mir_ret_void() } else { st.current_block.terminator = mir_ret_value(mir_const_int(st.current_fn.return_type, 0)) }
    st.current_block.has_terminator = true
    st.current_block = ok_block
}

fun mir_make_gep(st: MirCodegenState, source_type: str, operands: MirOperand[]): MirOperand {
    let inst = mir_make_result_inst(st, "gep", "ptr")
    inst.typ = source_type
    inst.operands = operands
    mir_emit_inst(st, inst)
    ret mir_value_operand("ptr", inst.result_name)
}

fun mir_make_ptrtoint(st: MirCodegenState, operand: MirOperand, target_type: str): MirOperand {
    let inst = mir_make_result_inst(st, "ptrtoint", target_type)
    inst.typ = target_type
    inst.operands.push(operand)
    mir_emit_inst(st, inst)
    ret mir_value_operand(target_type, inst.result_name)
}

fun mir_emit_call_inst(st: MirCodegenState, callee: str, ret_type: str, args: MirOperand[]): MirOperand {
    let inst = mir_inst_empty()
    inst.op = "call"
    inst.callee = callee
    inst.typ = ret_type
    inst.operands = args
    if ret_type == "void" {
        mir_emit_inst(st, inst)
        ret mir_const_int("i64", 0)
    }
    inst.result_name = mir_new_value(st, "call")
    inst.result_type = ret_type
    inst.has_result = true
    mir_emit_inst(st, inst)
    ret mir_value_operand(ret_type, inst.result_name)
}

fun mir_make_result_inst(st: MirCodegenState, op: str, result_type: str): MirInst {
    let inst = mir_inst_empty()
    inst.op = op
    inst.result_name = mir_new_value(st, str_replace_char_local(op, 46, 95))
    inst.result_type = result_type
    inst.has_result = true
    ret inst
}

fun mir_field_addr(st: MirCodegenState, base: MirOperand, struct_name: str, field_name: str): MirOperand {
    let ops = new MirOperand[0]
    ops.push(base)
    ops.push(mir_const_int("i64", 0))
    ops.push(mir_const_int("i32", mir_field_index(st, struct_name, field_name)))
    ret mir_make_gep(st, str_cat2("struct ", struct_name), ops)
}

fun mir_load_field(st: MirCodegenState, base: MirOperand, struct_name: str, field_name: str): MirOperand {
    let field_typ = mir_field_type(st, struct_name, field_name)
    let addr = mir_field_addr(st, base, struct_name, field_name)
    let result_name = mir_new_value(st, "load")
    mir_emit_inst(st, mir_load(result_name, field_typ, field_typ, addr))
    ret mir_value_operand(field_typ, result_name)
}

fun mir_promoted_field_addr_inner(st: MirCodegenState, base: MirOperand, struct_name: str, field_name: str, depth: i64): MirOperand {
    if depth <= 0 {
        ast_to_mir_die(f"embedded field cycle while resolving {mir_struct_key(struct_name, field_name)}")
    }
    if mir_direct_field_type(st, struct_name, field_name) != "" {
        ret mir_field_addr(st, base, struct_name, field_name)
    }
    let found_count = 0
    let found = mir_operand_null()
    for i in 0:len(st.struct_field_keys) {
        let prefix = str_cat2(struct_name, ".")
        let key = st.struct_field_keys[i]
        if len(key) > len(prefix) && key[0:len(prefix)] == prefix && st.struct_field_embedded[i] != 0 {
            let embedded_name = key[len(prefix):len(key)]
            let embedded_type = embedded_name
            if mir_promoted_field_type_inner(st, embedded_type, field_name, depth - 1) != "" {
                if found_count > 0 {
                    ast_to_mir_die(f"ambiguous field {mir_struct_key(struct_name, field_name)}")
                }
                let embedded_obj = mir_load_field(st, base, struct_name, embedded_name)
                found = mir_promoted_field_addr_inner(st, embedded_obj, embedded_type, field_name, depth - 1)
                found_count = found_count + 1
            }
        }
    }
    if found_count == 0 {
        ast_to_mir_die(f"unknown struct field {mir_struct_key(struct_name, field_name)}")
    }
    ret found
}

fun mir_promoted_field_addr(st: MirCodegenState, base: MirOperand, struct_name: str, field_name: str): MirOperand {
    ret mir_promoted_field_addr_inner(st, base, struct_name, field_name, 64)
}

fun mir_load_promoted_field(st: MirCodegenState, base: MirOperand, struct_name: str, field_name: str): MirOperand {
    let field_typ = mir_promoted_field_type(st, struct_name, field_name)
    let addr = mir_promoted_field_addr(st, base, struct_name, field_name)
    let result_name = mir_new_value(st, "load")
    mir_emit_inst(st, mir_load(result_name, field_typ, field_typ, addr))
    ret mir_value_operand(field_typ, result_name)
}

fun mir_union_member_names(st: MirCodegenState, union_name: str): str[] {
    let out = new str[0]
    let prefix = str_cat2(union_name, ".")
    for i in 0:len(st.union_member_keys) {
        let key = st.union_member_keys[i]
        if len(key) > len(prefix) && key[0:len(prefix)] == prefix {
            out.push(st.union_member_names[i])
        }
    }
    ret out
}

fun mir_union_common_embedded_field_type(st: MirCodegenState, union_name: str, field_name: str): str {
    let members = mir_union_member_names(st, union_name)
    let found = ""
    for i in 0:len(members) {
        let candidate = ""
        if mir_is_embedded_field(st, members[i], field_name) {
            candidate = mir_field_type(st, members[i], field_name)
        } else {
            candidate = mir_promoted_field_type_inner(st, members[i], field_name, 64)
            if candidate == "" {
                ast_to_mir_die(f"union {union_name} has no common embedded field {field_name}")
            }
        }
        if found != "" && found != candidate {
            ast_to_mir_die(f"union {union_name} embedded field {field_name} has inconsistent types")
        }
        found = candidate
    }
    if found == "" {
        ast_to_mir_die(f"union {union_name} has no common embedded field {field_name}")
    }
    ret found
}

fun mir_union_has_common_embedded_field(st: MirCodegenState, union_name: str, field_name: str): bool {
    let members = mir_union_member_names(st, union_name)
    if len(members) == 0 {
        ret false
    }
    for i in 0:len(members) {
        if mir_is_embedded_field(st, members[i], field_name) == false && mir_promoted_field_type_inner(st, members[i], field_name, 64) == "" {
            ret false
        }
    }
    ret true
}

fun mir_union_partial_field_type(st: MirCodegenState, union_name: str, field_name: str): str {
    let members = mir_union_member_names(st, union_name)
    let found = ""
    for i in 0:len(members) {
        let candidate = mir_direct_field_type(st, members[i], field_name)
        if candidate != "" {
            if found != "" && found != candidate {
                ast_to_mir_die(f"union {union_name} field {field_name} has inconsistent types")
            }
            found = candidate
        }
    }
    if found == "" {
        ast_to_mir_die(f"union {union_name} has no variant field {field_name}")
    }
    ret found
}

fun mir_union_partial_field_members(st: MirCodegenState, union_name: str, field_name: str): str[] {
    let out = new str[0]
    let members = mir_union_member_names(st, union_name)
    for i in 0:len(members) {
        if mir_direct_field_type(st, members[i], field_name) != "" {
            out.push(members[i])
        }
    }
    if len(out) == 0 {
        ast_to_mir_die(f"union {union_name} has no variant field {field_name}")
    }
    ret out
}

fun mir_emit_union_field_has(st: MirCodegenState, union_value: MirOperand, union_name: str, field_name: str): MirOperand {
    let members = mir_union_partial_field_members(st, union_name, field_name)
    let result = mir_const_bool(false)
    for i in 0:len(members) {
        let tag = mir_load_field(st, union_value, union_name, "tag")
        let cond = mir_make_result_inst(st, "icmp.eq", "bool")
        cond.operands.push(tag)
        cond.operands.push(mir_const_int("i64", mir_union_tag(st, union_name, members[i])))
        mir_emit_inst(st, cond)
        let cond_value = mir_value_operand("bool", cond.result_name)
        if i == 0 {
            result = cond_value
        } else {
            let or_inst = mir_make_result_inst(st, "or", "bool")
            or_inst.operands.push(result)
            or_inst.operands.push(cond_value)
            mir_emit_inst(st, or_inst)
            result = mir_value_operand("bool", or_inst.result_name)
        }
    }
    ret result
}

fun mir_load_union_partial_field(st: MirCodegenState, union_value: MirOperand, union_name: str, field_name: str): MirValueFlow {
    let field_typ = mir_union_partial_field_type(st, union_name, field_name)
    let wrapper_addr = mir_alloc_local(st, "__union_field", "ptr")
    mir_emit_inst(st, mir_store(union_value, wrapper_addr))
    let result_addr = mir_alloc_local(st, "__union_field_result", field_typ)
    let members = mir_union_partial_field_members(st, union_name, field_name)
    let end_block = mir_new_block(st, "union.field.end")
    let case_blocks = new MirBlock[0]
    for i in 0:len(members) {
        case_blocks.push(mir_new_block(st, "union.field.case"))
    }
    let next_blocks = new MirBlock[0]
    for i in 0:len(members) - 1 {
        next_blocks.push(mir_new_block(st, "union.field.next"))
    }
    let check_block = st.current_block
    for ci in 0:len(members) {
        st.current_block = check_block
        let next_block = end_block
        if ci < len(members) - 1 {
            next_block = next_blocks[ci]
        }
        let wrapper_name = mir_new_value(st, "load")
        mir_emit_inst(st, mir_load(wrapper_name, "ptr", "ptr", wrapper_addr))
        let tag = mir_load_field(st, mir_value_operand("ptr", wrapper_name), union_name, "tag")
        let cond = mir_make_result_inst(st, "icmp.eq", "bool")
        cond.operands.push(tag)
        cond.operands.push(mir_const_int("i64", mir_union_tag(st, union_name, members[ci])))
        mir_emit_inst(st, cond)
        st.current_block.terminator = mir_condbr(mir_value_operand("bool", cond.result_name), case_blocks[ci].name, next_block.name)
        st.current_block.has_terminator = true
        if ci < len(members) - 1 {
            check_block = next_blocks[ci]
        }
    }
    for bi in 0:len(members) {
        st.current_block = case_blocks[bi]
        let wrapper_name = mir_new_value(st, "load")
        mir_emit_inst(st, mir_load(wrapper_name, "ptr", "ptr", wrapper_addr))
        let payload = mir_load_field(st, mir_value_operand("ptr", wrapper_name), union_name, "payload")
        let value = mir_load_promoted_field(st, payload, members[bi], field_name)
        mir_emit_inst(st, mir_store(value, result_addr))
        st.current_block.terminator = mir_br(end_block.name)
        st.current_block.has_terminator = true
    }
    st.current_block = end_block
    let result_name = mir_new_value(st, "load")
    mir_emit_inst(st, mir_load(result_name, field_typ, field_typ, result_addr))
    ret mir_value_flow(mir_value_operand(field_typ, result_name), st.current_block)
}

fun mir_store_union_partial_field(st: MirCodegenState, union_value: MirOperand, union_name: str, field_name: str, value: MirOperand): void {
    let wrapper_addr = mir_alloc_local(st, "__union_field", "ptr")
    mir_emit_inst(st, mir_store(union_value, wrapper_addr))
    let members = mir_union_partial_field_members(st, union_name, field_name)
    let end_block = mir_new_block(st, "union.field.end")
    let case_blocks = new MirBlock[0]
    for i in 0:len(members) {
        case_blocks.push(mir_new_block(st, "union.field.case"))
    }
    let next_blocks = new MirBlock[0]
    for i in 0:len(members) - 1 {
        next_blocks.push(mir_new_block(st, "union.field.next"))
    }
    let check_block = st.current_block
    for ci in 0:len(members) {
        st.current_block = check_block
        let next_block = end_block
        if ci < len(members) - 1 {
            next_block = next_blocks[ci]
        }
        let wrapper_name = mir_new_value(st, "load")
        mir_emit_inst(st, mir_load(wrapper_name, "ptr", "ptr", wrapper_addr))
        let tag = mir_load_field(st, mir_value_operand("ptr", wrapper_name), union_name, "tag")
        let cond = mir_make_result_inst(st, "icmp.eq", "bool")
        cond.operands.push(tag)
        cond.operands.push(mir_const_int("i64", mir_union_tag(st, union_name, members[ci])))
        mir_emit_inst(st, cond)
        st.current_block.terminator = mir_condbr(mir_value_operand("bool", cond.result_name), case_blocks[ci].name, next_block.name)
        st.current_block.has_terminator = true
        if ci < len(members) - 1 {
            check_block = next_blocks[ci]
        }
    }
    for bi in 0:len(members) {
        st.current_block = case_blocks[bi]
        let wrapper_name = mir_new_value(st, "load")
        mir_emit_inst(st, mir_load(wrapper_name, "ptr", "ptr", wrapper_addr))
        let payload = mir_load_field(st, mir_value_operand("ptr", wrapper_name), union_name, "payload")
        let addr = mir_field_addr(st, payload, members[bi], field_name)
        mir_emit_inst(st, mir_store(value, addr))
        st.current_block.terminator = mir_br(end_block.name)
        st.current_block.has_terminator = true
    }
    st.current_block = end_block
}

fun mir_load_union_common_embedded_field(st: MirCodegenState, union_value: MirOperand, union_name: str, field_name: str): MirValueFlow {
    let field_typ = mir_union_common_embedded_field_type(st, union_name, field_name)
    let wrapper_addr = mir_alloc_local(st, "__union_field", "ptr")
    mir_emit_inst(st, mir_store(union_value, wrapper_addr))
    let result_addr = mir_alloc_local(st, "__union_field_result", field_typ)
    let members = mir_union_member_names(st, union_name)
    let end_block = mir_new_block(st, "union.field.end")
    let case_blocks = new MirBlock[0]
    for i in 0:len(members) {
        case_blocks.push(mir_new_block(st, "union.field.case"))
    }
    let next_blocks = new MirBlock[0]
    for i in 0:len(members) - 1 {
        next_blocks.push(mir_new_block(st, "union.field.next"))
    }
    let check_block = st.current_block
    for ci in 0:len(members) {
        st.current_block = check_block
        let next_block = end_block
        if ci < len(members) - 1 {
            next_block = next_blocks[ci]
        }
        let wrapper_name = mir_new_value(st, "load")
        mir_emit_inst(st, mir_load(wrapper_name, "ptr", "ptr", wrapper_addr))
        let tag = mir_load_field(st, mir_value_operand("ptr", wrapper_name), union_name, "tag")
        let cond = mir_make_result_inst(st, "icmp.eq", "bool")
        cond.operands.push(tag)
        cond.operands.push(mir_const_int("i64", mir_union_tag(st, union_name, members[ci])))
        mir_emit_inst(st, cond)
        st.current_block.terminator = mir_condbr(mir_value_operand("bool", cond.result_name), case_blocks[ci].name, next_block.name)
        st.current_block.has_terminator = true
        if ci < len(members) - 1 {
            check_block = next_blocks[ci]
        }
    }
    if len(members) == 0 {
        st.current_block = check_block
        st.current_block.terminator = mir_br(end_block.name)
        st.current_block.has_terminator = true
    }
    for bi in 0:len(members) {
        st.current_block = case_blocks[bi]
        let wrapper_name = mir_new_value(st, "load")
        mir_emit_inst(st, mir_load(wrapper_name, "ptr", "ptr", wrapper_addr))
        let payload = mir_load_field(st, mir_value_operand("ptr", wrapper_name), union_name, "payload")
        let value = mir_load_promoted_field(st, payload, members[bi], field_name)
        mir_emit_inst(st, mir_store(value, result_addr))
        st.current_block.terminator = mir_br(end_block.name)
        st.current_block.has_terminator = true
    }
    st.current_block = end_block
    let result_name = mir_new_value(st, "load")
    mir_emit_inst(st, mir_load(result_name, field_typ, field_typ, result_addr))
    ret mir_value_flow(mir_value_operand(field_typ, result_name), st.current_block)
}

fun mir_alloc_struct(st: MirCodegenState, struct_name: str): MirOperand {
    let size_ops = new MirOperand[0]
    size_ops.push(mir_operand_null())
    size_ops.push(mir_const_int("i64", 1))
    let size_ptr = mir_make_gep(st, str_cat2("struct ", struct_name), size_ops)
    let size_i64 = mir_make_ptrtoint(st, size_ptr, "i64")
    let args = new MirOperand[0]
    args.push(size_i64)
    let call = mir_make_result_inst(st, "call", "ptr")
    call.typ = "ptr"
    call.callee = "__epx_alloc"
    call.operands = args
    mir_emit_inst(st, call)
    ret mir_value_operand("ptr", call.result_name)
}

fun mir_emit_struct_init(st: MirCodegenState, block: MirBlock, expr: AstNode): MirValueFlow {
    st.current_block = block
    let obj = mir_alloc_struct(st, expr.name)
    let i = 0
    for i < len(expr.fields) {
        let field = expr.fields[i]
        let value_flow = mir_emit_expr(st, st.current_block, field.value_expr)
        st.current_block = value_flow.block
        let addr = mir_field_addr(st, obj, expr.name, field.name)
        mir_emit_inst(st, mir_store(value_flow.value, addr))
        i = i + 1
    }
    ret mir_value_flow(obj, st.current_block)
}

fun mir_emit_union_init(st: MirCodegenState, block: MirBlock, expr: AstNode): MirValueFlow {
    st.current_block = block
    let payload_flow = mir_emit_expr(st, st.current_block, expr.expr)
    st.current_block = payload_flow.block
    let obj = mir_alloc_struct(st, expr.type_name)
    let tag_addr = mir_field_addr(st, obj, expr.type_name, "tag")
    mir_emit_inst(st, mir_store(mir_const_int("i64", mir_union_tag(st, expr.type_name, ast_resolved_type(expr.expr))), tag_addr))
    let payload_addr = mir_field_addr(st, obj, expr.type_name, "payload")
    mir_emit_inst(st, mir_store(payload_flow.value, payload_addr))
    ret mir_value_flow(obj, st.current_block)
}



fun mir_trunc_uint_value(st: MirCodegenState, value: MirOperand, mask: i64): MirOperand {
    let inst = mir_make_result_inst(st, "and", "i64")
    inst.operands.push(value)
    inst.operands.push(mir_const_int("i64", mask))
    mir_emit_inst(st, inst)
    ret mir_value_operand("i64", inst.result_name)
}

fun mir_trunc_i32_value(st: MirCodegenState, value: MirOperand): MirOperand {
    let shl_inst = mir_make_result_inst(st, "shl", "i64")
    shl_inst.operands.push(value)
    shl_inst.operands.push(mir_const_int("i64", 32))
    mir_emit_inst(st, shl_inst)
    let sar_inst = mir_make_result_inst(st, "sar", "i64")
    sar_inst.operands.push(mir_value_operand("i64", shl_inst.result_name))
    sar_inst.operands.push(mir_const_int("i64", 32))
    mir_emit_inst(st, sar_inst)
    ret mir_value_operand("i64", sar_inst.result_name)
}

fun mir_normalize_int_value(st: MirCodegenState, value: MirOperand, source_type: str): MirOperand {
    if source_type == "u8" {
        ret mir_trunc_uint_value(st, value, 255)
    }
    if source_type == "u32" {
        ret mir_trunc_uint_value(st, value, 4294967295)
    }
    if source_type == "i32" {
        ret mir_trunc_i32_value(st, value)
    }
    ret value
}

fun mir_string_label(st: MirCodegenState, value: str): str {
    let i = 0
    for i < len(st.string_values) {
        if st.string_values[i] == value {
            ret st.string_labels[i]
        }
        i = i + 1
    }
    st.string_counter = st.string_counter + 1
    let label = str_cat2("str.", str(st.string_counter))
    st.string_values.push(value)
    st.string_labels.push(label)
    st.program.globals.push(mir_global_string(label, value))
    ret label
}

fun mir_emit_str_conversion(st: MirCodegenState, block: MirBlock, expr: AstNode): MirValueFlow {
    st.current_block = block
    let typ = ast_resolved_type(expr)
    if typ == "str" {
        ret mir_emit_expr(st, st.current_block, expr)
    }
    let arg_flow = mir_emit_expr(st, st.current_block, expr)
    st.current_block = arg_flow.block
    let args = new MirOperand[0]
    args.push(arg_flow.value)
    if typ == "bool" {
        ret mir_value_flow(mir_emit_call_inst(st, "__ep_str_from_bool", "ptr", args), st.current_block)
    }
    if mir_is_u8_array_type(typ) {
        ret mir_value_flow(mir_emit_call_inst(st, "__ep_str_from_slice_u8", "ptr", args), st.current_block)
    }
    if typ == "u64" {
        ret mir_value_flow(mir_emit_call_inst(st, "__ep_str_from_u64", "ptr", args), st.current_block)
    }
    ret mir_value_flow(mir_emit_call_inst(st, "__ep_str_from_i64", "ptr", args), st.current_block)
}

fun mir_emit_fstring(st: MirCodegenState, block: MirBlock, expr: AstNode): MirValueFlow {
    st.current_block = block
    let out = mir_operand_null()
    let has_out = false
    let i = 0
    for i < len(expr.fields) {
        let part = expr.fields[i]
        let piece = mir_operand_null()
        if ast_kind(part) == "FStringText" {
            if len(part.value) > 0 {
                piece = mir_symbol_operand("ptr", mir_string_label(st, part.value))
            }
        } else {
            let piece_flow = mir_emit_str_conversion(st, st.current_block, part)
            st.current_block = piece_flow.block
            piece = piece_flow.value
        }
        if mir_operand_is_null(piece) == false {
            if has_out == false {
                out = piece
                has_out = true
            } else {
                let args = new MirOperand[0]
                args.push(out)
                args.push(piece)
                out = mir_emit_call_inst(st, "__ep_str_cat", "ptr", args)
            }
        }
        i = i + 1
    }
    if has_out == false {
        out = mir_symbol_operand("ptr", mir_string_label(st, ""))
    }
    ret mir_value_flow(out, st.current_block)
}

fun mir_array_elem_type(type_name: str): str {
    if len(type_name) >= 2 && type_name[len(type_name) - 2:len(type_name)] == "[]" {
        ret type_name[0:len(type_name) - 2]
    }
    ret ""
}

fun mir_is_i64_array_elem_type(elem_type: str): bool {
    ret elem_type == "i64" || elem_type == "i32" || elem_type == "u64" || elem_type == "u32" || elem_type == "bool"
}

fun mir_is_i64_array_type(type_name: str): bool {
    ret mir_is_i64_array_elem_type(mir_array_elem_type(type_name))
}

fun mir_is_array_type(type_name: str): bool {
    ret mir_array_elem_type(type_name) != ""
}

fun mir_is_u8_array_elem_type(elem_type: str): bool {
    ret elem_type == "u8"
}

fun mir_is_u8_array_type(type_name: str): bool {
    ret mir_is_u8_array_elem_type(mir_array_elem_type(type_name))
}

fun mir_is_struct_name(st: MirCodegenState, name: str): bool {
    let i = 0
    for i < len(st.struct_names) {
        if st.struct_names[i] == name {
            ret true
        }
        i = i + 1
    }
    ret false
}

fun mir_is_ptr_array_elem_type(st: MirCodegenState, elem_type: str): bool {
    if elem_type == "str" {
        ret true
    }
    ret mir_is_struct_name(st, elem_type)
}

fun mir_is_ptr_array_type(st: MirCodegenState, type_name: str): bool {
    ret mir_is_ptr_array_elem_type(st, mir_array_elem_type(type_name))
}

fun mir_slice_struct_name(st: MirCodegenState, type_name: str): str {
    if mir_is_u8_array_type(type_name) {
        ret "_slice_u8"
    }
    if mir_is_i64_array_type(type_name) {
        ret "_slice_i64"
    }
    let elem = mir_array_elem_type(type_name)
    if elem == "str" {
        ret "_slice_str"
    }
    if elem != "" && mir_is_struct_name(st, elem) {
        ret str_cat2("_slice_", elem)
    }
    ret ""
}

fun mir_map_suffix(type_name: str): str {
    if type_name == "map[str]i64" {
        ret "i64"
    }
    if type_name == "map[str]bool" {
        ret "bool"
    }
    if type_name == "map[str]str" {
        ret "str"
    }
    ret ""
}

fun mir_map_value_type(type_name: str): str {
    let suffix = mir_map_suffix(type_name)
    if suffix == "i64" {
        ret "i64"
    }
    if suffix == "bool" {
        ret "bool"
    }
    if suffix == "str" {
        ret "ptr"
    }
    ret ""
}

fun mir_map_helper(type_name: str, op: str): str {
    let suffix = mir_map_suffix(type_name)
    if suffix == "" {
        ret ""
    }
    ret str_cat2(str_cat2("__ep_map_str_", suffix), str_cat2("_", op))
}

fun mir_dummy_return(st: MirCodegenState): MirTerminator {
    if st.current_fn.return_type == "void" {
        ret mir_ret_void()
    }
    ret mir_ret_value(mir_const_int(st.current_fn.return_type, 0))
}

fun mir_emit_print_text(st: MirCodegenState, text: str): void {
    let args = new MirOperand[0]
    args.push(mir_symbol_operand("ptr", mir_string_label(st, text)))
    mir_emit_call_inst(st, "__ep_print_str", "void", args)
}

fun mir_emit_print_expr(st: MirCodegenState, expr: AstNode): void {
    let value_flow = mir_emit_str_conversion(st, st.current_block, expr)
    st.current_block = value_flow.block
    let args = new MirOperand[0]
    args.push(value_flow.value)
    mir_emit_call_inst(st, "__ep_print_str", "void", args)
}

fun mir_emit_print_newline(st: MirCodegenState): void {
    let args = new MirOperand[0]
    mir_emit_call_inst(st, "__ep_print_newline", "void", args)
}

fun mir_emit_exit_current_block(st: MirCodegenState, code: i64): void {
    let args = new MirOperand[0]
    args.push(mir_const_int("i64", code))
    mir_emit_inst(st, mir_call(str_cat2("Exit", "Process"), "void", args))
}

fun mir_emit_slice(st: MirCodegenState, block: MirBlock, expr: AstNode): MirValueFlow {
    st.current_block = block
    let base_type = ast_resolved_type(expr.base)
    let base_flow = mir_emit_expr(st, st.current_block, expr.base)
    st.current_block = base_flow.block
    let start_flow = mir_emit_expr(st, st.current_block, expr.start)
    st.current_block = start_flow.block
    let end_flow = mir_emit_expr(st, st.current_block, expr.end)
    st.current_block = end_flow.block
    let args = new MirOperand[0]
    args.push(base_flow.value)
    args.push(start_flow.value)
    args.push(end_flow.value)
    if base_type == "str" {
        ret mir_value_flow(mir_emit_call_inst(st, "__ep_str_slice", "ptr", args), st.current_block)
    }
    if mir_is_u8_array_type(base_type) {
        ret mir_value_flow(mir_emit_call_inst(st, "__ep_slice_u8_slice", "ptr", args), st.current_block)
    }
    ast_to_mir_die("slice only supports str and u8[]")
    ret mir_value_flow(mir_operand_null(), st.current_block)
}

fun mir_emit_map_init(st: MirCodegenState, block: MirBlock, expr: AstNode): MirValueFlow {
    st.current_block = block
    let new_helper = mir_map_helper(ast_resolved_type(expr), "new")
    let set_helper = mir_map_helper(ast_resolved_type(expr), "set")
    if new_helper == "" || set_helper == "" {
        ast_to_mir_die(f"unsupported map init target: {expr.type_name}")
    }
    let args0 = new MirOperand[0]
    let map_value = mir_emit_call_inst(st, new_helper, "ptr", args0)
    let i = 0
    for i < len(expr.map_keys) {
        let key_flow = mir_emit_expr(st, st.current_block, expr.map_keys[i])
        st.current_block = key_flow.block
        let value_flow = mir_emit_expr(st, st.current_block, expr.map_values[i])
        st.current_block = value_flow.block
        let args = new MirOperand[0]
        args.push(map_value)
        args.push(key_flow.value)
        args.push(value_flow.value)
        mir_emit_call_inst(st, set_helper, "void", args)
        i = i + 1
    }
    ret mir_value_flow(map_value, st.current_block)
}

fun mir_emit_empty_array(st: MirCodegenState, elem_type: str, count: MirOperand): MirOperand {
    let args = new MirOperand[0]
    if mir_is_u8_array_elem_type(elem_type) {
        args.push(count)
        args.push(count)
        ret mir_emit_call_inst(st, "__ep_slice_u8_alloc", "ptr", args)
    }
    args.push(count)
    if mir_is_i64_array_elem_type(elem_type) {
        ret mir_emit_call_inst(st, "__ep_slice_i64_new", "ptr", args)
    }
    if mir_is_ptr_array_elem_type(st, elem_type) {
        ret mir_emit_call_inst(st, "__ep_slice_ptr_new", "ptr", args)
    }
    ast_to_mir_die(f"unsupported array element type: {elem_type}")
    ret mir_operand_null()
}

fun mir_emit_array_literal_storage(st: MirCodegenState, elem_type: str, count: MirOperand): MirOperand {
    let args = new MirOperand[0]
    if mir_is_u8_array_elem_type(elem_type) {
        args.push(count)
        args.push(count)
        ret mir_emit_call_inst(st, "__ep_slice_u8_alloc", "ptr", args)
    }
    args.push(count)
    if mir_is_i64_array_elem_type(elem_type) {
        ret mir_emit_call_inst(st, "__ep_slice_i64_new", "ptr", args)
    }
    if mir_is_ptr_array_elem_type(st, elem_type) {
        ret mir_emit_call_inst(st, "__ep_slice_ptr_new", "ptr", args)
    }
    ast_to_mir_die(f"unsupported array literal element type: {elem_type}")
    ret mir_operand_null()
}

fun mir_emit_new_array(st: MirCodegenState, block: MirBlock, expr: AstNode): MirValueFlow {
    st.current_block = block
    let count = mir_const_int("i64", 0)
    if ast_kind(expr.count) != "" {
        let count_flow = mir_emit_expr(st, st.current_block, expr.count)
        st.current_block = count_flow.block
        count = count_flow.value
    }
    let arr = mir_emit_empty_array(st, expr.type_name, count)
    ret mir_value_flow(arr, st.current_block)
}

fun mir_emit_array_literal(st: MirCodegenState, block: MirBlock, expr: AstNode): MirValueFlow {
    st.current_block = block
    let count = mir_const_int("i64", len(expr.args))
    let arr = mir_emit_array_literal_storage(st, expr.type_name, count)
    let i = 0
    for i < len(expr.args) {
        let args = new MirOperand[0]
        args.push(arr)
        if mir_is_u8_array_elem_type(expr.type_name) {
            args.push(mir_const_int("i64", i))
            let elem_flow = mir_emit_expr(st, st.current_block, expr.args[i])
            st.current_block = elem_flow.block
            args.push(elem_flow.value)
            mir_emit_call_inst(st, "__ep_slice_u8_set", "void", args)
        } else {
            args.push(mir_const_int("i64", i))
            let elem_flow = mir_emit_expr(st, st.current_block, expr.args[i])
            st.current_block = elem_flow.block
            args.push(elem_flow.value)
            if mir_is_ptr_array_elem_type(st, expr.type_name) {
                mir_emit_call_inst(st, "__ep_slice_ptr_set", "void", args)
            } else {
                mir_emit_call_inst(st, "__ep_slice_i64_set", "void", args)
            }
        }
        i = i + 1
    }
    ret mir_value_flow(arr, st.current_block)
}

fun mir_os_call_return_type(dll: str, name: str): str {
    if dll == "kernel32" {
        if name == "ExitProcess" { ret "void" }
        if name == "Sleep" { ret "void" }
        if name == "GetTickCount64" { ret "i64" }
        if name == "lstrlenA" { ret "i64" }
        if name == "lstrcmpA" { ret "i64" }
        if name == "GetStdHandle" { ret "i64" }
        if name == "GetProcessHeap" { ret "i64" }
        if name == "HeapAlloc" { ret "i64" }
        if name == "CreateFileA" { ret "i64" }
        if name == "GetFileSize" { ret "i64" }
        if name == "ReadFile" { ret "i64" }
        if name == "WriteFile" { ret "i64" }
        if name == "CloseHandle" { ret "i64" }
        if name == "CreateProcessA" { ret "i64" }
        if name == "WaitForSingleObject" { ret "i64" }
        if name == "GetExitCodeProcess" { ret "i64" }
        if name == "GetCommandLineA" { ret "i64" }
    }
    if dll == "user32" {
        if name == "MessageBoxA" { ret "i64" }
    }
    ast_to_mir_die(f"unsupported os call: os.{dll}.{name}")
    ret "i64"
}


fun mir_emit_os_call(st: MirCodegenState, expr: AstCall): MirValueFlow {
    let args = new MirOperand[0]
    let i = 0
    for i < len(expr.args) {
        let arg_flow = mir_emit_expr(st, st.current_block, expr.args[i])
        st.current_block = arg_flow.block
        args.push(arg_flow.value)
        i = i + 1
    }
    let ret_type = mir_os_call_return_type(expr.dll, expr.name)
    ret mir_value_flow(mir_emit_call_inst(st, expr.name, ret_type, args), st.current_block)
}


fun mir_emit_short_circuit(st: MirCodegenState, block: MirBlock, expr: AstNode): MirValueFlow {
    st.current_block = block
    let addr_name = mir_new_value(st, "logic.addr")
    let result_addr = mir_value_operand("ptr", addr_name)
    mir_emit_inst(st, mir_alloca(addr_name, "bool"))

    let left_flow = mir_emit_expr(st, st.current_block, expr.left)
    st.current_block = left_flow.block
    let rhs_block = mir_new_block(st, "logic.rhs")
    let short_block = mir_new_block(st, "logic.short")
    let end_block = mir_new_block(st, "logic.end")
    let short_value = mir_const_bool(false)
    if expr.op == "&&" {
        st.current_block.terminator = mir_condbr(left_flow.value, rhs_block.name, short_block.name)
        short_value = mir_const_bool(false)
    } else {
        st.current_block.terminator = mir_condbr(left_flow.value, short_block.name, rhs_block.name)
        short_value = mir_const_bool(true)
    }
    st.current_block.has_terminator = true

    st.current_block = short_block
    mir_emit_inst(st, mir_store(short_value, result_addr))
    st.current_block.terminator = mir_br(end_block.name)
    st.current_block.has_terminator = true

    let right_flow = mir_emit_expr(st, rhs_block, expr.right)
    st.current_block = right_flow.block
    mir_emit_inst(st, mir_store(right_flow.value, result_addr))
    st.current_block.terminator = mir_br(end_block.name)
    st.current_block.has_terminator = true

    st.current_block = end_block
    let result_name = mir_new_value(st, "load")
    mir_emit_inst(st, mir_load(result_name, "bool", "bool", result_addr))
    ret mir_value_flow(mir_value_operand("bool", result_name), st.current_block)
}

fun mir_emit_subscript(st: MirCodegenState, block: MirBlock, expr: AstNode): MirValueFlow {
    st.current_block = block
    let base_type = ast_resolved_type(expr.base)
    let base_flow = mir_emit_expr(st, st.current_block, expr.base)
    st.current_block = base_flow.block
    let index_flow = mir_emit_expr(st, st.current_block, expr.index)
    st.current_block = index_flow.block
    let args = new MirOperand[0]
    args.push(base_flow.value)
    args.push(index_flow.value)
    let map_value_type = mir_map_value_type(base_type)
    if map_value_type != "" {
        ret mir_value_flow(mir_emit_call_inst(st, mir_map_helper(base_type, "get"), map_value_type, args), st.current_block)
    }
    if mir_is_u8_array_type(base_type) {
        ret mir_value_flow(mir_emit_call_inst(st, "__ep_slice_u8_get", "i64", args), st.current_block)
    }
    if mir_is_i64_array_type(base_type) {
        ret mir_value_flow(mir_emit_call_inst(st, "__ep_slice_i64_get", "i64", args), st.current_block)
    }
    if mir_is_ptr_array_type(st, base_type) {
        ret mir_value_flow(mir_emit_call_inst(st, "__ep_slice_ptr_get", "ptr", args), st.current_block)
    }
    ast_to_mir_die(f"unsupported subscript base type {base_type}")
    ret mir_value_flow(mir_const_int("i64", 0), st.current_block)
}


fun mir_emit_dot_call(st: MirCodegenState, block: MirBlock, expr: AstDotCall): MirValueFlow {
    st.current_block = block
    match expr.object {
        AstFieldAccess field: {
            match field.object {
                AstVar receiver: {
                    if receiver.name == "os" {
                        let call = new AstCall { AstMeta: expr.AstMeta, name: expr.name, args: expr.args, type_name: "os", dll: field.name }
                        ret mir_emit_os_call(st, call)
                    }
                }
                _: {}
            }
        }
        _: {}
    }
    let receiver_type = ast_resolved_type(expr.object)
    if mir_is_array_type(receiver_type) {
        if expr.name == "push" {
            let dst_flow = mir_emit_expr(st, st.current_block, expr.object)
            st.current_block = dst_flow.block
            let value_flow = mir_emit_expr(st, st.current_block, expr.args[0])
            st.current_block = value_flow.block
            let args = new MirOperand[0]
            args.push(dst_flow.value)
            args.push(value_flow.value)
            if mir_is_u8_array_type(receiver_type) {
                mir_emit_call_inst(st, "__ep_slice_u8_push", "void", args)
            } else {
                if mir_is_ptr_array_type(st, receiver_type) {
                    mir_emit_call_inst(st, "__ep_slice_ptr_push", "void", args)
                } else {
                    mir_emit_call_inst(st, "__ep_slice_i64_push", "void", args)
                }
            }
            ret mir_value_flow(mir_const_int("i64", 0), st.current_block)
        }
        if expr.name == "extend" {
            let dst_flow = mir_emit_expr(st, st.current_block, expr.object)
            st.current_block = dst_flow.block
            let src_flow = mir_emit_expr(st, st.current_block, expr.args[0])
            st.current_block = src_flow.block
            let args = new MirOperand[0]
            args.push(dst_flow.value)
            args.push(src_flow.value)
            mir_emit_call_inst(st, "__ep_slice_u8_extend", "void", args)
            ret mir_value_flow(mir_const_int("i64", 0), st.current_block)
        }
    }
    if mir_map_value_type(receiver_type) != "" {
        if expr.name == "has" || expr.name == "del" {
            let helper = mir_map_helper(receiver_type, expr.name)
            if helper == "" {
                ast_to_mir_die(f"{expr.name} expects map")
            }
            let base_flow = mir_emit_expr(st, st.current_block, expr.object)
            st.current_block = base_flow.block
            let key_flow = mir_emit_expr(st, st.current_block, expr.args[0])
            st.current_block = key_flow.block
            let args = new MirOperand[0]
            args.push(base_flow.value)
            args.push(key_flow.value)
            ret mir_value_flow(mir_emit_call_inst(st, helper, "bool", args), st.current_block)
        }
    }
    let method_symbol = str_cat2(str_cat2(receiver_type, "__"), expr.name)
    for mi in 0:len(st.func_names) {
        if st.func_names[mi] == method_symbol {
            let args = new MirOperand[0]
            let receiver_flow = mir_emit_expr(st, st.current_block, expr.object)
            st.current_block = receiver_flow.block
            args.push(receiver_flow.value)
            for i in 0:len(expr.args) {
                let arg_flow = mir_emit_expr(st, st.current_block, expr.args[i])
                st.current_block = arg_flow.block
                args.push(arg_flow.value)
            }
            ret mir_value_flow(mir_emit_call_inst(st, method_symbol, st.func_return_types[mi], args), st.current_block)
        }
    }
    ast_to_mir_die(f"unsupported dot call {expr.name}")
    ret mir_value_flow(mir_const_int("i64", 0), st.current_block)
}



fun mir_emit_expr(st: MirCodegenState, block: MirBlock, expr: AstNode): MirValueFlow {
    st.current_block = block
    match expr {
        AstLiteral n: {
            ret mir_value_flow(mir_const_int("i64", sema_parse_i64(n.value)), st.current_block)
        }
        AstChar n: {
            ret mir_value_flow(mir_const_int("i64", sema_parse_i64(n.value)), st.current_block)
        }
        AstBool n: {
            ret mir_value_flow(mir_const_bool(n.value == "true" || n.value == "1"), st.current_block)
        }
        AstString n: {
            ret mir_value_flow(mir_symbol_operand("ptr", mir_string_label(st, n.value)), st.current_block)
        }
        AstFString n: {
            ret mir_emit_fstring(st, st.current_block, expr)
        }
        AstVar n: {
            if n.name == "argv" {
                ret mir_value_flow(mir_symbol_operand("ptr", "argv"), st.current_block)
            }
            let gidx = mir_global_index(st, n.name)
            if gidx >= 0 {
                let result_name = mir_new_value(st, "load")
                let addr = mir_symbol_operand("ptr", mir_global_label(n.name))
                mir_emit_inst(st, mir_load(result_name, st.global_types[gidx], st.global_types[gidx], addr))
                ret mir_value_flow(mir_value_operand(st.global_types[gidx], result_name), st.current_block)
            }
            let idx = mir_local_index(st, n.name)
            let result_name = mir_new_value(st, "load")
            let addr = mir_value_operand("ptr", st.local_addr_names[idx])
            mir_emit_inst(st, mir_load(result_name, st.local_types[idx], st.local_types[idx], addr))
            ret mir_value_flow(mir_value_operand(st.local_types[idx], result_name), st.current_block)
        }
        AstUnary n: {
            let inner_flow = mir_emit_expr(st, st.current_block, n.expr)
            st.current_block = inner_flow.block
            if n.op == "-" {
                let inst = mir_make_result_inst(st, "sub", "i64")
                inst.operands.push(mir_const_int("i64", 0))
                inst.operands.push(inner_flow.value)
                mir_emit_inst(st, inst)
                ret mir_value_flow(mir_value_operand("i64", inst.result_name), st.current_block)
            }
            if n.op == "!" {
                let inst = mir_make_result_inst(st, "not", "bool")
                inst.operands.push(inner_flow.value)
                mir_emit_inst(st, inst)
                ret mir_value_flow(mir_value_operand("bool", inst.result_name), st.current_block)
            }
            ast_to_mir_die(f"unsupported unary op {n.op}")
        }
        AstBinary n: {
            if n.op == "&&" || n.op == "||" {
                ret mir_emit_short_circuit(st, st.current_block, expr)
            }
            let left_flow = mir_emit_expr(st, st.current_block, n.left)
            st.current_block = left_flow.block
            let right_flow = mir_emit_expr(st, st.current_block, n.right)
            st.current_block = right_flow.block
            let left_type = ast_resolved_type(n.left)
            let right_type = ast_resolved_type(n.right)
            if left_type == "str" && right_type == "str" && (n.op == "==" || n.op == "!=") {
                let args = new MirOperand[0]
                args.push(left_flow.value)
                args.push(right_flow.value)
                let eq = mir_emit_call_inst(st, "__ep_str_eq", "bool", args)
                if n.op == "!=" {
                    let not_inst = mir_make_result_inst(st, "not", "bool")
                    not_inst.operands.push(eq)
                    mir_emit_inst(st, not_inst)
                    ret mir_value_flow(mir_value_operand("bool", not_inst.result_name), st.current_block)
                }
                ret mir_value_flow(eq, st.current_block)
            }
            let op = mir_binary_op(n.op, left_type)
            let result_type = mir_op_result_type(op)
            if n.op == "<<" || n.op == ">>" || n.op == ">>>" {
                mir_emit_shift_count_check(st, right_flow.value, left_type, n.AstMeta.line)
            }
            let inst = mir_make_result_inst(st, op, result_type)
            inst.operands.push(left_flow.value)
            inst.operands.push(right_flow.value)
            mir_emit_inst(st, inst)
            ret mir_value_flow(mir_normalize_int_value(st, mir_value_operand(result_type, inst.result_name), n.AstMeta.resolved_type), st.current_block)
        }
        AstNewArray n: {
            ret mir_emit_new_array(st, st.current_block, expr)
        }
        AstArrayLiteral n: {
            ret mir_emit_array_literal(st, st.current_block, expr)
        }
        AstSubscript n: {
            ret mir_emit_subscript(st, st.current_block, expr)
        }
        AstSlice n: {
            ret mir_emit_slice(st, st.current_block, expr)
        }
        AstMapInit n: {
            ret mir_emit_map_init(st, st.current_block, expr)
        }
        AstStructInit n: {
            ret mir_emit_struct_init(st, st.current_block, expr)
        }
        AstUnionInit n: {
            ret mir_emit_union_init(st, st.current_block, expr)
        }
        AstFieldHas n: {
            let base_type = ast_resolved_type(n.object)
            let base_flow = mir_emit_expr(st, st.current_block, n.object)
            st.current_block = base_flow.block
            if mir_is_union_name(st, base_type) == false {
                ast_to_mir_die("field existence guard base must be union")
            }
            ret mir_value_flow(mir_emit_union_field_has(st, base_flow.value, base_type, n.name), st.current_block)
        }
        AstFieldAccess n: {
            let base_type = ast_resolved_type(n.object)
            let base_flow = mir_emit_expr(st, st.current_block, n.object)
            st.current_block = base_flow.block
            if mir_is_union_name(st, base_type) {
                if mir_union_has_common_embedded_field(st, base_type, n.name) {
                    ret mir_load_union_common_embedded_field(st, base_flow.value, base_type, n.name)
                }
                ret mir_load_union_partial_field(st, base_flow.value, base_type, n.name)
            }
            let struct_name = mir_layout_struct_name(st, base_type)
            if struct_name == "" {
                ast_to_mir_die("field access base must be struct")
            }
            ret mir_value_flow(mir_load_promoted_field(st, base_flow.value, struct_name, n.name), st.current_block)
        }
        AstDotCall n: {
            ret mir_emit_dot_call(st, block, n)
        }
        AstCall n: {
            if n.type_name == "os" {
                ret mir_emit_os_call(st, n)
            }
            if n.type_name != "" {
                ast_to_mir_die(f"unsupported namespaced call: {n.type_name}.{n.name}")
            }
            if n.name == "println" {
                if len(n.args) == 1 {
                    let args = new MirOperand[0]
                    let arg_flow = mir_emit_expr(st, st.current_block, n.args[0])
                    st.current_block = arg_flow.block
                    args.push(arg_flow.value)
                    mir_emit_call_inst(st, "__ep_print_str", "void", args)
                }
                let nl_args = new MirOperand[0]
                mir_emit_call_inst(st, "__ep_print_newline", "void", nl_args)
                ret mir_value_flow(mir_const_int("i64", 0), st.current_block)
            }
            if n.name == "print" {
                let args = new MirOperand[0]
                let arg_flow = mir_emit_expr(st, st.current_block, n.args[0])
                st.current_block = arg_flow.block
                args.push(arg_flow.value)
                mir_emit_call_inst(st, "__ep_print_str", "void", args)
                ret mir_value_flow(mir_const_int("i64", 0), st.current_block)
            }
            if n.name == "len" || n.name == "cap" {
                let base_type = ast_resolved_type(n.args[0])
                let base_flow = mir_emit_expr(st, st.current_block, n.args[0])
                st.current_block = base_flow.block
                let struct_name = mir_layout_struct_name(st, base_type)
                if struct_name == "" {
                    ast_to_mir_die("len/cap expects aggregate pointer")
                }
                ret mir_value_flow(mir_load_promoted_field(st, base_flow.value, struct_name, n.name), st.current_block)
            }
            if n.name == "cstr" {
                let args = new MirOperand[0]
                let arg_flow = mir_emit_expr(st, st.current_block, n.args[0])
                st.current_block = arg_flow.block
                args.push(arg_flow.value)
                args.push(mir_const_int("i64", n.AstMeta.line))
                ret mir_value_flow(mir_emit_call_inst(st, "__ep_cstr", "i64", args), st.current_block)
            }
            if n.name == "i64" || n.name == "u64" || n.name == "bool" {
                ret mir_emit_expr(st, st.current_block, n.args[0])
            }
            if n.name == "u8" {
                let arg_flow = mir_emit_expr(st, st.current_block, n.args[0])
                st.current_block = arg_flow.block
                ret mir_value_flow(mir_trunc_uint_value(st, arg_flow.value, 255), st.current_block)
            }
            if n.name == "u32" {
                let arg_flow = mir_emit_expr(st, st.current_block, n.args[0])
                st.current_block = arg_flow.block
                ret mir_value_flow(mir_trunc_uint_value(st, arg_flow.value, 4294967295), st.current_block)
            }
            if n.name == "i32" {
                let arg_flow = mir_emit_expr(st, st.current_block, n.args[0])
                st.current_block = arg_flow.block
                ret mir_value_flow(mir_trunc_i32_value(st, arg_flow.value), st.current_block)
            }
            if n.name == "str" {
                ret mir_emit_str_conversion(st, st.current_block, n.args[0])
            }
            if n.name == "bytes" {
                let args = new MirOperand[0]
                let arg_flow = mir_emit_expr(st, st.current_block, n.args[0])
                st.current_block = arg_flow.block
                args.push(arg_flow.value)
                ret mir_value_flow(mir_emit_call_inst(st, "__ep_slice_u8_from_str", "ptr", args), st.current_block)
            }
            if n.name == "read_file" {
                let args = new MirOperand[0]
                let arg_flow = mir_emit_expr(st, st.current_block, n.args[0])
                st.current_block = arg_flow.block
                args.push(arg_flow.value)
                args.push(mir_const_int("i64", n.AstMeta.line))
                ret mir_value_flow(mir_emit_call_inst(st, "__ep_read_file", "ptr", args), st.current_block)
            }
            if n.name == "write_file" {
                let args = new MirOperand[0]
                let i = 0
                for i < len(n.args) {
                    let arg_flow = mir_emit_expr(st, st.current_block, n.args[i])
                    st.current_block = arg_flow.block
                    args.push(arg_flow.value)
                    i = i + 1
                }
                args.push(mir_const_int("i64", n.AstMeta.line))
                ret mir_value_flow(mir_emit_call_inst(st, "__ep_write_file", "i64", args), st.current_block)
            }
            if n.name == "system" {
                let args = new MirOperand[0]
                let arg_flow = mir_emit_expr(st, st.current_block, n.args[0])
                st.current_block = arg_flow.block
                args.push(arg_flow.value)
                args.push(mir_const_int("i64", n.AstMeta.line))
                ret mir_value_flow(mir_emit_call_inst(st, "__ep_system_cmd", "i64", args), st.current_block)
            }
            if n.name == "exit" {
                let args = new MirOperand[0]
                let code_flow = mir_emit_expr(st, st.current_block, n.args[0])
                st.current_block = code_flow.block
                args.push(code_flow.value)
                mir_emit_inst(st, mir_call("ExitProcess", "void", args))
                ret mir_value_flow(mir_const_int("i64", 0), st.current_block)
            }
            if n.name == "push" {
                let base_type = ast_resolved_type(n.args[0])
                let dst_flow = mir_emit_expr(st, st.current_block, n.args[0])
                st.current_block = dst_flow.block
                let args = new MirOperand[0]
                args.push(dst_flow.value)
                let value_flow = mir_emit_expr(st, st.current_block, n.args[1])
                st.current_block = value_flow.block
                args.push(value_flow.value)
                if mir_is_u8_array_type(base_type) {
                    mir_emit_call_inst(st, "__ep_slice_u8_push", "void", args)
                } else {
                    if mir_is_ptr_array_type(st, base_type) {
                        mir_emit_call_inst(st, "__ep_slice_ptr_push", "void", args)
                    } else {
                        mir_emit_call_inst(st, "__ep_slice_i64_push", "void", args)
                    }
                }
                ret mir_value_flow(mir_const_int("i64", 0), st.current_block)
            }
            if n.name == "extend" {
                let dst_flow = mir_emit_expr(st, st.current_block, n.args[0])
                st.current_block = dst_flow.block
                let src_flow = mir_emit_expr(st, st.current_block, n.args[1])
                st.current_block = src_flow.block
                let args = new MirOperand[0]
                args.push(dst_flow.value)
                args.push(src_flow.value)
                mir_emit_call_inst(st, "__ep_slice_u8_extend", "void", args)
                ret mir_value_flow(mir_const_int("i64", 0), st.current_block)
            }
            if n.name == "map_has" || n.name == "map_del" {
                let map_type = ast_resolved_type(n.args[0])
                let helper = mir_map_helper(map_type, "has")
                if n.name == "map_del" {
                    helper = mir_map_helper(map_type, "del")
                }
                if helper == "" {
                    ast_to_mir_die(f"{n.name} expects map")
                }
                let base_flow = mir_emit_expr(st, st.current_block, n.args[0])
                st.current_block = base_flow.block
                let key_flow = mir_emit_expr(st, st.current_block, n.args[1])
                st.current_block = key_flow.block
                let args = new MirOperand[0]
                args.push(base_flow.value)
                args.push(key_flow.value)
                ret mir_value_flow(mir_emit_call_inst(st, helper, "bool", args), st.current_block)
            }
            let ret_type = mir_func_return_type(st, n.name)
            let args = new MirOperand[0]
            let i = 0
            for i < len(n.args) {
                let arg_flow = mir_emit_expr(st, st.current_block, n.args[i])
                st.current_block = arg_flow.block
                args.push(arg_flow.value)
                i = i + 1
            }
            ret mir_value_flow(mir_emit_call_inst(st, n.name, ret_type, args), st.current_block)
        }
        _: {
            ast_to_mir_die(f"unsupported expr {ast_kind(expr)}")
        }
    }
    ret mir_value_flow(mir_const_int("i64", 0), st.current_block)
}


fun mir_emit_assert(st: MirCodegenState, block: MirBlock, stmt: AstNode): MirBlockFlow {
    st.current_block = block
    let cond_flow = mir_emit_expr(st, st.current_block, stmt.expr)
    st.current_block = cond_flow.block
    let ok_block = mir_new_block(st, "assert.ok")
    let fail_block = mir_new_block(st, "assert.fail")
    st.current_block.terminator = mir_condbr(cond_flow.value, ok_block.name, fail_block.name)
    st.current_block.has_terminator = true

    st.current_block = fail_block
    mir_emit_print_text(st, str_cat2(str_cat2("assert line ", str(ast_line(stmt))), ": "))
    if ast_kind(stmt.value_expr) == "" {
        mir_emit_print_text(st, "assertion failed")
    } else {
        mir_emit_print_expr(st, stmt.value_expr)
    }
    mir_emit_print_newline(st)
    mir_emit_exit_current_block(st, 1)
    st.current_block.terminator = mir_dummy_return(st)
    st.current_block.has_terminator = true
    st.current_block = ok_block
    ret mir_reachable_flow(ok_block)
}

fun mir_emit_panic(st: MirCodegenState, block: MirBlock, stmt: AstNode): MirBlockFlow {
    st.current_block = block
    mir_emit_print_text(st, str_cat2(str_cat2("panic line ", str(ast_line(stmt))), ": "))
    mir_emit_print_expr(st, stmt.expr)
    mir_emit_print_newline(st)
    mir_emit_exit_current_block(st, 1)
    st.current_block.terminator = mir_dummy_return(st)
    st.current_block.has_terminator = true
    ret mir_unreachable_flow()
}

fun mir_truncate_locals(st: MirCodegenState, count: i64): void {
    let names = new str[0]
    let addrs = new str[0]
    let types = new str[0]
    for i in 0:count {
        names.push(st.local_names[i])
        addrs.push(st.local_addr_names[i])
        types.push(st.local_types[i])
    }
    st.local_names = names
    st.local_addr_names = addrs
    st.local_types = types
}

fun mir_emit_union_match(st: MirCodegenState, block: MirBlock, stmt: AstNode): MirBlockFlow {
    st.current_block = block
    let union_name = ast_resolved_type(stmt.expr)
    let scrutinee_flow = mir_emit_expr(st, st.current_block, stmt.expr)
    st.current_block = scrutinee_flow.block
    let match_name = str_cat2("__match", str(st.value_counter))
    let match_addr = mir_alloc_local(st, match_name, "ptr")
    mir_emit_inst(st, mir_store(scrutinee_flow.value, match_addr))

    let end_block = mir_new_block(st, "match.end")
    let case_blocks = new MirBlock[0]
    for i in 0:len(stmt.fields) {
        case_blocks.push(mir_new_block(st, "match.case"))
    }
    let has_else = ast_kind(stmt.else_block) != ""
    let else_block = end_block
    if has_else {
        else_block = mir_new_block(st, "match.else")
    }
    let next_blocks = new MirBlock[0]
    for i in 0:len(stmt.fields) - 1 {
        next_blocks.push(mir_new_block(st, "match.next"))
    }

    let check_block = st.current_block
    for ci in 0:len(stmt.fields) {
        st.current_block = check_block
        let next_block = else_block
        if ci < len(stmt.fields) - 1 {
            next_block = next_blocks[ci]
        }
        let wrapper_name = mir_new_value(st, "load")
        mir_emit_inst(st, mir_load(wrapper_name, "ptr", "ptr", match_addr))
        let tag = mir_load_field(st, mir_value_operand("ptr", wrapper_name), union_name, "tag")
        let cond = mir_make_result_inst(st, "icmp.eq", "bool")
        cond.operands.push(tag)
        cond.operands.push(mir_const_int("i64", mir_union_tag(st, union_name, stmt.fields[ci].variant_name)))
        mir_emit_inst(st, cond)
        st.current_block.terminator = mir_condbr(mir_value_operand("bool", cond.result_name), case_blocks[ci].name, next_block.name)
        st.current_block.has_terminator = true
        if ci < len(stmt.fields) - 1 {
            check_block = next_blocks[ci]
        }
    }
    if len(stmt.fields) == 0 {
        st.current_block = check_block
        st.current_block.terminator = mir_br(else_block.name)
        st.current_block.has_terminator = true
    }

    for bi in 0:len(stmt.fields) {
        st.current_block = case_blocks[bi]
        let local_count = len(st.local_names)
        let wrapper_name = mir_new_value(st, "load")
        mir_emit_inst(st, mir_load(wrapper_name, "ptr", "ptr", match_addr))
        let payload = mir_load_field(st, mir_value_operand("ptr", wrapper_name), union_name, "payload")
        let bind_addr = mir_alloc_local(st, stmt.fields[bi].binding_name, "ptr")
        mir_emit_inst(st, mir_store(payload, bind_addr))
        let case_flow = mir_emit_block(st, st.current_block, stmt.fields[bi].body)
        mir_truncate_locals(st, local_count)
        if case_flow.reachable {
            case_flow.block.terminator = mir_br(end_block.name)
            case_flow.block.has_terminator = true
        }
    }
    if has_else {
        let else_flow = mir_emit_block(st, else_block, stmt.else_block)
        if else_flow.reachable {
            else_flow.block.terminator = mir_br(end_block.name)
            else_flow.block.has_terminator = true
        }
    }
    st.current_block = end_block
    ret mir_reachable_flow(end_block)
}

fun mir_emit_match(st: MirCodegenState, block: MirBlock, stmt: AstNode): MirBlockFlow {
    st.current_block = block
    if mir_is_union_name(st, ast_resolved_type(stmt.expr)) {
        ret mir_emit_union_match(st, block, stmt)
    }
    let scrutinee_flow = mir_emit_expr(st, st.current_block, stmt.expr)
    st.current_block = scrutinee_flow.block
    let match_name = str_cat2("__match", str(st.value_counter))
    let match_addr = mir_alloc_local(st, match_name, mir_operand_type(scrutinee_flow.value))
    mir_emit_inst(st, mir_store(scrutinee_flow.value, match_addr))

    let end_block = mir_new_block(st, "match.end")
    let case_blocks = new MirBlock[0]
    let i = 0
    for i < len(stmt.fields) {
        case_blocks.push(mir_new_block(st, "match.case"))
        i = i + 1
    }
    let has_else = ast_kind(stmt.else_block) != ""
    let else_block = end_block
    if has_else {
        else_block = mir_new_block(st, "match.else")
    }
    let next_blocks = new MirBlock[0]
    let ni = 0
    for ni < len(stmt.fields) - 1 {
        next_blocks.push(mir_new_block(st, "match.next"))
        ni = ni + 1
    }

    let check_block = st.current_block
    let ci = 0
    for ci < len(stmt.fields) {
        st.current_block = check_block
        let next_block = else_block
        if ci < len(stmt.fields) - 1 {
            next_block = next_blocks[ci]
        }
        let scrut_name = mir_new_value(st, "load")
        mir_emit_inst(st, mir_load(scrut_name, mir_operand_type(scrutinee_flow.value), mir_operand_type(scrutinee_flow.value), match_addr))
        let pat_flow = mir_emit_expr(st, st.current_block, stmt.fields[ci].expr)
        st.current_block = pat_flow.block
        let cond = mir_make_result_inst(st, "icmp.eq", "bool")
        cond.operands.push(mir_value_operand(mir_operand_type(scrutinee_flow.value), scrut_name))
        cond.operands.push(pat_flow.value)
        mir_emit_inst(st, cond)
        st.current_block.terminator = mir_condbr(mir_value_operand("bool", cond.result_name), case_blocks[ci].name, next_block.name)
        st.current_block.has_terminator = true
        if ci < len(stmt.fields) - 1 {
            check_block = next_blocks[ci]
        }
        ci = ci + 1
    }
    if len(stmt.fields) == 0 {
        st.current_block = check_block
        st.current_block.terminator = mir_br(else_block.name)
        st.current_block.has_terminator = true
    }

    let bi = 0
    for bi < len(stmt.fields) {
        let case_flow = mir_emit_block(st, case_blocks[bi], stmt.fields[bi].body)
        if case_flow.reachable {
            case_flow.block.terminator = mir_br(end_block.name)
            case_flow.block.has_terminator = true
        }
        bi = bi + 1
    }
    if has_else {
        let else_flow = mir_emit_block(st, else_block, stmt.else_block)
        if else_flow.reachable {
            else_flow.block.terminator = mir_br(end_block.name)
            else_flow.block.has_terminator = true
        }
    }
    st.current_block = end_block
    ret mir_reachable_flow(end_block)
}

fun mir_emit_if(st: MirCodegenState, block: MirBlock, stmt: AstNode): MirBlockFlow {
    st.current_block = block
    let cond_flow = mir_emit_expr(st, st.current_block, stmt.expr)
    st.current_block = cond_flow.block
    let then_block = mir_new_block(st, "if.then")
    let has_else = ast_kind(stmt.else_block) != ""
    let else_block = mir_block_empty("")
    if has_else {
        else_block = mir_new_block(st, "if.else")
    }
    let end_block = mir_new_block(st, "if.end")
    if has_else {
        st.current_block.terminator = mir_condbr(cond_flow.value, then_block.name, else_block.name)
    } else {
        st.current_block.terminator = mir_condbr(cond_flow.value, then_block.name, end_block.name)
    }
    st.current_block.has_terminator = true

    let then_flow = mir_emit_block(st, then_block, stmt.then_block)
    if then_flow.reachable {
        then_flow.block.terminator = mir_br(end_block.name)
        then_flow.block.has_terminator = true
    }

    let else_reachable = true
    if has_else {
        let else_flow = mir_emit_block(st, else_block, stmt.else_block)
        else_reachable = else_flow.reachable
        if else_flow.reachable {
            else_flow.block.terminator = mir_br(end_block.name)
            else_flow.block.has_terminator = true
        }
    }

    st.current_block = end_block
    if then_flow.reachable || else_reachable {
        ret mir_reachable_flow(end_block)
    }
    ret mir_unreachable_flow()
}

fun mir_push_loop(st: MirCodegenState, continue_target: str, break_target: str): void {
    st.continue_targets.push(continue_target)
    st.break_targets.push(break_target)
}

fun mir_pop_loop(st: MirCodegenState): void {
    let c = new str[0]
    let b = new str[0]
    let i = 0
    for i < len(st.continue_targets) - 1 {
        c.push(st.continue_targets[i])
        b.push(st.break_targets[i])
        i = i + 1
    }
    st.continue_targets = c
    st.break_targets = b
}

fun mir_emit_for(st: MirCodegenState, block: MirBlock, stmt: AstNode): MirBlockFlow {
    st.current_block = block
    let var_addr = mir_alloc_local(st, stmt.name, "i64")
    let end_name = str_cat2(str_cat2("__", stmt.name), str_cat2(".end", str(st.value_counter)))
    let end_addr = mir_alloc_local(st, end_name, "i64")

    let start_flow = mir_emit_expr(st, st.current_block, stmt.start)
    st.current_block = start_flow.block
    mir_emit_inst(st, mir_store(start_flow.value, var_addr))
    let end_flow = mir_emit_expr(st, st.current_block, stmt.end)
    st.current_block = end_flow.block
    mir_emit_inst(st, mir_store(end_flow.value, end_addr))

    let cond_block = mir_new_block(st, "for.cond")
    let body_block = mir_new_block(st, "for.body")
    let inc_block = mir_new_block(st, "for.inc")
    let end_block = mir_new_block(st, "for.end")
    st.current_block.terminator = mir_br(cond_block.name)
    st.current_block.has_terminator = true

    st.current_block = cond_block
    let cur_name = mir_new_value(st, "load")
    mir_emit_inst(st, mir_load(cur_name, "i64", "i64", var_addr))
    let end_load_name = mir_new_value(st, "load")
    mir_emit_inst(st, mir_load(end_load_name, "i64", "i64", end_addr))
    let cond_inst = mir_make_result_inst(st, "icmp.slt", "bool")
    cond_inst.operands.push(mir_value_operand("i64", cur_name))
    cond_inst.operands.push(mir_value_operand("i64", end_load_name))
    mir_emit_inst(st, cond_inst)
    st.current_block.terminator = mir_condbr(mir_value_operand("bool", cond_inst.result_name), body_block.name, end_block.name)
    st.current_block.has_terminator = true

    mir_push_loop(st, inc_block.name, end_block.name)
    let body_flow = mir_emit_block(st, body_block, stmt.body)
    if body_flow.reachable {
        body_flow.block.terminator = mir_br(inc_block.name)
        body_flow.block.has_terminator = true
    }
    mir_pop_loop(st)

    st.current_block = inc_block
    let inc_cur_name = mir_new_value(st, "load")
    mir_emit_inst(st, mir_load(inc_cur_name, "i64", "i64", var_addr))
    let add_inst = mir_make_result_inst(st, "add", "i64")
    add_inst.operands.push(mir_value_operand("i64", inc_cur_name))
    add_inst.operands.push(mir_const_int("i64", 1))
    mir_emit_inst(st, add_inst)
    mir_emit_inst(st, mir_store(mir_value_operand("i64", add_inst.result_name), var_addr))
    st.current_block.terminator = mir_br(cond_block.name)
    st.current_block.has_terminator = true
    ret mir_reachable_flow(end_block)
}

fun mir_emit_while(st: MirCodegenState, block: MirBlock, stmt: AstNode): MirBlockFlow {
    st.current_block = block
    let cond_block = mir_new_block(st, "while.cond")
    let body_block = mir_new_block(st, "while.body")
    let end_block = mir_new_block(st, "while.end")
    st.current_block.terminator = mir_br(cond_block.name)
    st.current_block.has_terminator = true

    mir_push_loop(st, cond_block.name, end_block.name)
    let cond_flow = mir_emit_expr(st, cond_block, stmt.expr)
    cond_flow.block.terminator = mir_condbr(cond_flow.value, body_block.name, end_block.name)
    cond_flow.block.has_terminator = true

    let body_flow = mir_emit_block(st, body_block, stmt.body)
    if body_flow.reachable {
        body_flow.block.terminator = mir_br(cond_block.name)
        body_flow.block.has_terminator = true
    }
    mir_pop_loop(st)
    ret mir_reachable_flow(end_block)
}


fun mir_emit_stmt(st: MirCodegenState, block: MirBlock, stmt: AstNode): MirBlockFlow {
    st.current_block = block
    match stmt {
        AstExprStmt n: {
            let value_flow = mir_emit_expr(st, st.current_block, n.expr)
            ret mir_reachable_flow(value_flow.block)
        }
        AstLet n: {
            let typ = mir_epic_type(n.AstMeta.resolved_type)
            let addr = mir_alloc_local(st, n.name, typ)
            let value_flow = mir_emit_expr(st, st.current_block, n.value_expr)
            st.current_block = value_flow.block
            mir_emit_inst(st, mir_store(value_flow.value, addr))
            ret mir_reachable_flow(st.current_block)
        }
        AstSubscriptAssign n: {
            let base_type = ast_resolved_type(n.base)
            let dst_flow = mir_emit_expr(st, st.current_block, n.base)
            st.current_block = dst_flow.block
            let index_flow = mir_emit_expr(st, st.current_block, n.index)
            st.current_block = index_flow.block
            let value_flow = mir_emit_expr(st, st.current_block, n.value_expr)
            st.current_block = value_flow.block
            let args = new MirOperand[0]
            args.push(dst_flow.value)
            args.push(index_flow.value)
            args.push(value_flow.value)
            let map_set_helper = mir_map_helper(base_type, "set")
            if map_set_helper != "" {
                mir_emit_call_inst(st, map_set_helper, "void", args)
            } else {
                if mir_is_u8_array_type(base_type) {
                    mir_emit_call_inst(st, "__ep_slice_u8_set", "void", args)
                } else {
                    if mir_is_ptr_array_type(st, base_type) {
                        mir_emit_call_inst(st, "__ep_slice_ptr_set", "void", args)
                    } else {
                        mir_emit_call_inst(st, "__ep_slice_i64_set", "void", args)
                    }
                }
            }
            ret mir_reachable_flow(st.current_block)
        }
        AstFieldSet n: {
            let base_type = ast_resolved_type(n.object)
            let base_flow = mir_emit_expr(st, st.current_block, n.object)
            st.current_block = base_flow.block
            let value_flow = mir_emit_expr(st, st.current_block, n.value_expr)
            st.current_block = value_flow.block
            if mir_is_union_name(st, base_type) {
                mir_store_union_partial_field(st, base_flow.value, base_type, n.name, value_flow.value)
                ret mir_reachable_flow(st.current_block)
            }
            let struct_name = mir_layout_struct_name(st, base_type)
            if struct_name == "" {
                ast_to_mir_die("field assignment base must be struct")
            }
            let addr = mir_promoted_field_addr(st, base_flow.value, struct_name, n.name)
            mir_emit_inst(st, mir_store(value_flow.value, addr))
            ret mir_reachable_flow(st.current_block)
        }
        AstAssign n: {
            let value_flow = mir_emit_expr(st, st.current_block, n.value_expr)
            st.current_block = value_flow.block
            let gidx = mir_global_index(st, n.name)
            if gidx >= 0 {
                let addr = mir_symbol_operand("ptr", mir_global_label(n.name))
                mir_emit_inst(st, mir_store(value_flow.value, addr))
                ret mir_reachable_flow(st.current_block)
            }
            let idx = mir_local_index(st, n.name)
            let addr = mir_value_operand("ptr", st.local_addr_names[idx])
            mir_emit_inst(st, mir_store(value_flow.value, addr))
            ret mir_reachable_flow(st.current_block)
        }
        AstAssignOp n: {
            match n.expr {
                AstVar target: {
                    let idx = mir_local_index(st, target.name)
                    let result_name = mir_new_value(st, "load")
                    let addr = mir_value_operand("ptr", st.local_addr_names[idx])
                    mir_emit_inst(st, mir_load(result_name, st.local_types[idx], st.local_types[idx], addr))
                    let rhs_flow = mir_emit_expr(st, st.current_block, n.value_expr)
                    st.current_block = rhs_flow.block
                    let target_type = target.AstMeta.resolved_type
                    let op = mir_binary_op(n.op, target_type)
                    let result_type = mir_op_result_type(op)
                    if n.op == "<<" || n.op == ">>" || n.op == ">>>" {
                        mir_emit_shift_count_check(st, rhs_flow.value, target_type, n.AstMeta.line)
                    }
                    let inst = mir_make_result_inst(st, op, result_type)
                    inst.operands.push(mir_value_operand(st.local_types[idx], result_name))
                    inst.operands.push(rhs_flow.value)
                    mir_emit_inst(st, inst)
                    mir_emit_inst(st, mir_store(mir_normalize_int_value(st, mir_value_operand(result_type, inst.result_name), target_type), addr))
                    ret mir_reachable_flow(st.current_block)
                }
                AstFieldAccess target: {
                    let base_type = ast_resolved_type(target.object)
                    let struct_name = mir_layout_struct_name(st, base_type)
                    if struct_name == "" {
                        ast_to_mir_die("compound field assignment base must be struct")
                    }
                    let base_flow = mir_emit_expr(st, st.current_block, target.object)
                    st.current_block = base_flow.block
                    let addr = mir_promoted_field_addr(st, base_flow.value, struct_name, target.name)
                    let field_typ = mir_promoted_field_type(st, struct_name, target.name)
                    let result_name = mir_new_value(st, "load")
                    mir_emit_inst(st, mir_load(result_name, field_typ, field_typ, addr))
                    let rhs_flow = mir_emit_expr(st, st.current_block, n.value_expr)
                    st.current_block = rhs_flow.block
                    let target_type = target.AstMeta.resolved_type
                    let op = mir_binary_op(n.op, target_type)
                    let result_type = mir_op_result_type(op)
                    if n.op == "<<" || n.op == ">>" || n.op == ">>>" {
                        mir_emit_shift_count_check(st, rhs_flow.value, target_type, n.AstMeta.line)
                    }
                    let inst = mir_make_result_inst(st, op, result_type)
                    inst.operands.push(mir_value_operand(field_typ, result_name))
                    inst.operands.push(rhs_flow.value)
                    mir_emit_inst(st, inst)
                    mir_emit_inst(st, mir_store(mir_normalize_int_value(st, mir_value_operand(result_type, inst.result_name), target_type), addr))
                    ret mir_reachable_flow(st.current_block)
                }
                AstSubscript target: {
                    let base_type = ast_resolved_type(target.base)
                    let dst_flow = mir_emit_expr(st, st.current_block, target.base)
                    st.current_block = dst_flow.block
                    let index_flow = mir_emit_expr(st, st.current_block, target.index)
                    st.current_block = index_flow.block
                    let get_args = new MirOperand[0]
                    get_args.push(dst_flow.value)
                    get_args.push(index_flow.value)
                    let current = mir_const_int("i64", 0)
                    let map_value_type = mir_map_value_type(base_type)
                    if map_value_type != "" {
                        current = mir_emit_call_inst(st, mir_map_helper(base_type, "get"), map_value_type, get_args)
                    } else {
                        if mir_is_u8_array_type(base_type) {
                            current = mir_emit_call_inst(st, "__ep_slice_u8_get", "i64", get_args)
                        } else {
                            current = mir_emit_call_inst(st, "__ep_slice_i64_get", "i64", get_args)
                        }
                    }
                    let rhs_flow = mir_emit_expr(st, st.current_block, n.value_expr)
                    st.current_block = rhs_flow.block
                    let target_type = target.AstMeta.resolved_type
                    let op = mir_binary_op(n.op, target_type)
                    let result_type = mir_op_result_type(op)
                    if n.op == "<<" || n.op == ">>" || n.op == ">>>" {
                        mir_emit_shift_count_check(st, rhs_flow.value, target_type, n.AstMeta.line)
                    }
                    let inst = mir_make_result_inst(st, op, result_type)
                    inst.operands.push(current)
                    inst.operands.push(rhs_flow.value)
                    mir_emit_inst(st, inst)
                    let set_args = new MirOperand[0]
                    set_args.push(dst_flow.value)
                    set_args.push(index_flow.value)
                    set_args.push(mir_normalize_int_value(st, mir_value_operand(result_type, inst.result_name), target_type))
                    let map_set_helper2 = mir_map_helper(base_type, "set")
                    if map_set_helper2 != "" {
                        mir_emit_call_inst(st, map_set_helper2, "void", set_args)
                    } else {
                        if mir_is_u8_array_type(base_type) {
                            mir_emit_call_inst(st, "__ep_slice_u8_set", "void", set_args)
                        } else {
                            mir_emit_call_inst(st, "__ep_slice_i64_set", "void", set_args)
                        }
                    }
                    ret mir_reachable_flow(st.current_block)
                }
                _: {
                    ast_to_mir_die("unsupported compound assignment target")
                }
            }
            ret mir_unreachable_flow()
        }
        AstIf n: {
            ret mir_emit_if(st, st.current_block, stmt)
        }
        AstAssert n: {
            ret mir_emit_assert(st, st.current_block, stmt)
        }
        AstPanic n: {
            ret mir_emit_panic(st, st.current_block, stmt)
        }
        AstMatch n: {
            ret mir_emit_match(st, st.current_block, stmt)
        }
        AstWhile n: {
            ret mir_emit_while(st, st.current_block, stmt)
        }
        AstFor n: {
            ret mir_emit_for(st, st.current_block, stmt)
        }
        AstBreak n: {
            if len(st.break_targets) == 0 {
                ast_to_mir_die("break outside loop")
            }
            st.current_block.terminator = mir_br(st.break_targets[len(st.break_targets) - 1])
            st.current_block.has_terminator = true
            ret mir_unreachable_flow()
        }
        AstContinue n: {
            if len(st.continue_targets) == 0 {
                ast_to_mir_die("continue outside loop")
            }
            st.current_block.terminator = mir_br(st.continue_targets[len(st.continue_targets) - 1])
            st.current_block.has_terminator = true
            ret mir_unreachable_flow()
        }
        AstReturn n: {
            match n.expr {
                AstEmpty e: {
                    st.current_block.terminator = mir_ret_void()
                }
                _: {
                    let value_flow = mir_emit_expr(st, st.current_block, n.expr)
                    st.current_block = value_flow.block
                    st.current_block.terminator = mir_ret_value(value_flow.value)
                }
            }
            st.current_block.has_terminator = true
            ret mir_unreachable_flow()
        }
        _: {
            ast_to_mir_die(f"unsupported stmt {ast_kind(stmt)}")
        }
    }
    ret mir_unreachable_flow()
}


fun mir_emit_block(st: MirCodegenState, block: MirBlock, ast_block: AstNode): MirBlockFlow {
    let current = block
    let i = 0
    for i < len(ast_block.stmts) {
        if current.has_terminator {
            ret mir_unreachable_flow()
        }
        let flow = mir_emit_stmt(st, current, ast_block.stmts[i])
        if flow.reachable == false {
            ret flow
        }
        current = flow.block
        i = i + 1
    }
    ret mir_reachable_flow(current)
}

fun mir_param(name: str, typ: str): MirParam {
    let p = new MirParam
    p.name = name
    p.typ = typ
    ret p
}


fun mir_emit_function(st: MirCodegenState, fn_ast: AstFunDef): MirFunction {
    st.value_counter = 0
    st.block_counter = 0
    st.local_names = new str[0]
    st.local_addr_names = new str[0]
    st.local_types = new str[0]
    st.continue_targets = new str[0]
    st.break_targets = new str[0]
    st.current_fn = mir_function_empty(fn_ast.name, mir_epic_type(fn_ast.AstMeta.resolved_type))

    let pi = 0
    for pi < len(fn_ast.params) {
        match fn_ast.params[pi] {
            AstParam param: {
                st.current_fn.params.push(mir_param(param.name, mir_epic_type(param.AstMeta.resolved_type)))
            }
            _: { ast_to_mir_die("internal: expected function parameter") }
        }
        pi = pi + 1
    }

    st.current_block = mir_new_block(st, "entry")

    let i = 0
    for i < len(st.current_fn.params) {
        let addr = mir_alloc_local(st, st.current_fn.params[i].name, st.current_fn.params[i].typ)
        mir_emit_inst(st, mir_store(mir_value_operand(st.current_fn.params[i].typ, st.current_fn.params[i].name), addr))
        i = i + 1
    }

    let body_flow = mir_emit_block(st, st.current_block, fn_ast.body)
    if body_flow.reachable {
        st.current_block = body_flow.block
    }
    if st.current_block.has_terminator == false {
        if st.current_fn.return_type == "void" {
            st.current_block.terminator = mir_ret_void()
            st.current_block.has_terminator = true
        } else {
            st.current_block.terminator = mir_ret_value(mir_const_int(st.current_fn.return_type, 0))
            st.current_block.has_terminator = true
        }
    }
    ret st.current_fn
}


fun mir_register_slice_layout(st: MirCodegenState, name: str): void {
    st.struct_names.push(name)
    st.struct_field_keys.push(mir_struct_key(name, "data"))
    st.struct_field_types.push("ptr")
    st.struct_field_indexes.push(0)
    st.struct_field_embedded.push(0)
    mir_program_add_struct_field(st.program, name, "ptr", 0)
    st.struct_field_keys.push(mir_struct_key(name, "len"))
    st.struct_field_types.push("i64")
    st.struct_field_indexes.push(1)
    st.struct_field_embedded.push(0)
    mir_program_add_struct_field(st.program, name, "i64", 1)
    st.struct_field_keys.push(mir_struct_key(name, "cap"))
    st.struct_field_types.push("i64")
    st.struct_field_indexes.push(2)
    st.struct_field_embedded.push(0)
    mir_program_add_struct_field(st.program, name, "i64", 2)
}


fun mir_ast_to_mir(ast: AstNode): MirProgram {
    let st = new MirCodegenState
    st.program = mir_program_empty()
    st.current_fn = mir_function_empty("", "void")
    st.current_block = mir_block_empty("")
    st.value_counter = 0
    st.block_counter = 0
    st.local_names = new str[0]
    st.local_addr_names = new str[0]
    st.local_types = new str[0]
    st.func_names = new str[0]
    st.func_return_types = new str[0]
    st.global_names = new str[0]
    st.global_types = new str[0]
    st.continue_targets = new str[0]
    st.break_targets = new str[0]
    st.struct_names = new str[0]
    st.union_names = new str[0]
    st.union_member_keys = new str[0]
    st.union_member_tags = new i64[0]
    st.union_member_names = new str[0]
    st.struct_field_keys = new str[0]
    st.struct_field_types = new str[0]
    st.struct_field_indexes = new i64[0]
    st.struct_field_embedded = new i64[0]
    st.string_values = new str[0]
    st.string_labels = new str[0]
    st.string_counter = 0

    match ast {
        AstProgram program: {
            let si = 0
            for si < len(program.structs) {
                match program.structs[si] {
                    AstStructDef sdef: {
                        st.struct_names.push(sdef.name)
                        let fi2 = 0
                        for fi2 < len(sdef.fields) {
                            match sdef.fields[fi2] {
                                AstStructField field: {
                                    st.struct_field_keys.push(mir_struct_key(sdef.name, field.name))
                                    let field_mir_type = mir_epic_type(field.type_name)
                                    st.struct_field_types.push(field_mir_type)
                                    st.struct_field_indexes.push(fi2)
                                    if field.embedded { st.struct_field_embedded.push(1) } else { st.struct_field_embedded.push(0) }
                                    mir_program_add_struct_field(st.program, sdef.name, field_mir_type, fi2)
                                }
                                _: { ast_to_mir_die("internal: expected struct field") }
                            }
                            fi2 = fi2 + 1
                        }
                    }
                    _: { ast_to_mir_die("internal: expected top-level struct") }
                }
                si = si + 1
            }
            for ui in 0:len(program.unions) {
                match program.unions[ui] {
                    AstUnionDef union: {
                        st.union_names.push(union.name)
                        st.struct_names.push(union.name)
                        for mi2 in 0:len(union.members) {
                            st.union_member_keys.push(mir_struct_key(union.name, union.members[mi2]))
                            st.union_member_tags.push(mi2 + 1)
                            st.union_member_names.push(union.members[mi2])
                        }
                        st.struct_field_keys.push(mir_struct_key(union.name, "tag"))
                        st.struct_field_types.push("i64")
                        st.struct_field_indexes.push(0)
                        st.struct_field_embedded.push(0)
                        mir_program_add_struct_field(st.program, union.name, "i64", 0)
                        st.struct_field_keys.push(mir_struct_key(union.name, "payload"))
                        st.struct_field_types.push("ptr")
                        st.struct_field_indexes.push(1)
                        st.struct_field_embedded.push(0)
                        mir_program_add_struct_field(st.program, union.name, "ptr", 1)
                    }
                    _: { ast_to_mir_die("internal: expected top-level union") }
                }
            }

            st.struct_names.push("str")
            st.struct_field_keys.push(mir_struct_key("str", "data"))
            st.struct_field_types.push("ptr")
            st.struct_field_indexes.push(0)
            st.struct_field_embedded.push(0)
            mir_program_add_struct_field(st.program, "str", "ptr", 0)
            st.struct_field_keys.push(mir_struct_key("str", "len"))
            st.struct_field_types.push("i64")
            st.struct_field_indexes.push(1)
            st.struct_field_embedded.push(0)
            mir_program_add_struct_field(st.program, "str", "i64", 1)
            st.struct_field_keys.push(mir_struct_key("str", "cap"))
            st.struct_field_types.push("i64")
            st.struct_field_indexes.push(2)
            st.struct_field_embedded.push(0)
            mir_program_add_struct_field(st.program, "str", "i64", 2)
            st.struct_names.push("_slice_i64")
            st.struct_field_keys.push(mir_struct_key("_slice_i64", "data"))
            st.struct_field_types.push("ptr")
            st.struct_field_indexes.push(0)
            st.struct_field_embedded.push(0)
            mir_program_add_struct_field(st.program, "_slice_i64", "ptr", 0)
            st.struct_field_keys.push(mir_struct_key("_slice_i64", "len"))
            st.struct_field_types.push("i64")
            st.struct_field_indexes.push(1)
            st.struct_field_embedded.push(0)
            mir_program_add_struct_field(st.program, "_slice_i64", "i64", 1)
            st.struct_field_keys.push(mir_struct_key("_slice_i64", "cap"))
            st.struct_field_types.push("i64")
            st.struct_field_indexes.push(2)
            st.struct_field_embedded.push(0)
            mir_program_add_struct_field(st.program, "_slice_i64", "i64", 2)
            st.struct_names.push("_slice_u8")
            st.struct_field_keys.push(mir_struct_key("_slice_u8", "data"))
            st.struct_field_types.push("ptr")
            st.struct_field_indexes.push(0)
            st.struct_field_embedded.push(0)
            mir_program_add_struct_field(st.program, "_slice_u8", "ptr", 0)
            st.struct_field_keys.push(mir_struct_key("_slice_u8", "len"))
            st.struct_field_types.push("i64")
            st.struct_field_indexes.push(1)
            st.struct_field_embedded.push(0)
            mir_program_add_struct_field(st.program, "_slice_u8", "i64", 1)
            st.struct_field_keys.push(mir_struct_key("_slice_u8", "cap"))
            st.struct_field_types.push("i64")
            st.struct_field_indexes.push(2)
            st.struct_field_embedded.push(0)
            mir_program_add_struct_field(st.program, "_slice_u8", "i64", 2)

            mir_register_slice_layout(st, "_slice_str")
            mir_register_slice_layout(st, "_slice_ptr")
            let asi = 0
            for asi < len(program.structs) {
                match program.structs[asi] {
                    AstStructDef sdef: { mir_register_slice_layout(st, str_cat2("_slice_", sdef.name)) }
                    _: { ast_to_mir_die("internal: expected top-level struct") }
                }
                asi = asi + 1
            }
            for aui in 0:len(program.unions) {
                match program.unions[aui] {
                    AstUnionDef union: { mir_register_slice_layout(st, str_cat2("_slice_", union.name)) }
                    _: { ast_to_mir_die("internal: expected top-level union") }
                }
            }

            let map_layouts = new str[0]
            map_layouts.push("_map_str_i64")
            map_layouts.push("_map_str_bool")
            map_layouts.push("_map_str_str")
            let mi = 0
            for mi < len(map_layouts) {
                st.struct_names.push(map_layouts[mi])
                st.struct_field_keys.push(mir_struct_key(map_layouts[mi], "entries"))
                st.struct_field_types.push("ptr")
                st.struct_field_indexes.push(0)
                st.struct_field_embedded.push(0)
                mir_program_add_struct_field(st.program, map_layouts[mi], "ptr", 0)
                st.struct_field_keys.push(mir_struct_key(map_layouts[mi], "len"))
                st.struct_field_types.push("i64")
                st.struct_field_indexes.push(1)
                st.struct_field_embedded.push(0)
                mir_program_add_struct_field(st.program, map_layouts[mi], "i64", 1)
                st.struct_field_keys.push(mir_struct_key(map_layouts[mi], "cap"))
                st.struct_field_types.push("i64")
                st.struct_field_indexes.push(2)
                st.struct_field_embedded.push(0)
                mir_program_add_struct_field(st.program, map_layouts[mi], "i64", 2)
                mi = mi + 1
            }

            mir_add_global_lets(st, program)
            mir_emit_global_init_function(st, program)

            let fi = 0
            for fi < len(program.funcs) {
                match program.funcs[fi] {
                    AstFunDef fn: {
                        st.func_names.push(fn.name)
                        st.func_return_types.push(mir_epic_type(fn.AstMeta.resolved_type))
                    }
                    _: { ast_to_mir_die("internal: expected function definition") }
                }
                fi = fi + 1
            }

            let i = 0
            for i < len(program.funcs) {
                match program.funcs[i] {
                    AstFunDef fn_ast: {
                        let fn = mir_emit_function(st, fn_ast)
                        st.program.functions.push(fn)
                    }
                    _: { ast_to_mir_die("internal: expected function definition") }
                }
                i = i + 1
            }
            ret st.program
        }
        _: {}
    }
    ast_to_mir_die("internal: expected program")
    ret st.program
}


fun main(): void {
    if len(argv) < 2 {
        panic "usage: ast_to_mir <file>"
    }
    let src = str(read_file(argv[1]))
    let tokens = lex(src)
    let p = make_parser(tokens)
    let ast = parse_program(p)
    let st = make_sema_state()
    sema_program(st, ast)
    let mir = mir_ast_to_mir(ast)
    mir_print_program(mir)
}
