#
# Pure helpers shared across compiler stages.
# Keep module-specific parsing, diagnostics, and output logic in their owners.
#
fun align_up(value: i64, alignment: i64): i64 {
    ret ((value + alignment - 1) / alignment) * alignment
}
fun type_is_array(name: str): i64 {
    if len(name) < 2 {
        ret 0
    }
    ret name[len(name) - 2] == 91 && name[len(name) - 1] == 93
}
fun array_element_type(name: str): str {
    ret str_new(name.data, len(name) - 2)
}
fun digit_value(c: i64): i64 {
    if c >= 48 && c <= 57 {
        ret c - 48
    }
    if c >= 65 && c <= 70 {
        ret c - 55
    }
    if c >= 97 && c <= 102 {
        ret c - 87
    }
    ret -1
}
fun parse_integer(text: str): i64 {
    let sign = 1
    let i = 0
    if text[0] == 45 {
        sign = -1
        i = 1
    }
    let base = 10
    if i + 2 <= len(text) && text[i] == 48 && (text[i + 1] == 120 || text[i + 1] == 88) {
        base = 16
        i += 2
    }
    let value = 0
    while i < len(text) {
        value = value * base + digit_value(text[i])
        i += 1
    }
    ret value * sign
}
