fun check(ok: bool): void {
    if !ok {
        panic "check failed"
    }
}

fun main(): void {
    let text = make_str_buf()
    str_buf_extend(text, "declare void @__ep_import$kernel32.dll$ExitProcess(i64)\n\ntype Zed = struct size 8 align 8 { ptr @0 }\n\ntype Unused = struct size 8 align 8 { i64 @0 }\n\ntype Data = struct size 16 align 8 { i8 @0, i16 @2, i32 @4, i64 @8 }\n\nglobal @argv: ptr\n\nglobal @counter: i64 = 42\n\nglobal @str.0: ptr = bytes \"A")
    text.push(u8(92))
    text.push(u8(110))
    text.push(u8(92))
    text.push(u8(34))
    text.push(u8(92))
    text.push(u8(92))
    text.push(u8(92))
    str_buf_extend(text, "x00")
    text.push(u8(92))
    str_buf_extend(text, "xFF//tail\"\n\ndefine i64 @main() {\nentry:\n  %1: ptr = gep struct Zed, ptr null, i64 1\n  %2: ptr = gep struct Data, ptr null, i64 1\n  call void __ep_import$kernel32.dll$ExitProcess(i64 0)\n  ret i64 0\n}\n")

    let program = mrt_parse_program(str_buf_finish(text))
    mir_validate_call_contracts(program)
    check(len(program.struct_layouts) == 3)
    check(program.struct_layouts[2].name == "Data")
    check(program.struct_layouts[2].size == 16)
    check(program.struct_layouts[2].align == 8)
    check(len(program.struct_fields) == 6)
    check(program.struct_fields[2].struct_name == "Data")
    check(program.struct_fields[2].field_type == "i8")
    check(program.struct_fields[2].field_index == 0)
    check(program.struct_fields[2].field_offset == 0)
    check(program.struct_fields[3].field_type == "i16")
    check(program.struct_fields[3].field_index == 1)
    check(program.struct_fields[3].field_offset == 2)
    check(program.struct_fields[4].field_type == "i32")
    check(program.struct_fields[4].field_offset == 4)
    check(program.struct_fields[5].field_type == "i64")
    check(program.struct_fields[5].field_offset == 8)
    check(len(program.globals) == 3)
    match program.globals[0] {
        MirDeclGlobal g: { check(g.name == "argv" && g.typ == "ptr") }
        _: { check(false) }
    }
    match program.globals[1] {
        MirScalarGlobal g: { check(g.name == "counter" && g.typ == "i64" && g.init == "42") }
        _: { check(false) }
    }
    match program.globals[2] {
        MirStringGlobal g: {
            let value = bytes(g.init)
            check(len(value) == 12)
            check(value[0] == u8(65))
            check(value[1] == u8(10))
            check(value[2] == u8(34))
            check(value[3] == u8(92))
            check(value[4] == u8(0))
            check(value[5] == u8(255))
            check(g.init[6:12] == "//tail")
        }
        _: { check(false) }
    }
    mir_print_program(program)
}
