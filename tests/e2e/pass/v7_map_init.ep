# EXIT: 0
fun main(): i64 {
    let suffix = "a"
    let nums = new map[str]i64 {
        "a": 1
        "b": 2
        "a": 3
    }
    let flags = new map[str]bool {
        "ready": true,
        suffix: false,
    }
    let names = new map[str]str {
        "x": "ex"
        "y": str(nums["b"])
    }

    assert(map_has(nums, "a"))
    assert(nums["a"] == 3)
    assert(nums["b"] == 2)
    assert(flags["ready"])
    assert(flags["a"] == false)
    assert(names["x"] == "ex")
    assert(names["y"] == "2")
    ret 0
}
