# EXIT: 0
# STDOUT: false
# STDOUT: true
# STDOUT: true

type Inner {
    ok: bool
}

type Outer {
    inner: Inner
}

fun run(): i64 {
    let o = new Outer
    println(str(o.inner?))
    o.inner = new Inner { ok: true }
    let x = o.inner
    println(str(x?))
    if x? {
        println(str(x.ok))
    }
    ret 0
}

fun main(): void {
    exit(run())
}
