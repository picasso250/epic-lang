# EXIT: 0
# STDOUT: ok

struct Box {
    value: i64
}

fun main(): i64 {
    let boxes = new map[str]Box
    boxes["a"] = new Box { value: 3 }
    boxes["b"] = new Box { value: 4 }
    assert(boxes.has("a"))
    assert(boxes["a"].value == 3)
    assert(boxes["b"].value == 4)
    assert(boxes.del("a"))
    assert(boxes.has("a") == false)
    println("ok")
    ret 0
}
