# EXIT: 0

fun choose(n: i64): i64 {
    if n == 0 {
        ret 2
    } else {
        ret 3
    }
}

fun classify(n: i64): i64 {
    match n {
        0: {
            ret 5
        }
        _: {
            ret 7
        }
    }
}

fun run(): i64 {
    ret choose(0) + classify(1) - 9
}

fun main(): void {
    exit(run())
}
