# EXIT: 0
fun to_upper(c: u8): i64 {
    if c >= 'a' && c <= 'z' {
        ret c - 32
    }
    ret c
}
fun narrow_return(): u8 {
    ret 300
}
fun main(): void {
    let buf = new u8[]
    push(buf, 255)
    if to_upper('h') != 'H' || to_upper('i') != 'I' || to_upper('z') != 90 || narrow_return() != 44 || buf.data[0] != 255 {
        os.ExitProcess(1)
    }
    os.ExitProcess(0)
}
