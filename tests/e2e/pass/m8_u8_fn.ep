# EXIT: 0
# STDOUT: HI
# STDOUT: 90
# STDOUT: 44
# STDOUT: 255
fun to_upper(c: u8): i64 {
    if c >= 'a' && c <= 'z' {
        return c - 32
    }
    return c
}
fun narrow_return(): u8 {
    return 300
}
fun main(): void {
    putc(to_upper('h'))
    putc(to_upper('i'))
    putc(10)
    putstr(itoa(to_upper('z')))
    putc(10)
    putstr(itoa(narrow_return()))
    putc(10)
    let buf = new u8[1]
    push(buf, 255)
    putstr(itoa(buf.data[0]))
    putc(10)
    os.ExitProcess(0)
}
