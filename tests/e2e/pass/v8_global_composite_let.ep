# EXIT: 9
struct Config {
    port: i64
    name: str
}

let greeting = "hello"
let bytes = new u8[] { u8(1), u8(2), u8(3) }
let nums = new i64[] { 4, 5 }
let cfg = new Config { port: 7, name: "dev" }

fun main(): i64 {
    if greeting != "hello" {
        ret 1
    }
    if len(bytes) != 3 {
        ret 2
    }
    if nums[1] != 5 {
        ret 3
    }
    if cfg.port != 7 {
        ret 6
    }
    ret len(bytes) + nums[1] + 1
}