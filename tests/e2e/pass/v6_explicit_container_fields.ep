# EXIT: 0
# STDOUT: ok

fun check(ok: bool): void {
    if !ok {
        panic "check failed"
    }
}

type S = {
    xs: i64[]
}

fun add_one(xs: i64[]): void {
    xs.push(1)
}

fun run(): i64 {
    let s = new S { xs: new i64[] }
    check(len(s.xs) == 0)
    s.xs.push(7)
    add_one(s.xs)
    check(len(s.xs) == 2)
    check(s.xs[0] == 7)
    check(s.xs[1] == 1)
    println("ok")
    ret 0
}

fun main(): void {
    exit(run())
}

