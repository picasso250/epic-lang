# EXIT: 0
# STDOUT: one,s,true,else

fun run(): i64 {
    let n = 1
    match n {
        0: {
            print("zero")
        }
        1: {
            print("one")
        }
        _: {
            print("many")
        }
    }
    print(",")

    let s = "x"
    match s {
        "x": {
            print("s")
        }
        _: {
            print("no")
        }
    }
    print(",")

    let b = true
    match b {
        true: {
            print("true")
        }
        _: {
            print("false")
        }
    }
    print(",")

    let m = 3
    match m {
        1: {
            print("bad")
        }
        _: {
            print("else")
        }
    }
    ret 0
}

fun main(): void {
    exit(run())
}
