# EXIT: 0
# CLEAN: test_os_create.tmp
fun main(): void {
    os.Sleep(1)
    let t = os.GetTickCount64()
    let n = os.lstrlenA(cstr("abc"))
    let prefix = os.lstrlenA(cstr("a\0b"))
    let c = os.lstrcmpA("same", "same")
    let made = os.CreateDirectoryA("build", 0)
    let mkdir_error = os.GetLastError()
    let attrs = os.GetFileAttributesA("build")
    let h = os.CreateFileA("test_os_create.tmp", 1073741824, 0, 0, 2, 128, 0)
    if t >= 0 && n == 3 && prefix == 1 && c == 0 && (made != 0 || mkdir_error == 183) && (attrs & 16) != 0 && h + 1 != 0 {
        os.CloseHandle(h)
        os.ExitProcess(0)
    }
    os.ExitProcess(1)
}
