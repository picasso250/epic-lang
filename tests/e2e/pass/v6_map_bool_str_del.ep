# EXIT: 0
# STDOUT: ok

fun main(): i64 {
    let flags = new map[str]bool
    flags["alpha"] = true
    let kb = new u8[]
    extend(kb, bytes("alp"))
    extend(kb, bytes("ha"))
    let dyn_key = str(kb)
    assert(map_has(flags, dyn_key))
    assert(flags[dyn_key] == true)
    assert(map_del(flags, dyn_key))
    assert(map_has(flags, "alpha") == false)
    assert(flags["alpha"] == false)
    assert(map_del(flags, "alpha") == false)

    flags["k0"] = true
    flags["k1"] = true
    flags["k2"] = true
    flags["k3"] = true
    flags["k4"] = true
    assert(flags["k4"] == true)

    let names = new map[str]str
    names["a"] = "one"
    names["b"] = "two"
    assert(names["a"] == "one")
    assert(names["b"] == "two")
    assert(map_del(names, "a"))
    assert(names["a"] == "")
    assert(names["b"] == "two")

    println("ok")
    ret 0
}
