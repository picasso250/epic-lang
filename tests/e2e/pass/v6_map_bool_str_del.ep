# EXIT: 0
# STDOUT: ok

fun main(): i64 {
    let flags = new map[str]bool
    flags["alpha"] = true
    let kb = new u8[]
    kb.extend(bytes("alp"))
    kb.extend(bytes("ha"))
    let dyn_key = str(kb)
    assert(flags.has(dyn_key))
    assert(flags[dyn_key] == true)
    assert(flags.del(dyn_key))
    assert(flags.has("alpha") == false)
    assert(flags.del("alpha") == false)

    flags["k0"] = true
    flags["k1"] = true
    flags["k2"] = true
    flags["k3"] = true
    flags["k4"] = true
    assert(flags["k4"] == true)

    let names = new map[str]str
    names["a"] = "one"
    names["b"] = "two"
    assert(names["a"] == "one")
    assert(names["b"] == "two")
    assert(names.del("a"))
    assert(names.has("a") == false)
    assert(names["b"] == "two")

    println("ok")
    ret 0
}
