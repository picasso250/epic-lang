# EXIT: 0
# STDOUT: 42

struct Meta {
    line: i64
}

struct Leaf {
    Meta
    value: i64
}

struct Pair {
    Meta
    left: i64
    right: i64
}

type Node = Leaf | Pair

fun main(): i64 {
    let m = new Meta { line: 41 }
    let n: Node = new Node(new Leaf { Meta: m, value: 1 })
    n.Meta.line += 1
    println(str(n.Meta.line))
    ret 0
}
