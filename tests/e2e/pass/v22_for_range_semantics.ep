# EXIT: 0
fun check(ok: bool): void {
    if !ok {
        panic "check failed"
    }
}

fun bump(counter: i64[]): i64 {
    counter[0] += 1
    ret counter[0]
}

fun main(): void {
    let counter = new i64[] { 0 }
    let sum = 0
    for i: bump(counter):bump(counter) + 3 {
        if i < 3 {
            continue
        }
        sum += i
    }
    let assert = counter[0] == 2
    check(assert)
    check(sum == 7)
    let in = 42
    let while = 43
    check(in == 42)
    check(while == 43)
    exit(0)
}
