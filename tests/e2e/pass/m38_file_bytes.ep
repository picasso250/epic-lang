# EXIT: 0
# CLEAN: test_file_bytes.bin
fun main(): void {
    let data = new u8[3]
    push(data, 'A')
    push(data, 0)
    push(data, 'B')
    if write_file("test_file_bytes.bin", data) != 3 {
        os.ExitProcess(1)
    }
    let loaded = read_file("test_file_bytes.bin")
    if loaded.len != 3 || loaded[0] != 'A' || loaded[1] != 0 || loaded[2] != 'B' {
        os.ExitProcess(2)
    }

    let empty = new u8[1]
    if write_file("test_file_bytes.bin", empty) != 0 {
        os.ExitProcess(3)
    }
    let loaded_empty = read_file("test_file_bytes.bin")
    if loaded_empty.len != 0 {
        os.ExitProcess(4)
    }
    let missing = read_file("missing-file-for-m38")
    if missing.len != 0 {
        os.ExitProcess(5)
    }

    let bad_path_bytes = bytes("x")
    push(bad_path_bytes, 0)
    push(bad_path_bytes, 'y')
    let bad_path = str_new(bad_path_bytes.data, bad_path_bytes.len)
    if write_file(bad_path, data) + 1 != 0 {
        os.ExitProcess(6)
    }
    os.ExitProcess(0)
}
