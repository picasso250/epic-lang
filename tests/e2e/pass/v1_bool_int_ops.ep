# EXIT: 0
# STDOUT: OK
# STDOUT: 90
# STDOUT: 65
fun main(): void {
    let ok: bool = true
    let b: u8 = 'A'
    let mask: u64 = u64(240)
    let low: u64 = u64(15)
    if ok && !false {
        println("OK")
    }
    let combined: u64 = (mask | low) ^ u64(165)
    if combined == u64(90) {
        println(str(combined))
    }
    let shifted: u64 = (u64(b) << 1) >> 1
    println(str(shifted))
    let logical: u64 = (u64(0) - u64(1)) >> 1
    if logical != u64(9223372036854775807) { exit(1) }
    let arithmetic: i64 = -2 >> 1
    if arithmetic != -1 { exit(2) }
    exit(0)
}
