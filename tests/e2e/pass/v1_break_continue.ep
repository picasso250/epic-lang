# EXIT: 22
fun main(): void {
    let i = 0
    let sum = 0
    for i < 10 {
        i = i + 1
        if i == 2 {
            continue
        }
        if i == 6 {
            break
        }
        sum = sum + i
    }
    for j: 0:6 {
        if j == 1 {
            continue
        }
        if j == 5 {
            break
        }
        sum = sum + j
    }
    exit(sum)
}
