# EXIT: 0
# STDOUT: 3
# STDOUT: 2
fun main(): void {
    let xs = new i64[]
    xs.push(1)
    xs.push(2)
    xs.push(3)
    let sum = 0
    for i in xs {
        sum = sum + xs[i]
        if i == 0 {
            xs.pop()
        }
    }
    println(str(sum))
    println(str(xs.pop()))

    exit(0)
}
