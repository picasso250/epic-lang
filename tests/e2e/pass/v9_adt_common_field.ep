# EXIT: 0
# STDOUT: 42

struct Meta {
    line: i64
}

struct Leaf {
    meta: Meta
    value: i64
}

struct Pair {
    meta: Meta
    left: i64
    right: i64
}

type Node = Leaf | Pair

fun run(): i64 {
    let m = new Meta { line: 41 }
    let n: Node = new Node(new Leaf { meta: m, value: 1 })
    n.meta.line += 1
    println(str(n.meta.line))
    ret 0
}

fun main(): void {
    exit(run())
}
