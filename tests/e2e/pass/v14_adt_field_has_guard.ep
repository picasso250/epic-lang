# EXIT: 0
# STDOUT: leaf
# STDOUT: fallback

struct Leaf {
    name: str
}

struct Pair {
    left: i64
    right: i64
}

type Node = Leaf | Pair

fun print_name(n: Node): void {
    if n.name? {
        println(n.name)
        n.name = "changed"
        println(n.name)
    } else {
        println("fallback")
    }
}

fun main(): i64 {
    let a: Node = new Node(new Leaf { name: "leaf" })
    let b: Node = new Node(new Pair { left: 1, right: 2 })
    if a.name? {
        println(a.name)
        a.name = "after"
    }
    print_name(b)
    ret 0
}
