# EXIT: 0
fun main(): void {
    let buf = new u8[10]
    buf.data[0] = 'E'
    buf.data[1] = 'p'
    buf.data[2] = 'i'
    buf.data[3] = 'c'
    buf.data[4] = 10
    let i = 0
    while i < 5 {
        if buf.data[i] == 0 {
            os.ExitProcess(1)
        }
        i = i + 1
    }
    if buf.data[0] != 69 || buf.data[1] != 112 || buf.data[2] != 105 || buf.data[3] != 99 || buf.data[4] != 10 {
        os.ExitProcess(1)
    }
    os.ExitProcess(0)
}
