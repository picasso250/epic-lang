# EXIT: 0
fun main(): void {
    let buf = new u8[10]
    buf[0] = 'E'
    buf[1] = 'p'
    buf[2] = 'i'
    buf[3] = 'c'
    buf[4] = 10
    let i = 0
    for i < 5 {
        if buf[i] == 0 {
            os.ExitProcess(1)
        }
        i = i + 1
    }
    if buf[0] != 69 || buf[1] != 112 || buf[2] != 105 || buf[3] != 99 || buf[4] != 10 {
        os.ExitProcess(1)
    }
    os.ExitProcess(0)
}
