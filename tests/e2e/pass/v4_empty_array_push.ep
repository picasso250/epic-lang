# EXIT: 0
# STDOUT: 47,1,65,2,-12
fun check(ok: bool): void {
    if !ok {
        panic "check failed"
    }
}

type Pair {
    value: i64
}

fun main(): void {
    let a = str(47)
    let b = str(1)
    let s = str(65)
    let t = str(2)
    let neg = str(0 - 12)

    let buf1 = new u8[]
    check(len(buf1) == 0)
    buf1.extend(bytes(a))
    buf1.push(',')
    buf1.extend(bytes(b))
    print(str(buf1))

    let buf2 = new u8[]
    buf2.push(',')
    buf2.extend(bytes(s))
    buf2.push(',')
    buf2.extend(bytes(t))
    print(str(buf2))

    let buf3 = new u8[]
    buf3.push(',')
    buf3.extend(bytes(neg))
    print(str(buf3))

    let nums = new i64[]
    check(len(nums) == 0)
    nums.push(40)
    nums.push(2)
    check(nums[0] + nums[1] == 42)
    let pairs = new Pair[]
    check(len(pairs) == 0)
    let p = new Pair {}
    p.value = 7
    pairs.push(p)
    check(pairs[0].value == 7)
    exit(0)
}
