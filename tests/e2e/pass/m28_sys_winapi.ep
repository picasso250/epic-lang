# EXIT: 0
# STDOUT: true
# CLEAN: test_sys_create.tmp

extern "kernel32.dll" fun Sleep(milliseconds: u32): void
extern "kernel32.dll" fun GetTickCount64(): u64
extern "kernel32.dll" fun lstrlenA(text: u64): i32
extern "kernel32.dll" fun lstrcmpA(left: u64, right: u64): i32
extern "kernel32.dll" fun CreateFileA(path: u64, access: u32, share: u32, security: u64, creation: u32, flags: u32, template_file: u64): u64
extern "kernel32.dll" fun CloseHandle(handle: u64): i32

fun main(): void {
    Sleep(u32(1))
    let t = GetTickCount64()
    let n = lstrlenA(cstr("abc"))
    let c = lstrcmpA(cstr("a"), cstr("b"))
    let h = CreateFileA(cstr("test_sys_create.tmp"), u32(1073741824), u32(0), u64(0), u32(2), u32(128), u64(0))
    let invalid = u64(0) - u64(1)
    if t >= u64(0) && n == i32(3) && c < i32(0) && h != invalid {
        CloseHandle(h)
        println(str(true))
        exit(0)
    }
    exit(1)
}
