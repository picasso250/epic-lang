# EXIT: 0
# STDOUT: true
# CLEAN: test_sys_create.tmp

extern "kernel32.dll" fun Sleep(milliseconds: u32): void
extern "kernel32.dll" fun GetTickCount64(): u64
extern "kernel32.dll" fun lstrlenA(text: ptr): i32
extern "kernel32.dll" fun lstrcmpA(left: ptr, right: ptr): i32
extern "kernel32.dll" fun CreateFileA(path: ptr, access: u32, share: u32, security: ptr, creation: u32, flags: u32, template_file: ptr): ptr
extern "kernel32.dll" fun CloseHandle(handle: ptr): i32

fun main(): void {
    Sleep(u32(1))
    let t = GetTickCount64()
    let n = lstrlenA(cptr("abc"))
    let c = lstrcmpA(cptr("a"), cptr("b"))
    let h = CreateFileA(cptr("test_sys_create.tmp"), u32(1073741824), u32(0), ptr(0), u32(2), u32(128), ptr(0))
    let invalid = ptr(u64(0) - u64(1))
    if t >= u64(0) && n == i32(3) && c < i32(0) && h != invalid {
        CloseHandle(h)
        println(str(true))
        exit(0)
    }
    exit(1)
}
