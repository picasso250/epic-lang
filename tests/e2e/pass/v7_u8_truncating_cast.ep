# EXIT: 0
fun run(): i64 {
    let b: u8 = u8(300)
    if i64(b) != 44 { ret 10 }

    let neg: u8 = u8(-1)
    if i64(neg) != 255 { ret 11 }

    let bs = new u8[] { u8(300), u8(-1) }
    if i64(bs[0]) != 44 { ret 12 }
    if i64(bs[1]) != 255 { ret 13 }

    ret 0
}

fun main(): void {
    exit(run())
}
