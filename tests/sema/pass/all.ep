# Semantic analysis surface contract sample.
# This file must pass Python sema and produce a stable typed AST dump.

fun check(ok: bool): void {
    if !ok {
        panic "check failed"
    }
}

extern "kernel32.dll" fun GetTickCount64(): u64

struct Point {
    x: i64
    y: i64
    label: str
}

struct Holder {
    point: Point
    bytes: u8[]
    count: i64
}


struct SemLit {
    value: i64
}

struct SemAdd {
    left: i64
    right: i64
}

type SemExpr = SemLit | SemAdd

fun add(a: i64, b: i64): i64 {
    ret a + b
}

fun make_point(x: i64, y: i64, label: str): Point {
    ret new Point { x: x, y: y, label: label }
}

fun use_scalars(): i64 {
    let in = 42
    let a = 1
    let b: i64 = 2
    let c: u64 = u64(3)
    let d: i32 = i32(4)
    let e: u32 = u32(5)
    let byte: u8 = 'A'
    let ok: bool = true
    let no: bool = false
    let converted_i32 = i32(a)
    let converted_u32 = u32(b)
    let converted_u8 = u8(65)
    let converted_bool = bool(a)
    let sum = a + b * 3 - 4 / 2 + 5 % 2
    let shifted = (sum << 1) >> 2
    let bits = ~shifted & 255 | 16 ^ 3
    let cmp = sum == shifted || sum != bits && sum < bits || sum <= bits && bits > 0 || bits >= 0
    let logic = ok && !no || converted_bool
    if logic {
        ret add(sum, bits)
    }
    ret i64(byte)
}

fun use_arrays_and_strings(): i64 {
    let text = "hello"
    let bs = bytes(text)
    let again = str(bs)
    let joined = "hello, " + again
    let same = joined == "hello, hello"
    let different = joined != text
    let first: u8 = bs[0]
    let b0: u8 = bs[0]
    let sub = text[0:2]
    let bsub = bs[0:2]
    let xs = new i64[] { 1, 2, 3 }
    let ys = new u8[4]
    let zs = new u8[]
    xs.push(4)
    zs.push(first)
    zs.extend(bs)
    let n = len(xs)
    xs[0] = add(xs[1], xs[2])
    xs[1] += 1
    let index_sum = 0
    for i: 0:len(xs) {
        index_sum += i
    }
    let popped = xs.pop()
    println(f"{again} {sub} {bsub} {b0}")
    if same && different {
        ret n + xs[0] + popped + index_sum
    }
    ret 0
}

fun use_structs(): i64 {
    let p = make_point(1, 2, "p")
    let q = new Point
    let h = new Holder { point: p, bytes: bytes("abc"), count: 3 }
    let has_point = h.point?
    let has_bytes = h.bytes?
    q.x = p.x
    q.y = h.point.y
    q.label = str(h.bytes)
    if has_point && has_bytes {
        ret q.x + q.y + h.count
    }
    ret 0
}

fun use_control(limit: i64): i64 {
    let total = 0
    for i: 0:limit {
        if i == 2 {
            continue
        }
        if i == 5 {
            break
        }
        total += i
    }
    for total < 10 {
        total += 1
    }
    match total {
        0: {
            ret 0
        }
        10: {
            ret total
        }
        _: {
            ret total + 1
        }
    }
}


fun use_adt(): i64 {
    let e: SemExpr = new SemExpr(new SemAdd { left: 20, right: 22 })
    let out = 0
    match e {
        SemLit lit: {
            out = lit.value
        }
        SemAdd add_expr: {
            out = add_expr.left + add_expr.right
        }
    }
    ret out
}

fun main(): void {
    let a = use_scalars()
    let b = use_arrays_and_strings()
    let c = use_structs()
    let d = use_control(8)
    let e = use_adt()
    let assert = a >= 0
    check(assert)
    check(b >= 0)
    check(e == 42)
    println(str(a + b + c + d + e))
    ret
}
