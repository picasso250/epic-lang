fun build_machine_jcc_fixture(): X64Program {
    let program = x64_program_empty()
    x64_add_section(program, ".text")
    let ops = new i64[]
    ops.push(8) # x64 jo
    ops.push(9) # x64 jno
    ops.push(10) # x64 jb
    ops.push(11) # x64 jae
    ops.push(12) # x64 jz
    ops.push(13) # x64 jnz
    ops.push(14) # x64 jbe
    ops.push(15) # x64 ja
    ops.push(16) # x64 js
    ops.push(17) # x64 jns
    ops.push(18) # x64 jp
    ops.push(19) # x64 jnp
    ops.push(20) # x64 jl
    ops.push(21) # x64 jge
    ops.push(22) # x64 jle
    ops.push(23) # x64 jg
    let labels = new X64Label[]
    for i: 0:len(ops) {
        labels.push(x64_new_label(program))
    }
    for i: 0:len(ops) {
        x64_add_inst1(program, ops[i], x64_label_ref(labels[i]))
    }
    x64_add_inst0(program, 4) # x64 ret
    for i: 0:len(labels) {
        x64_bind_label(program, labels[i])
    }
    ret program
}

fun assert_machine_jcc_bytes(): void {
    let obj = machine_build_object(build_machine_jcc_fixture())
    if len(obj.text) != 97 { panic "machine jcc byte length mismatch" }
    for i: 0:16 {
        let offset = i * 6
        if obj.text[offset] != 15 || obj.text[offset + 1] != 128 + i {
            panic "machine jcc opcode mismatch"
        }
    }
    if obj.text[96] != 195 { panic "machine jcc fixture must end in ret" }
}

fun main(): void {
    assert_machine_generic_register_bytes()
    assert_machine_high_register_bytes()
    assert_machine_immediate_bytes()
    assert_machine_jcc_bytes()
    let index = machine_name_index_new(2)
    machine_name_index_insert(index, "symbol_0", 7)
    machine_name_index_insert(index, "symbol_8", 11)
    if machine_name_index_lookup(index, "symbol_0") != 7 || machine_name_index_lookup(index, "symbol_8") != 11 {
        panic "machine name index collision lookup failed"
    }
    let obj = machine_build_object(build_machine_x64_fixture())
    if len(obj.symbol_names) != 4 || obj.symbol_names[0] != "_start" || obj.symbol_names[1] != "msg" || obj.symbol_names[2] != "scratch" || obj.symbol_names[3] != "ExitProcess" {
        panic "machine symbol order mismatch"
    }
    if len(obj.text) != 40 || obj.text[0] != 72 || obj.text[39] != 195 || len(obj.data) != 10 || obj.data[0] != 65 {
        panic "machine bytes mismatch"
    }
    if len(obj.text_reloc_offsets) != 2 || len(obj.data_reloc_offsets) != 0 {
        panic "machine relocation mismatch"
    }
}
