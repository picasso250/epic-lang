# Machine byte emission fixture for self-hosted machine.ep.

fun build_machine_x64_fixture(): X64Program {
    let program = x64_program_empty()
    x64_add_global(program, "_start")
    x64_add_extern(program, "ExitProcess")
    x64_add_section(program, ".data")

    let msg = new i64[]
    msg.push(65)
    msg.push(0)
    x64_add_data_bytes(program, "msg", msg)
    x64_add_data_zero(program, "scratch", 8)

    x64_add_section(program, ".text")
    let start = x64_new_symbol_label(program, "_start")
    let done = x64_new_label(program)
    x64_bind_label(program, start)
    x64_add_inst2(program, 1, x64_reg("rax"), x64_imm(1)) # x64 mov
    x64_add_inst2(program, 29, x64_reg("rax"), x64_imm(1)) # x64 cmp
    x64_add_inst1(program, 12, x64_label_ref(done)) # x64 jz
    x64_add_inst2(program, 1, x64_reg("rax"), x64_imm(2)) # x64 mov
    x64_bind_label(program, done)
    x64_add_inst2(program, 2, x64_reg("rdx"), x64_mem_symbol("msg", 8)) # x64 lea
    x64_add_inst2(program, 1, x64_reg("rcx"), x64_reg("rax")) # x64 mov
    x64_add_inst1(program, 3, x64_symbol("ExitProcess")) # x64 call
    x64_add_inst0(program, 4) # x64 ret
    ret program
}

fun build_machine_generic_register_fixture(): X64Program {
    let program = x64_program_empty()
    x64_add_section(program, ".text")
    x64_add_inst2(program, 31, x64_reg("r10"), x64_reg("r9")) # x64 imul
    x64_add_inst1(program, 34, x64_reg("r10")) # x64 neg
    x64_add_inst1(program, 33, x64_reg("r9")) # x64 idiv
    x64_add_inst1(program, 32, x64_reg("rsi")) # x64 div
    x64_add_inst2(program, 36, x64_reg("r10"), x64_reg("cl")) # x64 shl
    x64_add_inst2(program, 37, x64_reg("rsi"), x64_reg("cl")) # x64 shr
    x64_add_inst2(program, 38, x64_reg("r9"), x64_reg("cl")) # x64 sar
    ret program
}

fun assert_machine_generic_register_bytes(): void {
    let obj = machine_build_object(build_machine_generic_register_fixture())
    let expected = new i64[]
    expected.push(77)
    expected.push(15)
    expected.push(175)
    expected.push(209)
    expected.push(73)
    expected.push(247)
    expected.push(218)
    expected.push(73)
    expected.push(247)
    expected.push(249)
    expected.push(72)
    expected.push(247)
    expected.push(246)
    expected.push(73)
    expected.push(211)
    expected.push(226)
    expected.push(72)
    expected.push(211)
    expected.push(238)
    expected.push(73)
    expected.push(211)
    expected.push(249)
    if len(obj.text) != len(expected) {
        panic "machine generic register byte length mismatch"
    }
    let i = 0
    for i < len(expected) {
        if obj.text[i] != expected[i] {
            panic "machine generic register bytes mismatch"
        }
        i = i + 1
    }
}

fun build_machine_immediate_fixture(): X64Program {
    let program = x64_program_empty()
    x64_add_section(program, ".text")
    x64_add_inst2(program, 24, x64_reg("r10"), x64_imm(-1)) # x64 add
    x64_add_inst2(program, 27, x64_reg("r9"), x64_imm(4660)) # x64 or
    x64_add_inst2(program, 26, x64_reg("rsi"), x64_imm(255)) # x64 and
    x64_add_inst2(program, 25, x64_reg("r10"), x64_imm(127)) # x64 sub
    x64_add_inst2(program, 28, x64_reg("r9"), x64_imm(-129)) # x64 xor
    x64_add_inst2(program, 29, x64_reg("rsi"), x64_imm(5)) # x64 cmp
    x64_add_inst2(program, 36, x64_reg("r10"), x64_imm(3)) # x64 shl
    x64_add_inst2(program, 37, x64_reg("rsi"), x64_imm(8)) # x64 shr
    x64_add_inst2(program, 38, x64_reg("r9"), x64_imm(63)) # x64 sar
    let small_mul = new X64Operand[]
    small_mul.push(x64_reg("r10"))
    small_mul.push(x64_reg("r9"))
    small_mul.push(x64_imm(7))
    x64_add_inst(program, 31, small_mul) # x64 imul
    let wide_mul = new X64Operand[]
    wide_mul.push(x64_reg("rsi"))
    wide_mul.push(x64_reg("r10"))
    wide_mul.push(x64_imm(1000))
    x64_add_inst(program, 31, wide_mul) # x64 imul
    ret program
}

fun build_machine_high_register_fixture(): X64Program {
    let program = x64_program_empty()
    x64_add_section(program, ".text")
    x64_add_inst2(program, 1, x64_reg("r12"), x64_imm(305419896)) # x64 mov
    x64_add_inst2(program, 1, x64_reg("r13"), x64_reg("r14")) # x64 mov
    x64_add_inst2(program, 2, x64_reg("r15"), x64_mem_base("r12", 16, 8)) # x64 lea
    x64_add_inst2(program, 1, x64_mem_base("r13", 0, 8), x64_reg("r14")) # x64 mov
    x64_add_inst2(program, 1, x64_reg("r12d"), x64_mem_base("r15", 8, 4)) # x64 mov
    x64_add_inst2(program, 1, x64_mem_base("r14", 32, 2), x64_reg("r13w")) # x64 mov
    x64_add_inst2(program, 1, x64_mem_base("r15", 0, 1), x64_reg("r12b")) # x64 mov
    x64_add_inst2(program, 24, x64_reg("r15b"), x64_imm(1)) # x64 add
    ret program
}

