# Machine byte emission fixture for self-hosted machine.ep.

fun build_machine_x64_fixture(): X64Program {
    let program = x64_program_empty()
    x64_add_global(program, "_start")
    x64_add_extern(program, "ExitProcess")
    x64_add_section(program, ".data")

    let msg = new i64[]
    msg.push(65)
    msg.push(0)
    x64_add_data_bytes(program, "msg", msg)
    x64_add_data_zero(program, "scratch", 8)

    x64_add_section(program, ".text")
    let start = x64_new_symbol_label(program, "_start")
    let done = x64_new_label(program)
    x64_bind_label(program, start)
    x64_add_inst2(program, "mov", x64_reg("rax"), x64_imm(1))
    x64_add_inst2(program, "cmp", x64_reg("rax"), x64_imm(1))
    x64_add_inst1(program, "jz", x64_label_ref(done))
    x64_add_inst2(program, "mov", x64_reg("rax"), x64_imm(2))
    x64_bind_label(program, done)
    x64_add_inst2(program, "lea", x64_reg("rdx"), x64_mem_symbol("msg", 8))
    x64_add_inst2(program, "mov", x64_reg("rcx"), x64_reg("rax"))
    x64_add_inst1(program, "call", x64_symbol("ExitProcess"))
    x64_add_inst0(program, "ret")
    ret program
}

fun build_machine_generic_register_fixture(): X64Program {
    let program = x64_program_empty()
    x64_add_section(program, ".text")
    x64_add_inst2(program, "imul", x64_reg("r10"), x64_reg("r9"))
    x64_add_inst1(program, "neg", x64_reg("r10"))
    x64_add_inst1(program, "idiv", x64_reg("r9"))
    x64_add_inst1(program, "div", x64_reg("rsi"))
    x64_add_inst2(program, "shl", x64_reg("r10"), x64_reg("cl"))
    x64_add_inst2(program, "shr", x64_reg("rsi"), x64_reg("cl"))
    x64_add_inst2(program, "sar", x64_reg("r9"), x64_reg("cl"))
    ret program
}

fun assert_machine_generic_register_bytes(): void {
    let obj = machine_build_object(build_machine_generic_register_fixture())
    let expected = new i64[]
    expected.push(77)
    expected.push(15)
    expected.push(175)
    expected.push(209)
    expected.push(73)
    expected.push(247)
    expected.push(218)
    expected.push(73)
    expected.push(247)
    expected.push(249)
    expected.push(72)
    expected.push(247)
    expected.push(246)
    expected.push(73)
    expected.push(211)
    expected.push(226)
    expected.push(72)
    expected.push(211)
    expected.push(238)
    expected.push(73)
    expected.push(211)
    expected.push(249)
    if len(obj.text) != len(expected) {
        panic "machine generic register byte length mismatch"
    }
    let i = 0
    for i < len(expected) {
        if obj.text[i] != expected[i] {
            panic "machine generic register bytes mismatch"
        }
        i = i + 1
    }
}

fun build_machine_immediate_fixture(): X64Program {
    let program = x64_program_empty()
    x64_add_section(program, ".text")
    x64_add_inst2(program, "add", x64_reg("r10"), x64_imm(-1))
    x64_add_inst2(program, "or", x64_reg("r9"), x64_imm(4660))
    x64_add_inst2(program, "and", x64_reg("rsi"), x64_imm(255))
    x64_add_inst2(program, "sub", x64_reg("r10"), x64_imm(127))
    x64_add_inst2(program, "xor", x64_reg("r9"), x64_imm(-129))
    x64_add_inst2(program, "cmp", x64_reg("rsi"), x64_imm(5))
    x64_add_inst2(program, "shl", x64_reg("r10"), x64_imm(3))
    x64_add_inst2(program, "shr", x64_reg("rsi"), x64_imm(8))
    x64_add_inst2(program, "sar", x64_reg("r9"), x64_imm(63))
    let small_mul = new X64Operand[]
    small_mul.push(x64_reg("r10"))
    small_mul.push(x64_reg("r9"))
    small_mul.push(x64_imm(7))
    x64_add_inst(program, "imul", small_mul)
    let wide_mul = new X64Operand[]
    wide_mul.push(x64_reg("rsi"))
    wide_mul.push(x64_reg("r10"))
    wide_mul.push(x64_imm(1000))
    x64_add_inst(program, "imul", wide_mul)
    ret program
}

fun assert_machine_immediate_bytes(): void {
    let obj = machine_build_object(build_machine_immediate_fixture())
    let expected = new i64[]
    expected.push(73)
    expected.push(131)
    expected.push(194)
    expected.push(255)
    expected.push(73)
    expected.push(129)
    expected.push(201)
    expected.push(52)
    expected.push(18)
    expected.push(0)
    expected.push(0)
    expected.push(72)
    expected.push(129)
    expected.push(230)
    expected.push(255)
    expected.push(0)
    expected.push(0)
    expected.push(0)
    expected.push(73)
    expected.push(131)
    expected.push(234)
    expected.push(127)
    expected.push(73)
    expected.push(129)
    expected.push(241)
    expected.push(127)
    expected.push(255)
    expected.push(255)
    expected.push(255)
    expected.push(72)
    expected.push(131)
    expected.push(254)
    expected.push(5)
    expected.push(73)
    expected.push(193)
    expected.push(226)
    expected.push(3)
    expected.push(72)
    expected.push(193)
    expected.push(238)
    expected.push(8)
    expected.push(73)
    expected.push(193)
    expected.push(249)
    expected.push(63)
    expected.push(77)
    expected.push(107)
    expected.push(209)
    expected.push(7)
    expected.push(73)
    expected.push(105)
    expected.push(242)
    expected.push(232)
    expected.push(3)
    expected.push(0)
    expected.push(0)
    if len(obj.text) != len(expected) {
        panic "machine immediate byte length mismatch"
    }
    let i = 0
    for i < len(expected) {
        if obj.text[i] != expected[i] {
            panic "machine immediate bytes mismatch"
        }
        i = i + 1
    }
}

fun main(): void {
    assert_machine_generic_register_bytes()
    assert_machine_immediate_bytes()
    let index = machine_name_index_new(2)
    machine_name_index_insert(index, "symbol_0", 7)
    machine_name_index_insert(index, "symbol_8", 11)
    if machine_name_index_lookup(index, "symbol_0") != 7 || machine_name_index_lookup(index, "symbol_8") != 11 {
        panic "machine name index collision lookup failed"
    }
    let obj = machine_build_object(build_machine_x64_fixture())
    if len(obj.symbol_names) != 4 || obj.symbol_names[0] != "_start" || obj.symbol_names[1] != "msg" || obj.symbol_names[2] != "scratch" || obj.symbol_names[3] != "ExitProcess" {
        panic "machine symbol order mismatch"
    }
    if len(obj.text) != 40 || obj.text[0] != 72 || obj.text[39] != 195 || len(obj.data) != 10 || obj.data[0] != 65 {
        panic "machine bytes mismatch"
    }
    if len(obj.text_reloc_offsets) != 2 || len(obj.data_reloc_offsets) != 0 {
        panic "machine relocation mismatch"
    }
}
