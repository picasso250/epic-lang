fun comparison(op: str, result_id: i64, left: MirOperand, right: MirOperand): MirInst {
    let inst = mir_inst_empty()
    inst.op = op
    inst.result_id = result_id
    inst.result_type = "bool"
    inst.has_result = true
    inst.operands.push(left)
    inst.operands.push(right)
    ret inst
}

fun has_op(program: X64Program, op: i64): bool {
    for i: 0:len(program.items) {
        match program.items[i] {
            X64InstItem inst: { if inst.op == op { ret true } }
            _: {}
        }
    }
    ret false
}

fun has_materialized_bool(program: X64Program): bool {
    if has_op(program, 44) || has_op(program, 45) { ret true }
    if has_op(program, 47) || has_op(program, 49) { ret true }
    if has_op(program, 46) || has_op(program, 48) { ret true }
    if has_op(program, 52) || has_op(program, 53) { ret true }
    if has_op(program, 50) || has_op(program, 51) { ret true }
    ret has_op(program, 41) || has_op(program, 30)
}

fun assert_fused(op: str, typ: str, expected_jcc: i64): void {
    let program = mir_program_empty()
    let fused = mir_function_empty("fused", "i64")
    fused.params.push(new MirParam { typ: typ, value_id: 1 })
    fused.params.push(new MirParam { typ: typ, value_id: 2 })
    let entry = mir_block_empty("entry")
    entry.instructions.push(comparison(op, 3, mir_value_operand(typ, 1), mir_value_operand(typ, 2)))
    entry.terminator = mir_condbr(mir_value_operand("bool", 3), "yes", "no")
    entry.has_terminator = true
    let no = mir_block_empty("no")
    no.terminator = mir_ret_value(mir_const_int("i64", 0))
    no.has_terminator = true
    let yes = mir_block_empty("yes")
    yes.terminator = mir_ret_value(mir_const_int("i64", 1))
    yes.has_terminator = true
    fused.blocks.push(entry)
    fused.blocks.push(no)
    fused.blocks.push(yes)
    let lowered = mir_to_x64_lower_function_with_program(program, fused)
    if !has_op(lowered, 29) || !has_op(lowered, expected_jcc) {
        panic "terminal icmp must use its canonical direct branch"
    }
    if has_materialized_bool(lowered) {
        panic "fused icmp must not materialize a boolean"
    }
}

fun assert_materialized_value(): void {
    let program = mir_program_empty()
    let materialized = mir_function_empty("materialized", "bool")
    materialized.params.push(new MirParam { typ: "i64", value_id: 1 })
    materialized.params.push(new MirParam { typ: "i64", value_id: 2 })
    let entry = mir_block_empty("entry")
    entry.instructions.push(comparison("icmp.slt", 3, mir_value_operand("i64", 1), mir_value_operand("i64", 2)))
    entry.terminator = mir_ret_value(mir_value_operand("bool", 3))
    entry.has_terminator = true
    materialized.blocks.push(entry)
    let lowered = mir_to_x64_lower_function_with_program(program, materialized)
    if !has_op(lowered, 47) || !has_op(lowered, 41) {
        panic "icmp used as a value must remain materialized"
    }
}

fun main(): void {
    assert_fused("icmp.eq", "i64", 12)
    assert_fused("icmp.ne", "i64", 13)
    assert_fused("icmp.slt", "i64", 20)
    assert_fused("icmp.sle", "i64", 22)
    assert_fused("icmp.sgt", "i64", 23)
    assert_fused("icmp.sge", "i64", 21)
    assert_fused("icmp.ult", "u64", 10)
    assert_fused("icmp.ule", "u64", 14)
    assert_fused("icmp.ugt", "u64", 15)
    assert_fused("icmp.uge", "u64", 11)
    assert_materialized_value()
}
