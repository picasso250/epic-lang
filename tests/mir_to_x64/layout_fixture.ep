fun main(): void {
    let program = mir_program_empty()
    mir_program_add_struct_layout(program, "Twelve", 12, 4)
    let fn = mir_function_empty("stride", "ptr")
    fn.params.push(new MirParam { typ: "ptr", value_id: 1 })
    fn.params.push(new MirParam { typ: "i64", value_id: 2 })
    let entry = mir_block_empty("entry")
    let gep = mir_gep(3, "ptr", "struct Twelve", new MirOperand[] { mir_value_operand("ptr", 1), mir_value_operand("i64", 2) })
    entry.instructions.push(gep)
    entry.terminator = mir_ret_value(mir_value_operand("ptr", 3))
    entry.has_terminator = true
    fn.blocks.push(entry)

    let lowered = mir_to_x64_lower_function_with_program(program, fn)
    let saw_scale = false
    let saw_multiply = false
    for i: 0:len(lowered.items) {
        match lowered.items[i] {
            X64InstItem inst: {
                if inst.op == 31 { saw_multiply = true } # x64 imul
                for j: 0:len(inst.operands) {
                    match inst.operands[j] {
                        X64ImmOperand imm: { if imm.value == 12 { saw_scale = true } }
                        _: {}
                    }
                }
            }
            _: {}
        }
    }
    if !saw_scale || !saw_multiply { panic "dynamic struct GEP must multiply by explicit size" }
}
