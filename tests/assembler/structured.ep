fun equal_bytes(a: u8[], b: u8[]): i64 {
    if len(a) != len(b) {
        return 0
    }
    for i: 0:len(a) {
        if a.data[i] != b.data[i] {
            return 0
        }
    }
    return 1
}

fun main(): void {
    let program = asm_program_new()
    program.entry_symbol = "_start"
    asm_section_data(program)
    asm_label(program, "value")
    asm_dq(program, 0)
    let payload = new u8[]
    push(payload, 1)
    push(payload, 2)
    push(payload, 3)
    asm_label(program, "payload")
    asm_bytes(program, payload)
    asm_section_text(program)
    asm_label(program, "_start")
    asm_mov(program, asm_rax(), asm_imm(7))
    asm_mov(program, asm_mem_symbol(64, "value", 0), asm_imm(0))
    asm_jmp(program, asm_symbol("done"))
    asm_label(program, "done")
    asm_ret(program)

    let rendered = asm_render(program)
    let newline_count = 0
    for i: 0:len(rendered) {
        if rendered.data[i] == 10 {
            newline_count += 1
        }
    }
    if newline_count != len(program.items) + 2 {
        os.ExitProcess(1)
    }

    let parsed = asm_parse(str_new(rendered.data, len(rendered)))
    let direct = asm_encode(program)
    let roundtrip = asm_encode(parsed)
    if equal_bytes(direct.text, roundtrip.text) == 0 {
        os.ExitProcess(2)
    }
    if equal_bytes(direct.data, roundtrip.data) == 0 {
        os.ExitProcess(3)
    }
    if direct.entry_offset != roundtrip.entry_offset {
        os.ExitProcess(4)
    }
    if len(direct.relocs) != len(roundtrip.relocs) {
        os.ExitProcess(5)
    }
    for reloc_i: 0:len(direct.relocs) {
        let a = direct.relocs.data[reloc_i]
        let b = roundtrip.relocs.data[reloc_i]
        if a.kind != b.kind || a.symbol != b.symbol || a.addend != b.addend {
            os.ExitProcess(6)
        }
    }

    let presentation = asm_parse("; ignored\n\nsection .text\nentry: ; ignored\n    ret\n")
    if len(presentation.items) != 3 {
        os.ExitProcess(7)
    }
    os.ExitProcess(0)
}
