fun main(): void {
    let image = assemble_text("section .data\nvalue:\n    dq 0\nsection .text\n    mov qword [value], 0\n    mov byte [value], 0\n")
    if image.relocs.len != 2 {
        os.ExitProcess(1)
    }
    if image.relocs.data[0].addend != 0 - 4 {
        os.ExitProcess(2)
    }
    if image.relocs.data[1].addend != 0 - 1 {
        os.ExitProcess(3)
    }
    let forward = assemble_text("section .text\n    call aaa\n    call rbq\naaa:\n    ret\nrbq:\n    ret\n")
    if forward.relocs.data[0].symbol_index == forward.relocs.data[1].symbol_index {
        os.ExitProcess(4)
    }
    if forward.relocs.data[0].symbol_index != asm_symbol_find(forward, "aaa") {
        os.ExitProcess(5)
    }
    if forward.relocs.data[1].symbol_index != asm_symbol_find(forward, "rbq") {
        os.ExitProcess(6)
    }
    os.ExitProcess(0)
}
