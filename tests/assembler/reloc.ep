fun main(): void {
    let image = assemble_text("section .data\nvalue:\n    dq 0\nsection .text\n    mov qword [value], 0\n    mov byte [value], 0\n")
    if image.relocs.len != 2 {
        os.ExitProcess(1)
    }
    if image.relocs.data[0].addend != 0 - 4 {
        os.ExitProcess(2)
    }
    if image.relocs.data[1].addend != 0 - 1 {
        os.ExitProcess(3)
    }
    os.ExitProcess(0)
}
