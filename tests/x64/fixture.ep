# X64IR pretty-print fixture for the self-hosted x64 DTO.

fun check_local_peephole(): void {
    let program = x64_program_empty()
    x64_add_inst2(program, 1, x64_mem_base("rbp", -8, 8), x64_reg("rax")) # x64 mov
    x64_add_inst2(program, 1, x64_reg("rax"), x64_mem_base("rbp", -8, 8)) # x64 mov
    if len(program.items) != 1 { panic "same-register stack reload must be removed" }

    x64_add_inst2(program, 1, x64_reg("rcx"), x64_mem_base("rbp", -8, 8)) # x64 mov
    if len(program.items) != 2 { panic "different-register reload must remain" }

    let label = x64_new_label(program)
    x64_bind_label(program, label)
    x64_add_inst2(program, 1, x64_reg("rax"), x64_mem_base("rbp", -8, 8)) # x64 mov
    if len(program.items) != 4 { panic "label must block reload peephole" }

    let branches = x64_program_empty()
    let fallthrough = x64_new_label(branches)
    x64_add_inst1(branches, 7, x64_label_ref(fallthrough)) # x64 jmp
    x64_bind_label(branches, fallthrough)
    if len(branches.items) != 1 { panic "jump to immediately bound label must be removed" }

    let retained = x64_program_empty()
    let other = x64_new_label(retained)
    let bound = x64_new_label(retained)
    x64_add_inst1(retained, 7, x64_label_ref(other)) # x64 jmp
    x64_bind_label(retained, bound)
    if len(retained.items) != 2 { panic "jump to another label must remain" }

    let inverted = x64_program_empty()
    let next = x64_new_label(inverted)
    let away = x64_new_label(inverted)
    x64_add_inst1(inverted, 13, x64_label_ref(next)) # x64 jnz
    x64_add_inst1(inverted, 7, x64_label_ref(away)) # x64 jmp
    x64_bind_label(inverted, next)
    if len(inverted.items) != 2 { panic "conditional fallthrough must remove trailing jump" }
    match inverted.items[0] {
        X64InstItem branch: {
            if branch.op != 12 { panic "conditional fallthrough must invert branch" }
            match branch.operands[0] {
                X64LabelRefOperand target: {
                    if target.label.id != away.id { panic "inverted branch must target former jump destination" }
                }
                _: { panic "inverted branch target must remain a label" }
            }
        }
        _: { panic "inverted branch must remain an instruction" }
    }

    let conditions = new i64[]
    conditions.push(8) # x64 jo
    conditions.push(9) # x64 jno
    conditions.push(10) # x64 jb
    conditions.push(11) # x64 jae
    conditions.push(12) # x64 jz
    conditions.push(13) # x64 jnz
    conditions.push(14) # x64 jbe
    conditions.push(15) # x64 ja
    conditions.push(16) # x64 js
    conditions.push(17) # x64 jns
    conditions.push(18) # x64 jp
    conditions.push(19) # x64 jnp
    conditions.push(20) # x64 jl
    conditions.push(21) # x64 jge
    conditions.push(22) # x64 jle
    conditions.push(23) # x64 jg
    for i: 0:len(conditions) {
        let inverse = x64_invert_jcc(conditions[i])
        if inverse == 0 || x64_invert_jcc(inverse) != conditions[i] {
            panic "jcc inverse mapping must be complete and symmetric"
        }
    }
}

fun build_x64_fixture(): X64Program {
    let program = x64_program_empty()
    x64_add_global(program, "_start")
    x64_add_extern(program, "ExitProcess")
    x64_add_section(program, ".rdata")
    x64_add_data_bytes(program, "ro", new u8[] { u8(7) })
    x64_add_section(program, ".data")

    let msg = new u8[]
    msg.push(u8(65))
    msg.push(u8(255))
    msg.push(u8(0))
    x64_add_data_bytes(program, "msg", msg)
    x64_add_data_zero(program, "scratch", 8)

    x64_add_section(program, ".text")
    let start = x64_new_symbol_label(program, "_start")
    let done = x64_new_label(program)
    x64_bind_label(program, start)
    x64_add_inst2(program, 1, x64_reg("rax"), x64_imm(1)) # x64 mov
    x64_add_inst2(program, 29, x64_reg("rax"), x64_imm(1)) # x64 cmp
    x64_add_inst1(program, 12, x64_label_ref(done)) # x64 jz
    x64_add_inst2(program, 1, x64_reg("rax"), x64_imm(2)) # x64 mov
    x64_bind_label(program, done)
    x64_add_inst2(program, 2, x64_reg("rdx"), x64_mem_symbol("msg", 8)) # x64 lea
    x64_add_inst2(program, 1, x64_reg("rcx"), x64_reg("rax")) # x64 mov
    x64_add_inst1(program, 3, x64_symbol("ExitProcess")) # x64 call
    x64_add_inst0(program, 4) # x64 ret
    ret program
}

fun main(): void {
    check_local_peephole()
    print(x64_program_text(build_x64_fixture()))
}
