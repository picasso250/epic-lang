# MIR-CODEGEN: map new/get/set/has/del for word, bool, str, and pointer maps.
struct Box {
    value: i64
}

fun main(): i64 {
    let ids = new map[str]i64 { "main": 1 }
    ids["main"] += 100
    if ids["main"] != 101 { ret 1 }
    if ids.has("main") == false { ret 2 }
    if ids.del("main") == false { ret 3 }

    let flags = new map[str]bool
    flags["ok"] = true
    if flags["ok"] == false { ret 4 }

    let names = new map[str]str { "a": "one" }
    if names["a"] != "one" { ret 5 }
    let boxes = new map[str]Box
    boxes["b"] = new Box { value: 9 }
    if boxes["b"].value != 9 { ret 6 }
    ret 0
}
