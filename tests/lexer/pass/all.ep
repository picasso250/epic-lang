# tests/lexer/pass/all.ep
# Lexer golden fixture -- covers all important token kinds.
# Not required to pass parser/sema/e2e. This is a lexer-only spec sample.

fun main(): i64 {
    # -- Keywords ---------------------------------------------------
    let a = true
    let b = false
    if a { ret 1 }
    else { ret 2 }
    for false { break }
    for i: 0:10 { continue }
    struct Point {
        x: i64
        y: i64
    }
    let x = new Point { x: 1, y: 2 }
    type Maybe {
        None
        Some {
            v: i64
        }
    }
    match a {
        1: {
            ret 0
        }
        _: {
            ret 1
        }
    }

    # -- Identifiers ------------------------------------------------
    let while = 0
    let in = 0
    let assert = 0
    let UPPER_CASE = 0
    let mixed123 = 0
    let a_b_c = 0

    # -- Numbers ----------------------------------------------------
    let n0 = 0
    let n1 = 1
    let big = 9223372036854775807

    # -- Strings ----------------------------------------------------
    let s0 = "hello"
    let s1 = "line1\nline2"
    let s2 = "tab\there"
    let s3 = "back\\slash"
    let s4 = "quote\"here"
    let s5 = ""
    let s6 = "multi"
           + "line"

    # -- Chars ------------------------------------------------------
    let c0 = 'a'
    let c1 = '\n'
    let c2 = '\t'
    let c3 = '\\'
    let c4 = '\''

    # -- F-strings --------------------------------------------------
    let f0 = f"hello {name}"
    let f1 = f"a\n{ value }!"
    let f2 = f"{x} + {y} = {x + y}"

    # -- Comments (already present throughout this file) ------------
    # this is a single-line comment

    # -- Punctuation ------------------------------------------------
    let paren = (1 + 2)
    let brace = [1, 2, 3]
    let curly = { 0 }
    let comma = (1, 2)
    let colon = 0
    let dot = 0

    # -- Operators --------------------------------------------------
    let arith = 1 + 2 - 3 * 4 / 5 % 6
    let bit = 1 & 2 | 3 ^ 4
    let shift = 1 << 2 >> 3 >>> 4
    let comp = 1 == 2 != 3 < 4 <= 5 > 6 >= 7
    let logic = true && false || !true
    let neg = ~0
    let assign = 1
    assign += 1
    assign -= 1
    assign *= 1
    assign /= 1
    assign %= 1
    assign &= 1
    assign |= 1
    assign ^= 1
    assign <<= 1
    assign >>= 1
    assign >>>= 1

    # -- Language-ish structures ------------------------------------
    # Struct field access
    let px = x.x

    # Index access
    let first = brace[0]

    # Slice
    let slice = brace[1..3]

    # Function call
    let result = foo(1, 2)

    # Dotted call (module-style)
    let code = foo.bar.baz(0)
    ret 0
}

# Separate function to force edge-case tokens on dedicated lines
fun operators(): i64 {
    let a = 1 + 2
    let b = 1 - 2
    let c = 1 * 2
    let d = 1 / 2
    let e = 1 % 2
    let f = 1 ^ 2
    let g = 1 & 2
    let h = 1 | 2
    let i = 1 << 2
    let j = 1 >> 2
    let k = 1 >>> 2
    let l = 1 == 2
    let m = 1 != 2
    let n = 1 < 2
    let o = 1 <= 2
    let p = 1 > 2
    let q = 1 >= 2
    let r = true && false
    let s = false || true
    let t = !true
    let u = ~0
    ret 0
}

fun structs(): Point {
    ret Point { x: 0, y: 0 }
}

fun calls(): i64 {
    let x = foo()
    let y = foo(1)
    let z = foo(1, 2)
    let w = mod.func(1)
    let v = a.b.c.d(1)
    ret 0
}
