# EXIT: 0
# STDOUT: 3
# STDOUT: gone
fun main(): i64 {
    let counts = new map[str]i64
    counts["epic"] = 1
    counts["epic"] = counts["epic"] + 2
    println(str(counts["epic"]))

    if counts.del("epic") {
        if counts.has("epic") == false {
            println("gone")
        }
    }
    ret 0
}
