# EXIT 0
# STDOUT Epic
# STDOUT 69
fun main() -> i64 {
    let buf = new i8[10];
    buf.data[0] = 'E';
    buf.data[1] = 'p';
    buf.data[2] = 'i';
    buf.data[3] = 'c';
    buf.data[4] = 10;

    let i = 0;
    while i < 5 {
        putc(buf.data[i]);
        i = i + 1;
    }
    puti(buf.data[0]);
    exit(0);
}
