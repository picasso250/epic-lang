# EXIT: 0
# STDOUT: true
# CLEAN: test_sys_create.tmp

fun main(): void {
    os.kernel32.Sleep(1)
    let t = os.kernel32.GetTickCount64()
    let n = os.kernel32.lstrlenA(cstr("abc"))
    let c = os.kernel32.lstrcmpA(cstr("same"), cstr("same"))
    let h = os.kernel32.CreateFileA(cstr("test_sys_create.tmp"), 1073741824, 0, 0, 2, 128, 0)
    if t >= 0 && n == 3 && c == 0 && h + 1 != 0 {
        os.kernel32.CloseHandle(h)
        println(str(true))
        exit(0)
    }
    exit(1)
}
