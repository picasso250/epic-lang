# EXIT: 0
# STDOUT: hello world
# CLEAN: test_append_file.txt
fun main() -> void {
    let path = "test_append_file.txt"
    let n = write_file(path, bytes("hello"))
    if n != 5 {
        sys.ExitProcess(1)
    }
    n = append_file(path, bytes(" "))
    if n != 1 {
        sys.ExitProcess(2)
    }
    n = append_file(path, bytes("world"))
    if n != 5 {
        sys.ExitProcess(3)
    }
    let s = str(read_file(path))
    putstr(s)
    sys.ExitProcess(0)
}
