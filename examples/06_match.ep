# EXIT: 0
# STDOUT: int
# STDOUT: str
fun main(): void {
    let n = 1
    match n {
        0: {
            println("zero")
        }
        1: {
            println("int")
        }
        _: {
            println("many")
        }
    }

    let name = "epic"
    match name {
        "epic": {
            println("str")
        }
        _: {
            println("other")
        }
    }
}
