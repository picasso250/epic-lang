# EXIT: 0
# STDOUT: 42
type Lit = {
    value: i64
}

type Add = {
    left: i64
    right: i64
}

type Expr = Lit | Add

fun eval(e: Expr): i64 {
    let out = 0
    match e {
        Lit lit: {
            out = lit.value
        }
        Add add: {
            out = add.left + add.right
        }
    }
    ret out
}

fun main(): void {
    let e: Expr = new Expr(new Add { left: 20, right: 22 })
    println(str(eval(e)))
}
