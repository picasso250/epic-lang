# EXIT: 0
# STDOUT: 3
# STDOUT: 1
# STDOUT: 70
# STDOUT: 9
# STDOUT: -5
# STDOUT: -5
# STDOUT: 5
fun main(): void {
    println(str(10 / 3))
    println(str(10 % 3))
    println(str(10 + 20 * 3))
    println(str((1 + 2) * 3))
    println(str(0 - 5))
    println(str(-5))
    println(str(10 - 3 - 2))
    exit(0)
}
