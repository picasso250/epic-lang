# Test: dynamic struct arrays store object references

struct Point {
    x: i64
    y: i64
}

fun main(): void {
    let points = new Point[4]
    let p = new Point {}
    p.x = 42
    p.y = 99

    push(points, p)

    let p2 = points.data[0]
    let result = p2.x + p2.y
    exit(result)
}
# EXIT: 141
