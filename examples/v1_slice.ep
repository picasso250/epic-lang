# EXIT: 0
# STDOUT: picEpicpicEpEi
fun main(): void {
    let s = "Epic"
    print(s[1:4])
    print(s[0:len(s)])
    print(s[1:len(s)])
    print(s[0:2])

    let xs = new u8[4]
    push(xs, 'x')
    push(xs, 'E')
    push(xs, 'i')
    push(xs, 'x')
    let ys = xs[1:3]
    xs[1] = 'Z'
    println(str(ys))

    exit(0)
}
