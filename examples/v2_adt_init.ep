# EXIT: 0
# STDOUT: 012

type Expr {
    Empty

    IntLit {
        value: i64
    }

    Binary {
        op: str
        left: Expr
        right: Expr
    }
}

fun main(): i64 {
    let z: Expr
    let a = new Expr.IntLit { value: 123 }
    let b = new Expr.Binary { op: "+", left: z, right: a }
    print(z.tag)
    print(a.tag)
    print(b.tag)
    return 0
}
