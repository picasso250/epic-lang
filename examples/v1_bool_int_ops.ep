# EXIT: 0
# STDOUT: OK
# STDOUT: 90
# STDOUT: 65
fun main(): void {
    let ok: bool = true
    let b: u8 = 'A'
    let mask: u64 = 240
    let low: u64 = 15
    if ok && !false {
        println("OK")
    }
    let combined: u64 = (mask | low) ^ 165
    if combined == 90 {
        println(combined)
    }
    let shifted: u64 = (u64(b) << 1) >>> 1
    println(shifted)
    os.ExitProcess(0)
}
