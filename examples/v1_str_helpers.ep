# EXIT: 0
# STDOUT: 105-1trim me
fun main(): void {
    let s = "epic language"
    putstr(itoa(str_starts_with(s, "epic")))
    putstr(itoa(str_starts_with(s, "lang")))
    putstr(itoa(str_find(s, "language")))
    putstr(itoa(str_find(s, "missing")))
    putstr(str_trim(" \t\r\ntrim me\n "))
    os.ExitProcess(0)
}
