# EXIT: 0
# STDOUT: 3
# STDOUT: 1
# STDOUT: 6
fun main(): void {
    let xs = new i64[]
    push(xs, 1)
    push(xs, 2)
    push(xs, 3)

    print(itoa(len(xs)))
    print("\n")
    print(itoa(xs[0]))
    print("\n")

    let total = 0
    let i = 0
    while i < len(xs) {
        total = total + xs[i]
        i = i + 1
    }
    print(itoa(total))
    print("\n")
}
