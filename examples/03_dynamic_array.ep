# EXIT: 0
# STDOUT: 3
# STDOUT: 1
# STDOUT: 6
fun main(): void {
    let xs = new i64[]
    push(xs, 1)
    push(xs, 2)
    push(xs, 3)

    print(itoa(xs.len))
    print("\n")
    print(itoa(xs.data[0]))
    print("\n")

    let total = 0
    let i = 0
    for i < xs.len {
        total = total + xs.data[i]
        i = i + 1
    }
    print(itoa(total))
    print("\n")
}
