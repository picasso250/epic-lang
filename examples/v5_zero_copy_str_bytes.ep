# EXIT: 0
# STDOUT: AbcAef
fun main(): void {
    # Test 1: bytes(str) shares buffer with string literal
    let s = "abc"
    let bs = bytes(s)
    bs[0] = 'A'
    print(s)

    # Test 2: str(u8[]) is identity, bytes(str) shares same buffer
    let arr = new u8[] { u8(65), u8(66), u8(99) }
    let s2 = str(arr)
    let bs2 = bytes(s2)
    bs2[1] = 'e'
    bs2[2] = 'f'
    println(s2)
    exit(0)
}
