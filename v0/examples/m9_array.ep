# EXIT: 0
# STDOUT: Epic
# STDOUT: 69
fun main(): void {
    let buf = new i8[10]
    buf.data[0] = 'E'
    buf.data[1] = 'p'
    buf.data[2] = 'i'
    buf.data[3] = 'c'
    buf.data[4] = 10
    let i = 0
    while i < 5 {
        putc(buf.data[i])
        i = i + 1
    }
    putstr(itoa(buf.data[0]))
    putc(10)
    os.ExitProcess(0)
}
